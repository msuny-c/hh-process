POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public
JWT_SECRET=
SERVER_PORT=8080
NARAYANA_LOG_DIR=./transaction-logs
NARAYANA_NODE_IDENTIFIER=hh-process-local
NARAYANA_DEFAULT_TIMEOUT=60

APP_SECURITY_USERS_XML=./data/users.xml

# Внешняя EIS (пусто = in-memory внутри JCA в том же процессе)
# Docker Compose: контейнер external-eis не поднимается по умолчанию.
# Чтобы поднять мок EIS: в .env добавьте COMPOSE_PROFILES=eis и строку ниже:
# APP_EIS_REMOTE_BASE_URL=http://external-eis:8090
# Локально без Docker: APP_EIS_REMOTE_BASE_URL=http://127.0.0.1:8090

# CI/CD: repository variable SKIP_EXTERNAL_EIS=true — не собирать/не выкладывать external-eis на сервер (API без APP_EIS_REMOTE_BASE_URL).

# Optional for deploy workflow when helios reaches the DB through a reverse SSH tunnel
# VPS_SSH_HOST / VPS_SSH_USER / VPS_SSH_PORT — в GitHub: Secrets или Variables (workflow подставляет secrets || vars).
DB_TUNNEL_REMOTE_HOST=127.0.0.1
DB_TUNNEL_REMOTE_PORT=5432
# Порт на helios, который reverse SSH ведёт на external-eis на VPS (127.0.0.1:8090). Задаётся как GitHub Actions variable EIS_TUNNEL_LOCAL_PORT (по умолчанию 18090).
