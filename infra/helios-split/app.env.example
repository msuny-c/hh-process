


APP_ROLE=api
APP_INSTANCE_NAME=hh-api-wildfly


SERVER_PORT=18081
APP_HTTP_PORT=18081
APP_MGMT_PORT=19081




POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public


CAMUNDA_ENABLED=true
CAMUNDA_BASE_URL=http://127.0.0.1:18082/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo
CAMUNDA_FAIL_ON_ERROR=true
CAMUNDA_WORKER_ENABLED=true
CAMUNDA_WORKER_INITIAL_DELAY_MS=1000
CAMUNDA_IDENTITY_SYNC_INITIAL_PASSWORD=camunda
APP_TIMEOUT_LOCAL_SCHEDULER_ENABLED=false


APP_HOME=${HOME}/apps/hh-process
NARAYANA_LOG_DIR=${APP_HOME}/transaction-logs
NARAYANA_NODE_IDENTIFIER=hh-process-helios
APP_SECURITY_USERS_XML=${APP_HOME}/data/users.xml
WS_ALLOWED_ORIGINS=*


JAVA_OPTS=-Xms128m -Xmx768m -Dorg.springframework.boot.logging.LoggingSystem=none
