# Runtime environment for hh-process on WildFly host (Helios API machine)
# This file is generated by .github/workflows/deploy-split-helios.yml during CI deploy.

APP_ROLE=api
APP_INSTANCE_NAME=hh-api-wildfly

# WildFly HTTP port. Do not use 8080 on Helios; it is often busy.
SERVER_PORT=18081
APP_HTTP_PORT=18081
APP_MGMT_PORT=19081

# External PostgreSQL/VPS connection.
# If POSTGRES_HOST=localhost, the workflow can create reverse SSH tunnel VPS -> Helios:
#   Helios localhost:${POSTGRES_PORT} -> VPS ${DB_TUNNEL_REMOTE_HOST}:${DB_TUNNEL_REMOTE_PORT}
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public

# Camunda standalone service on the second Helios machine.
CAMUNDA_ENABLED=true
CAMUNDA_BASE_URL=http://127.0.0.1:18082/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo
CAMUNDA_FAIL_ON_ERROR=true
CAMUNDA_WORKER_ENABLED=true
CAMUNDA_IDENTITY_SYNC_INITIAL_PASSWORD=camunda

# App runtime files on Helios.
APP_HOME=${HOME}/apps/hh-process
NARAYANA_LOG_DIR=${APP_HOME}/transaction-logs
NARAYANA_NODE_IDENTIFIER=hh-process-helios
APP_SECURITY_USERS_XML=${APP_HOME}/data/users.xml
WS_ALLOWED_ORIGINS=*

# Java options for Helios memory limits.
JAVA_OPTS=-Xms128m -Xmx768m -Dorg.springframework.boot.logging.LoggingSystem=none
