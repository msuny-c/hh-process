<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_hh_ui_recruiter_schedule" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED" />
  <bpmn:collaboration id="Collaboration_hhUiRecruiterSchedule" name="Пул: экран расписания рекрутера">
    <bpmn:participant id="Participant_hhUiRecruiterSchedule" name="Пул: экран расписания рекрутера" processRef="hhUiRecruiterSchedule" />
  </bpmn:collaboration>
  <bpmn:process id="hhUiRecruiterSchedule" name="Экран расписания рекрутера" isExecutable="true" camunda:candidateStarterGroups="RECRUITER,ADMIN" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_hhUiRecruiterSchedule">
      <bpmn:lane id="Lane_hhUiRecruiterSchedule_RoleSystem" name="Рекрутер / администратор / система">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EnterScheduleWeek</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LoadRecruiterSchedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>DisplayRecruiterSchedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterScheduleValidationError</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Рекрутер открыл расписание интервью" camunda:initiator="starterUserId" />
    <bpmn:userTask id="EnterScheduleWeek" name="Выбрать неделю для просмотра расписания" camunda:formRef="schedule-week-input-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:serviceTask id="LoadRecruiterSchedule" name="Загрузить интервью рекрутера за выбранную неделю" camunda:type="external" camunda:topic="ui-query" />
    <bpmn:userTask id="DisplayRecruiterSchedule" name="Показать расписание интервью рекрутера" camunda:formRef="ui-json-display-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:endEvent id="End" name="Расписание показано рекрутеру" />
    <bpmn:boundaryEvent id="RecruiterScheduleValidationError" attachedToRef="LoadRecruiterSchedule">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="EnterScheduleWeek" />
    <bpmn:sequenceFlow id="F2e" name="ошибка формы -&#62; повторить ввод" sourceRef="RecruiterScheduleValidationError" targetRef="EnterScheduleWeek" />
    <bpmn:sequenceFlow id="F2" sourceRef="EnterScheduleWeek" targetRef="LoadRecruiterSchedule" />
    <bpmn:sequenceFlow id="F3" sourceRef="LoadRecruiterSchedule" targetRef="DisplayRecruiterSchedule" />
    <bpmn:sequenceFlow id="F4" sourceRef="DisplayRecruiterSchedule" targetRef="End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_hhUiRecruiterSchedule">
    <bpmndi:BPMNPlane id="BPMNPlane_hhUiRecruiterSchedule" bpmnElement="Collaboration_hhUiRecruiterSchedule">
      <bpmndi:BPMNShape id="BPMNShape_Participant_hhUiRecruiterSchedule" bpmnElement="Participant_hhUiRecruiterSchedule" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1556" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_hhUiRecruiterSchedule_RoleSystem" bpmnElement="Lane_hhUiRecruiterSchedule_RoleSystem" isHorizontal="true">
        <dc:Bounds x="260" y="100" width="1436" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Start" bpmnElement="Start">
        <dc:Bounds x="300" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="288" y="198" width="60" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EnterScheduleWeek" bpmnElement="EnterScheduleWeek">
        <dc:Bounds x="455" y="140" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_LoadRecruiterSchedule" bpmnElement="LoadRecruiterSchedule">
        <dc:Bounds x="735" y="140" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_DisplayRecruiterSchedule" bpmnElement="DisplayRecruiterSchedule">
        <dc:Bounds x="995" y="140" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End" bpmnElement="End">
        <dc:Bounds x="1260" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1248" y="198" width="61" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RecruiterScheduleValidationError" bpmnElement="RecruiterScheduleValidationError">
        <dc:Bounds x="887" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_F1" bpmnElement="F1">
        <di:waypoint x="336" y="180" />
        <di:waypoint x="455" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F2" bpmnElement="F2">
        <di:waypoint x="625" y="180" />
        <di:waypoint x="735" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F2e" bpmnElement="F2e">
        <di:waypoint x="905" y="238" />
        <di:waypoint x="905" y="250" />
        <di:waypoint x="540" y="250" />
        <di:waypoint x="540" y="220" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="679" y="226" width="86" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F3" bpmnElement="F3">
        <di:waypoint x="905" y="180" />
        <di:waypoint x="995" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F4" bpmnElement="F4">
        <di:waypoint x="1165" y="180" />
        <di:waypoint x="1260" y="180" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
