<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_hh_ui_candidate_application_view" targetNamespace="http://itmo.ru/hhprocess/camunda">
  <bpmn:process id="hhUiCandidateApplicationView" name="HH UI candidate application view" isExecutable="true" camunda:candidateStarterGroups="CANDIDATE,ADMIN" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="Start" camunda:initiator="starterUserId"/>
    <bpmn:userTask id="EnterCandidateApplicationId" name="Выбрать отклик" camunda:formRef="application-id-input-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE,ADMIN"/>
    <bpmn:serviceTask id="LoadCandidateApplicationView" name="Загрузить отклик кандидата" camunda:type="external" camunda:topic="ui-query"/>
    <bpmn:userTask id="DisplayCandidateApplicationView" name="Просмотр отклика кандидата" camunda:formRef="ui-json-display-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE,ADMIN"/>
    <bpmn:endEvent id="End"/>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="EnterCandidateApplicationId"/>
    <bpmn:sequenceFlow id="F2" sourceRef="EnterCandidateApplicationId" targetRef="LoadCandidateApplicationView"/>
    <bpmn:sequenceFlow id="F3" sourceRef="LoadCandidateApplicationView" targetRef="DisplayCandidateApplicationView"/>
    <bpmn:sequenceFlow id="F4" sourceRef="DisplayCandidateApplicationView" targetRef="End"/>
  </bpmn:process>
</bpmn:definitions>
