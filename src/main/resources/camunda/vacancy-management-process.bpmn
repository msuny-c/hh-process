<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_VacancyManagement" targetNamespace="http://itmo.ru/hhprocess/camunda">
  <bpmn:process id="vacancy-management-process" name="Vacancy Management Process" isExecutable="true">
    <bpmn:startEvent id="Start_VacancyManagement" name="Recruiter manages vacancy">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="vacancyOperation" label="Operation" type="enum">
            <camunda:value id="CREATE" name="Create" />
            <camunda:value id="UPDATE" name="Update" />
            <camunda:value id="CLOSE" name="Close" />
            <camunda:validation><camunda:constraint name="required" /></camunda:validation>
          </camunda:formField>
          <camunda:formField id="recruiterUserId" label="Recruiter email" type="string">
            <camunda:validation><camunda:constraint name="required" /></camunda:validation>
          </camunda:formField>
          <camunda:formField id="vacancyId" label="Vacancy ID" type="string" />
          <camunda:formField id="vacancyTitle" label="Title" type="string" />
          <camunda:formField id="vacancyDescription" label="Description" type="string" />
          <camunda:formField id="requiredSkillsCsv" label="Required skills CSV" type="string" />
          <camunda:formField id="screeningThreshold" label="Screening threshold" type="long" />
          <camunda:formField id="vacancyStatus" label="Status" type="enum">
            <camunda:value id="ACTIVE" name="Active" />
            <camunda:value id="CLOSED" name="Closed" />
          </camunda:formField>
          <camunda:formField id="vacancyCloseReason" label="Close reason" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_Operation</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_VacancyOperation" name="Operation?">
      <bpmn:incoming>Flow_Start_Operation</bpmn:incoming>
      <bpmn:outgoing>Flow_Operation_Create</bpmn:outgoing>
      <bpmn:outgoing>Flow_Operation_Update</bpmn:outgoing>
      <bpmn:outgoing>Flow_Operation_Close</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_CreateVacancy" name="Create vacancy" camunda:type="external" camunda:topic="create-vacancy">
      <bpmn:incoming>Flow_Operation_Create</bpmn:incoming>
      <bpmn:outgoing>Flow_Create_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UpdateVacancy" name="Update vacancy" camunda:type="external" camunda:topic="update-vacancy">
      <bpmn:incoming>Flow_Operation_Update</bpmn:incoming>
      <bpmn:outgoing>Flow_Update_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CloseVacancy" name="Close vacancy and related applications" camunda:type="external" camunda:topic="close-vacancy">
      <bpmn:incoming>Flow_Operation_Close</bpmn:incoming>
      <bpmn:outgoing>Flow_Close_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_VacancyCreated" name="Vacancy created"><bpmn:incoming>Flow_Create_End</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="End_VacancyUpdated" name="Vacancy updated"><bpmn:incoming>Flow_Update_End</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="End_VacancyClosed" name="Vacancy closed"><bpmn:incoming>Flow_Close_End</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Operation" sourceRef="Start_VacancyManagement" targetRef="Gateway_VacancyOperation" />
    <bpmn:sequenceFlow id="Flow_Operation_Create" name="create" sourceRef="Gateway_VacancyOperation" targetRef="Task_CreateVacancy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${vacancyOperation == "CREATE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Operation_Update" name="update" sourceRef="Gateway_VacancyOperation" targetRef="Task_UpdateVacancy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${vacancyOperation == "UPDATE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Operation_Close" name="close" sourceRef="Gateway_VacancyOperation" targetRef="Task_CloseVacancy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${vacancyOperation == "CLOSE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Create_End" sourceRef="Task_CreateVacancy" targetRef="End_VacancyCreated" />
    <bpmn:sequenceFlow id="Flow_Update_End" sourceRef="Task_UpdateVacancy" targetRef="End_VacancyUpdated" />
    <bpmn:sequenceFlow id="Flow_Close_End" sourceRef="Task_CloseVacancy" targetRef="End_VacancyClosed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_VacancyManagement"><bpmndi:BPMNPlane id="BPMNPlane_VacancyManagement" bpmnElement="vacancy-management-process">
    <bpmndi:BPMNShape id="Start_VacancyManagement_di" bpmnElement="Start_VacancyManagement"><dc:Bounds x="160" y="170" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Gateway_VacancyOperation_di" bpmnElement="Gateway_VacancyOperation" isMarkerVisible="true"><dc:Bounds x="260" y="163" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Task_CreateVacancy_di" bpmnElement="Task_CreateVacancy"><dc:Bounds x="390" y="70" width="150" height="80" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Task_UpdateVacancy_di" bpmnElement="Task_UpdateVacancy"><dc:Bounds x="390" y="170" width="150" height="80" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Task_CloseVacancy_di" bpmnElement="Task_CloseVacancy"><dc:Bounds x="390" y="270" width="180" height="80" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="End_VacancyCreated_di" bpmnElement="End_VacancyCreated"><dc:Bounds x="640" y="92" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="End_VacancyUpdated_di" bpmnElement="End_VacancyUpdated"><dc:Bounds x="640" y="192" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="End_VacancyClosed_di" bpmnElement="End_VacancyClosed"><dc:Bounds x="640" y="292" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="Flow_Start_Operation_di" bpmnElement="Flow_Start_Operation"><di:waypoint x="196" y="188" /><di:waypoint x="260" y="188" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Operation_Create_di" bpmnElement="Flow_Operation_Create"><di:waypoint x="285" y="163" /><di:waypoint x="285" y="110" /><di:waypoint x="390" y="110" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Operation_Update_di" bpmnElement="Flow_Operation_Update"><di:waypoint x="310" y="188" /><di:waypoint x="390" y="210" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Operation_Close_di" bpmnElement="Flow_Operation_Close"><di:waypoint x="285" y="213" /><di:waypoint x="285" y="310" /><di:waypoint x="390" y="310" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Create_End_di" bpmnElement="Flow_Create_End"><di:waypoint x="540" y="110" /><di:waypoint x="640" y="110" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Update_End_di" bpmnElement="Flow_Update_End"><di:waypoint x="540" y="210" /><di:waypoint x="640" y="210" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Close_End_di" bpmnElement="Flow_Close_End"><di:waypoint x="570" y="310" /><di:waypoint x="640" y="310" /></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>
