<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_HH_Overview"
                  targetNamespace="http://itmo.ru/hhprocess/overview">
  <bpmn:dataStore id="DataStore_HH_Main" name="Единая БД HH" />
  <bpmn:message id="Message_ApplicationSubmitted" name="Отклик отправлен" />
  <bpmn:message id="Message_NewApplication" name="Новый отклик рекрутеру" />
  <bpmn:message id="Message_RecruiterRejected" name="Рекрутер отклонил отклик" />
  <bpmn:message id="Message_RecruiterInvited" name="Рекрутер отправил приглашение" />
  <bpmn:message id="Message_InvitationSent" name="Приглашение отправлено кандидату" />
  <bpmn:message id="Message_CandidateResponded" name="Кандидат ответил на приглашение" />
  <bpmn:message id="Message_ResponseStored" name="Ответ доставлен рекрутеру" />
  <bpmn:message id="Message_TimeoutScan" name="Запуск проверки таймаутов" />
  <bpmn:message id="Message_TimeoutClosed" name="Отклик закрыт по таймауту" />
  <bpmn:message id="Message_CloseVacancy" name="Закрыть вакансию" />
  <bpmn:message id="Message_VacancyClosed" name="Вакансия закрыта" />
  <bpmn:message id="Message_AdminResetInterview" name="Админ сбросил интервью" />
  <bpmn:message id="Message_InterviewReset" name="Интервью сброшено" />
  <bpmn:error id="Error_TransactionFailed" name="Ошибка транзакции" errorCode="TX_FAILED" />
  <bpmn:collaboration id="Collaboration_HH_Overview">
    <bpmn:participant id="Participant_Candidate" name="Соискатель (ROLE=CANDIDATE)" processRef="Process_Candidate_Overview" />
    <bpmn:participant id="Participant_Recruiter" name="HR / рекрутер (ROLE=RECRUITER)" processRef="Process_Recruiter_Overview" />
    <bpmn:participant id="Participant_System" name="Система HH + Camunda + Narayana" processRef="Process_System_Overview" />
    <bpmn:participant id="Participant_Scheduler" name="Шедулер Camunda" processRef="Process_Scheduler_Overview" />
    <bpmn:participant id="Participant_Admin" name="Администратор (ROLE=ADMIN)" processRef="Process_Admin_Overview" />
    <bpmn:messageFlow id="MF_Candidate_System_Application" sourceRef="Throw_ApplicationSubmitted" targetRef="Start_System_ApplicationSubmitted" />
    <bpmn:messageFlow id="MF_System_Recruiter_NewApplication" sourceRef="Throw_NewApplication" targetRef="Start_Recruiter_NewApplication" />
    <bpmn:messageFlow id="MF_Recruiter_System_Reject" sourceRef="Throw_RecruiterRejected" targetRef="Start_System_RecruiterRejected" />
    <bpmn:messageFlow id="MF_Recruiter_System_Invite" sourceRef="Throw_RecruiterInvited" targetRef="Start_System_RecruiterInvited" />
    <bpmn:messageFlow id="MF_System_Candidate_Invitation" sourceRef="Throw_InvitationSent" targetRef="Catch_Candidate_Invitation" />
    <bpmn:messageFlow id="MF_Candidate_System_Response" sourceRef="Throw_CandidateResponded" targetRef="Start_System_CandidateResponded" />
    <bpmn:messageFlow id="MF_System_Recruiter_Response" sourceRef="Throw_ResponseStored" targetRef="Catch_Recruiter_Response" />
    <bpmn:messageFlow id="MF_Scheduler_System_TimeoutScan" sourceRef="Throw_TimeoutScan" targetRef="Start_System_TimeoutScan" />
    <bpmn:messageFlow id="MF_System_Candidate_Timeout" sourceRef="Throw_TimeoutClosed" targetRef="Catch_Candidate_TimeoutClosed" />
    <bpmn:messageFlow id="MF_Recruiter_System_CloseVacancy" sourceRef="Throw_CloseVacancy" targetRef="Start_System_CloseVacancy" />
    <bpmn:messageFlow id="MF_System_Candidate_VacancyClosed" sourceRef="Throw_VacancyClosed" targetRef="Catch_Candidate_VacancyClosed" />
    <bpmn:messageFlow id="MF_Admin_System_Reset" sourceRef="Throw_AdminResetInterview" targetRef="Start_System_AdminReset" />
    <bpmn:messageFlow id="MF_System_Candidate_Reset" sourceRef="Throw_InterviewReset" targetRef="Catch_Candidate_InterviewReset" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Candidate_Overview" name="Соискатель" isExecutable="false">
    <bpmn:startEvent id="Start_Candidate_Search" name="Выбрал вакансию">
      <bpmn:outgoing>Flow_Candidate_Apply</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Candidate_Apply" name="Заполнить форму отклика">
      <bpmn:incoming>Flow_Candidate_Apply</bpmn:incoming>
      <bpmn:outgoing>Flow_Candidate_SendApplication</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateThrowEvent id="Throw_ApplicationSubmitted" name="Отправить отклик">
      <bpmn:incoming>Flow_Candidate_SendApplication</bpmn:incoming>
      <bpmn:outgoing>Flow_Candidate_WaitInvitation</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ApplicationSubmitted" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Catch_Candidate_Invitation" name="Получить приглашение">
      <bpmn:incoming>Flow_Candidate_WaitInvitation</bpmn:incoming>
      <bpmn:outgoing>Flow_Candidate_ResponseTask</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_InvitationSent" />
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_Candidate_Response" name="Заполнить ответ на приглашение">
      <bpmn:incoming>Flow_Candidate_ResponseTask</bpmn:incoming>
      <bpmn:outgoing>Flow_Candidate_SendResponse</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateThrowEvent id="Throw_CandidateResponded" name="Отправить ответ">
      <bpmn:incoming>Flow_Candidate_SendResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_Candidate_ResponseEnd</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_CandidateResponded" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="End_Candidate_Response" name="Ответ отправлен">
      <bpmn:incoming>Flow_Candidate_ResponseEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="Catch_Candidate_TimeoutClosed" name="Получить уведомление о таймауте">
      <bpmn:messageEventDefinition messageRef="Message_TimeoutClosed" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Catch_Candidate_VacancyClosed" name="Получить уведомление о закрытии вакансии">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Catch_Candidate_InterviewReset" name="Получить уведомление о сбросе интервью">
      <bpmn:messageEventDefinition messageRef="Message_InterviewReset" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_Candidate_Apply" sourceRef="Start_Candidate_Search" targetRef="Task_Candidate_Apply" />
    <bpmn:sequenceFlow id="Flow_Candidate_SendApplication" sourceRef="Task_Candidate_Apply" targetRef="Throw_ApplicationSubmitted" />
    <bpmn:sequenceFlow id="Flow_Candidate_WaitInvitation" sourceRef="Throw_ApplicationSubmitted" targetRef="Catch_Candidate_Invitation" />
    <bpmn:sequenceFlow id="Flow_Candidate_ResponseTask" sourceRef="Catch_Candidate_Invitation" targetRef="Task_Candidate_Response" />
    <bpmn:sequenceFlow id="Flow_Candidate_SendResponse" sourceRef="Task_Candidate_Response" targetRef="Throw_CandidateResponded" />
    <bpmn:sequenceFlow id="Flow_Candidate_ResponseEnd" sourceRef="Throw_CandidateResponded" targetRef="End_Candidate_Response" />
  </bpmn:process>

  <bpmn:process id="Process_Recruiter_Overview" name="HR / рекрутер" isExecutable="false">
    <bpmn:startEvent id="Start_Recruiter_NewApplication" name="Получен новый отклик">
      <bpmn:outgoing>Flow_Recruiter_Review</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_NewApplication" />
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Recruiter_Review" name="Рассмотреть отклик">
      <bpmn:incoming>Flow_Recruiter_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Recruiter_Decision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Recruiter_Decision" name="Решение">
      <bpmn:incoming>Flow_Recruiter_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_Recruiter_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Recruiter_Invite</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateThrowEvent id="Throw_RecruiterRejected" name="Отправить отказ">
      <bpmn:incoming>Flow_Recruiter_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Recruiter_RejectEnd</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_RecruiterRejected" />
    </bpmn:intermediateThrowEvent>
    <bpmn:userTask id="Task_Recruiter_WriteInvitation" name="Заполнить форму приглашения">
      <bpmn:incoming>Flow_Recruiter_Invite</bpmn:incoming>
      <bpmn:outgoing>Flow_Recruiter_SendInvitation</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateThrowEvent id="Throw_RecruiterInvited" name="Отправить приглашение">
      <bpmn:incoming>Flow_Recruiter_SendInvitation</bpmn:incoming>
      <bpmn:outgoing>Flow_Recruiter_WaitResponse</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_RecruiterInvited" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Catch_Recruiter_Response" name="Получить ответ кандидата">
      <bpmn:incoming>Flow_Recruiter_WaitResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_Recruiter_ResponseEnd</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ResponseStored" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End_Recruiter_Response" name="Ответ обработан">
      <bpmn:incoming>Flow_Recruiter_ResponseEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Recruiter_Reject" name="Отказ отправлен">
      <bpmn:incoming>Flow_Recruiter_RejectEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_Recruiter_CloseVacancy" name="Закрыть вакансию">
      <bpmn:outgoing>Flow_Recruiter_CloseVacancy</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateThrowEvent id="Throw_CloseVacancy" name="Отправить событие закрытия вакансии">
      <bpmn:incoming>Flow_Recruiter_CloseVacancy</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_CloseVacancy" />
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_Recruiter_Review" sourceRef="Start_Recruiter_NewApplication" targetRef="Task_Recruiter_Review" />
    <bpmn:sequenceFlow id="Flow_Recruiter_Decision" sourceRef="Task_Recruiter_Review" targetRef="Gateway_Recruiter_Decision" />
    <bpmn:sequenceFlow id="Flow_Recruiter_Reject" sourceRef="Gateway_Recruiter_Decision" targetRef="Throw_RecruiterRejected" />
    <bpmn:sequenceFlow id="Flow_Recruiter_Invite" sourceRef="Gateway_Recruiter_Decision" targetRef="Task_Recruiter_WriteInvitation" />
    <bpmn:sequenceFlow id="Flow_Recruiter_SendInvitation" sourceRef="Task_Recruiter_WriteInvitation" targetRef="Throw_RecruiterInvited" />
    <bpmn:sequenceFlow id="Flow_Recruiter_WaitResponse" sourceRef="Throw_RecruiterInvited" targetRef="Catch_Recruiter_Response" />
    <bpmn:sequenceFlow id="Flow_Recruiter_ResponseEnd" sourceRef="Catch_Recruiter_Response" targetRef="End_Recruiter_Response" />
    <bpmn:sequenceFlow id="Flow_Recruiter_RejectEnd" sourceRef="Throw_RecruiterRejected" targetRef="End_Recruiter_Reject" />
    <bpmn:sequenceFlow id="Flow_Recruiter_CloseVacancy" sourceRef="Task_Recruiter_CloseVacancy" targetRef="Throw_CloseVacancy" />
  </bpmn:process>

  <bpmn:process id="Process_System_Overview" name="Система HH" isExecutable="false">
    <bpmn:dataStoreReference id="DataStoreRef_HH_Main" name="Единая БД HH" dataStoreRef="DataStore_HH_Main" />
    <bpmn:startEvent id="Start_System_ApplicationSubmitted" name="Получить отклик">
      <bpmn:outgoing>Flow_System_ApplicationTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ApplicationSubmitted" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_ApplicationSubmit" name="Транзакция приема отклика и автоскрининга">
      <bpmn:incoming>Flow_System_ApplicationTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_ScreeningGateway</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_ApplicationSubmit" name="Начать">
        <bpmn:outgoing>Flow_Tx_App_Save</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_App_SaveApplication" name="Сохранить отклик">
        <bpmn:incoming>Flow_Tx_App_Save</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_App_Screen</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_App_Save_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_App_AutoScreen" name="Выполнить автоскрининг">
        <bpmn:incoming>Flow_Tx_App_Screen</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_App_WriteScreening</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_App_WriteScreening" name="Записать статус и историю">
        <bpmn:incoming>Flow_Tx_App_WriteScreening</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_App_End</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_App_Screening_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:endEvent id="End_Tx_ApplicationSubmit" name="Commit">
        <bpmn:incoming>Flow_Tx_App_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_App_Save" sourceRef="Start_Tx_ApplicationSubmit" targetRef="Task_Tx_App_SaveApplication" />
      <bpmn:sequenceFlow id="Flow_Tx_App_Screen" sourceRef="Task_Tx_App_SaveApplication" targetRef="Task_Tx_App_AutoScreen" />
      <bpmn:sequenceFlow id="Flow_Tx_App_WriteScreening" sourceRef="Task_Tx_App_AutoScreen" targetRef="Task_Tx_App_WriteScreening" />
      <bpmn:sequenceFlow id="Flow_Tx_App_End" sourceRef="Task_Tx_App_WriteScreening" targetRef="End_Tx_ApplicationSubmit" />
    </bpmn:transaction>
    <bpmn:exclusiveGateway id="Gateway_System_Screening" name="Скрининг пройден?">
      <bpmn:incoming>Flow_System_ScreeningGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_System_NewApplication</bpmn:outgoing>
      <bpmn:outgoing>Flow_System_ScreeningRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateThrowEvent id="Throw_NewApplication" name="Сообщить рекрутеру">
      <bpmn:incoming>Flow_System_NewApplication</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_NewApplication" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="End_System_ScreeningRejected" name="Отклик закрыт скринингом">
      <bpmn:incoming>Flow_System_ScreeningRejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="Start_System_RecruiterRejected" name="Получить отказ рекрутера">
      <bpmn:outgoing>Flow_System_RejectionTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_RecruiterRejected" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_Rejection" name="Транзакция отказа">
      <bpmn:incoming>Flow_System_RejectionTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_RejectionEnd</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_Rejection" name="Начать">
        <bpmn:outgoing>Flow_Tx_Rej_CancelInterview</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_Rej_CancelInterview" name="Отменить активное интервью">
        <bpmn:incoming>Flow_Tx_Rej_CancelInterview</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Rej_ReleaseSlot</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Rej_ReleaseSlot" name="Освободить слот расписания">
        <bpmn:incoming>Flow_Tx_Rej_ReleaseSlot</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Rej_UpdateStatus</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Rej_Slot_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Rej_UpdateStatus" name="Записать отказ и историю">
        <bpmn:incoming>Flow_Tx_Rej_UpdateStatus</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Rej_Notify</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Rej_Status_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_Tx_Rej_NotifyCandidate" name="Уведомить кандидата">
        <bpmn:incoming>Flow_Tx_Rej_Notify</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Rej_End</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_Tx_Rejection" name="Commit">
        <bpmn:incoming>Flow_Tx_Rej_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_Rej_CancelInterview" sourceRef="Start_Tx_Rejection" targetRef="Task_Tx_Rej_CancelInterview" />
      <bpmn:sequenceFlow id="Flow_Tx_Rej_ReleaseSlot" sourceRef="Task_Tx_Rej_CancelInterview" targetRef="Task_Tx_Rej_ReleaseSlot" />
      <bpmn:sequenceFlow id="Flow_Tx_Rej_UpdateStatus" sourceRef="Task_Tx_Rej_ReleaseSlot" targetRef="Task_Tx_Rej_UpdateStatus" />
      <bpmn:sequenceFlow id="Flow_Tx_Rej_Notify" sourceRef="Task_Tx_Rej_UpdateStatus" targetRef="Task_Tx_Rej_NotifyCandidate" />
      <bpmn:sequenceFlow id="Flow_Tx_Rej_End" sourceRef="Task_Tx_Rej_NotifyCandidate" targetRef="End_Tx_Rejection" />
    </bpmn:transaction>
    <bpmn:endEvent id="End_System_Rejection" name="Отказ сохранен">
      <bpmn:incoming>Flow_System_RejectionEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="Start_System_RecruiterInvited" name="Получить приглашение">
      <bpmn:outgoing>Flow_System_InvitationTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_RecruiterInvited" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_Invitation" name="Транзакция приглашения и бронирования слота">
      <bpmn:incoming>Flow_System_InvitationTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_InvitationMessage</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_Invitation" name="Начать">
        <bpmn:outgoing>Flow_Tx_Inv_Validate</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_Inv_Validate" name="Проверить форму и доступ рекрутера">
        <bpmn:incoming>Flow_Tx_Inv_Validate</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Inv_SaveInvitation</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Inv_SaveInvitation" name="Сохранить приглашение">
        <bpmn:incoming>Flow_Tx_Inv_SaveInvitation</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Inv_CreateInterview</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Inv_Invitation_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Inv_CreateInterview" name="Создать интервью">
        <bpmn:incoming>Flow_Tx_Inv_CreateInterview</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Inv_ReserveSlot</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Inv_Interview_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Inv_ReserveSlot" name="Зарезервировать слот">
        <bpmn:incoming>Flow_Tx_Inv_ReserveSlot</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Inv_Notify</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Inv_Slot_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_Tx_Inv_NotifyCandidate" name="Уведомить кандидата">
        <bpmn:incoming>Flow_Tx_Inv_Notify</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Inv_End</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_Tx_Invitation" name="Commit">
        <bpmn:incoming>Flow_Tx_Inv_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_Inv_Validate" sourceRef="Start_Tx_Invitation" targetRef="Task_Tx_Inv_Validate" />
      <bpmn:sequenceFlow id="Flow_Tx_Inv_SaveInvitation" sourceRef="Task_Tx_Inv_Validate" targetRef="Task_Tx_Inv_SaveInvitation" />
      <bpmn:sequenceFlow id="Flow_Tx_Inv_CreateInterview" sourceRef="Task_Tx_Inv_SaveInvitation" targetRef="Task_Tx_Inv_CreateInterview" />
      <bpmn:sequenceFlow id="Flow_Tx_Inv_ReserveSlot" sourceRef="Task_Tx_Inv_CreateInterview" targetRef="Task_Tx_Inv_ReserveSlot" />
      <bpmn:sequenceFlow id="Flow_Tx_Inv_Notify" sourceRef="Task_Tx_Inv_ReserveSlot" targetRef="Task_Tx_Inv_NotifyCandidate" />
      <bpmn:sequenceFlow id="Flow_Tx_Inv_End" sourceRef="Task_Tx_Inv_NotifyCandidate" targetRef="End_Tx_Invitation" />
    </bpmn:transaction>
    <bpmn:intermediateThrowEvent id="Throw_InvitationSent" name="Сообщить кандидату о приглашении">
      <bpmn:incoming>Flow_System_InvitationMessage</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_InvitationSent" />
    </bpmn:intermediateThrowEvent>

    <bpmn:startEvent id="Start_System_CandidateResponded" name="Получить ответ кандидата">
      <bpmn:outgoing>Flow_System_ResponseTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_CandidateResponded" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_Response" name="Транзакция ответа кандидата">
      <bpmn:incoming>Flow_System_ResponseTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_ResponseMessage</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_Response" name="Начать">
        <bpmn:outgoing>Flow_Tx_Resp_Validate</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_Resp_Validate" name="Проверить форму и доступ кандидата">
        <bpmn:incoming>Flow_Tx_Resp_Validate</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Resp_Save</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Resp_Save" name="Сохранить ответ">
        <bpmn:incoming>Flow_Tx_Resp_Save</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Resp_UpdateStatus</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Resp_Save_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Resp_UpdateStatus" name="Обновить статус отклика">
        <bpmn:incoming>Flow_Tx_Resp_UpdateStatus</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Resp_Notify</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Resp_Status_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_Tx_Resp_NotifyRecruiter" name="Уведомить рекрутера">
        <bpmn:incoming>Flow_Tx_Resp_Notify</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Resp_End</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_Tx_Response" name="Commit">
        <bpmn:incoming>Flow_Tx_Resp_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_Resp_Validate" sourceRef="Start_Tx_Response" targetRef="Task_Tx_Resp_Validate" />
      <bpmn:sequenceFlow id="Flow_Tx_Resp_Save" sourceRef="Task_Tx_Resp_Validate" targetRef="Task_Tx_Resp_Save" />
      <bpmn:sequenceFlow id="Flow_Tx_Resp_UpdateStatus" sourceRef="Task_Tx_Resp_Save" targetRef="Task_Tx_Resp_UpdateStatus" />
      <bpmn:sequenceFlow id="Flow_Tx_Resp_Notify" sourceRef="Task_Tx_Resp_UpdateStatus" targetRef="Task_Tx_Resp_NotifyRecruiter" />
      <bpmn:sequenceFlow id="Flow_Tx_Resp_End" sourceRef="Task_Tx_Resp_NotifyRecruiter" targetRef="End_Tx_Response" />
    </bpmn:transaction>
    <bpmn:intermediateThrowEvent id="Throw_ResponseStored" name="Сообщить рекрутеру об ответе">
      <bpmn:incoming>Flow_System_ResponseMessage</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_ResponseStored" />
    </bpmn:intermediateThrowEvent>

    <bpmn:startEvent id="Start_System_TimeoutScan" name="Получить запуск шедулера">
      <bpmn:outgoing>Flow_System_TimeoutTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_TimeoutScan" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_TimeoutBatch" name="Batch-транзакция таймаутов">
      <bpmn:incoming>Flow_System_TimeoutTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_TimeoutMessage</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_Timeout" name="Начать">
        <bpmn:outgoing>Flow_Tx_Timeout_Find</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_Timeout_Find" name="Найти просроченные приглашения">
        <bpmn:incoming>Flow_Tx_Timeout_Find</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Timeout_Close</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Timeout_Find_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Timeout_Close" name="Закрыть отклики и отменить интервью">
        <bpmn:incoming>Flow_Tx_Timeout_Close</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Timeout_Release</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Timeout_Close_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_Timeout_Release" name="Освободить слоты">
        <bpmn:incoming>Flow_Tx_Timeout_Release</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Timeout_Notify</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_Timeout_Slots_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_Tx_Timeout_Notify" name="Уведомить кандидата и рекрутера">
        <bpmn:incoming>Flow_Tx_Timeout_Notify</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_Timeout_End</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_Tx_Timeout" name="Commit">
        <bpmn:incoming>Flow_Tx_Timeout_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_Timeout_Find" sourceRef="Start_Tx_Timeout" targetRef="Task_Tx_Timeout_Find" />
      <bpmn:sequenceFlow id="Flow_Tx_Timeout_Close" sourceRef="Task_Tx_Timeout_Find" targetRef="Task_Tx_Timeout_Close" />
      <bpmn:sequenceFlow id="Flow_Tx_Timeout_Release" sourceRef="Task_Tx_Timeout_Close" targetRef="Task_Tx_Timeout_Release" />
      <bpmn:sequenceFlow id="Flow_Tx_Timeout_Notify" sourceRef="Task_Tx_Timeout_Release" targetRef="Task_Tx_Timeout_Notify" />
      <bpmn:sequenceFlow id="Flow_Tx_Timeout_End" sourceRef="Task_Tx_Timeout_Notify" targetRef="End_Tx_Timeout" />
    </bpmn:transaction>
    <bpmn:intermediateThrowEvent id="Throw_TimeoutClosed" name="Разослать сообщения о таймауте">
      <bpmn:incoming>Flow_System_TimeoutMessage</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_TimeoutClosed" />
    </bpmn:intermediateThrowEvent>

    <bpmn:startEvent id="Start_System_CloseVacancy" name="Получить закрытие вакансии">
      <bpmn:outgoing>Flow_System_CloseVacancyTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_CloseVacancy" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_CloseVacancy" name="Транзакция закрытия вакансии">
      <bpmn:incoming>Flow_System_CloseVacancyTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_VacancyClosedMessage</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_CloseVacancy" name="Начать">
        <bpmn:outgoing>Flow_Tx_CloseVacancy_Update</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_CloseVacancy_Update" name="Закрыть вакансию">
        <bpmn:incoming>Flow_Tx_CloseVacancy_Update</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_CloseVacancy_Applications</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_CloseVacancy_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_CloseVacancy_Applications" name="Закрыть активные отклики">
        <bpmn:incoming>Flow_Tx_CloseVacancy_Applications</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_CloseVacancy_Interviews</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_CloseApps_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_CloseVacancy_Interviews" name="Отменить интервью и освободить слоты">
        <bpmn:incoming>Flow_Tx_CloseVacancy_Interviews</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_CloseVacancy_Notify</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_CloseSlots_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_Tx_CloseVacancy_Notify" name="Уведомить кандидатов">
        <bpmn:incoming>Flow_Tx_CloseVacancy_Notify</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_CloseVacancy_End</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_Tx_CloseVacancy" name="Commit">
        <bpmn:incoming>Flow_Tx_CloseVacancy_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_CloseVacancy_Update" sourceRef="Start_Tx_CloseVacancy" targetRef="Task_Tx_CloseVacancy_Update" />
      <bpmn:sequenceFlow id="Flow_Tx_CloseVacancy_Applications" sourceRef="Task_Tx_CloseVacancy_Update" targetRef="Task_Tx_CloseVacancy_Applications" />
      <bpmn:sequenceFlow id="Flow_Tx_CloseVacancy_Interviews" sourceRef="Task_Tx_CloseVacancy_Applications" targetRef="Task_Tx_CloseVacancy_Interviews" />
      <bpmn:sequenceFlow id="Flow_Tx_CloseVacancy_Notify" sourceRef="Task_Tx_CloseVacancy_Interviews" targetRef="Task_Tx_CloseVacancy_Notify" />
      <bpmn:sequenceFlow id="Flow_Tx_CloseVacancy_End" sourceRef="Task_Tx_CloseVacancy_Notify" targetRef="End_Tx_CloseVacancy" />
    </bpmn:transaction>
    <bpmn:intermediateThrowEvent id="Throw_VacancyClosed" name="Разослать сообщения о закрытии вакансии">
      <bpmn:incoming>Flow_System_VacancyClosedMessage</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed" />
    </bpmn:intermediateThrowEvent>

    <bpmn:startEvent id="Start_System_AdminReset" name="Получить админский сброс интервью">
      <bpmn:outgoing>Flow_System_AdminResetTx</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_AdminResetInterview" />
    </bpmn:startEvent>
    <bpmn:transaction id="Transaction_AdminReset" name="Транзакция админского сброса интервью">
      <bpmn:incoming>Flow_System_AdminResetTx</bpmn:incoming>
      <bpmn:outgoing>Flow_System_AdminResetMessage</bpmn:outgoing>
      <bpmn:startEvent id="Start_Tx_AdminReset" name="Начать">
        <bpmn:outgoing>Flow_Tx_AdminReset_Check</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Tx_AdminReset_Check" name="Проверить роль ADMIN">
        <bpmn:incoming>Flow_Tx_AdminReset_Check</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_AdminReset_Cancel</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_AdminReset_Cancel" name="Отменить интервью">
        <bpmn:incoming>Flow_Tx_AdminReset_Cancel</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_AdminReset_Release</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_AdminReset_Interview_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_AdminReset_Release" name="Освободить слот">
        <bpmn:incoming>Flow_Tx_AdminReset_Release</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_AdminReset_Status</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_AdminReset_Slot_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_Tx_AdminReset_Status" name="Вернуть отклик на рассмотрение">
        <bpmn:incoming>Flow_Tx_AdminReset_Status</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_AdminReset_Notify</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DA_AdminReset_Status_DB"><bpmn:targetRef>DataStoreRef_HH_Main</bpmn:targetRef></bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_Tx_AdminReset_Notify" name="Уведомить кандидата и рекрутера">
        <bpmn:incoming>Flow_Tx_AdminReset_Notify</bpmn:incoming>
        <bpmn:outgoing>Flow_Tx_AdminReset_End</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_Tx_AdminReset" name="Commit">
        <bpmn:incoming>Flow_Tx_AdminReset_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Tx_AdminReset_Check" sourceRef="Start_Tx_AdminReset" targetRef="Task_Tx_AdminReset_Check" />
      <bpmn:sequenceFlow id="Flow_Tx_AdminReset_Cancel" sourceRef="Task_Tx_AdminReset_Check" targetRef="Task_Tx_AdminReset_Cancel" />
      <bpmn:sequenceFlow id="Flow_Tx_AdminReset_Release" sourceRef="Task_Tx_AdminReset_Cancel" targetRef="Task_Tx_AdminReset_Release" />
      <bpmn:sequenceFlow id="Flow_Tx_AdminReset_Status" sourceRef="Task_Tx_AdminReset_Release" targetRef="Task_Tx_AdminReset_Status" />
      <bpmn:sequenceFlow id="Flow_Tx_AdminReset_Notify" sourceRef="Task_Tx_AdminReset_Status" targetRef="Task_Tx_AdminReset_Notify" />
      <bpmn:sequenceFlow id="Flow_Tx_AdminReset_End" sourceRef="Task_Tx_AdminReset_Notify" targetRef="End_Tx_AdminReset" />
    </bpmn:transaction>
    <bpmn:intermediateThrowEvent id="Throw_InterviewReset" name="Разослать сообщения о сбросе интервью">
      <bpmn:incoming>Flow_System_AdminResetMessage</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_InterviewReset" />
    </bpmn:intermediateThrowEvent>

    <bpmn:sequenceFlow id="Flow_System_ApplicationTx" sourceRef="Start_System_ApplicationSubmitted" targetRef="Transaction_ApplicationSubmit" />
    <bpmn:sequenceFlow id="Flow_System_ScreeningGateway" sourceRef="Transaction_ApplicationSubmit" targetRef="Gateway_System_Screening" />
    <bpmn:sequenceFlow id="Flow_System_NewApplication" sourceRef="Gateway_System_Screening" targetRef="Throw_NewApplication" />
    <bpmn:sequenceFlow id="Flow_System_ScreeningRejected" sourceRef="Gateway_System_Screening" targetRef="End_System_ScreeningRejected" />
    <bpmn:sequenceFlow id="Flow_System_RejectionTx" sourceRef="Start_System_RecruiterRejected" targetRef="Transaction_Rejection" />
    <bpmn:sequenceFlow id="Flow_System_RejectionEnd" sourceRef="Transaction_Rejection" targetRef="End_System_Rejection" />
    <bpmn:sequenceFlow id="Flow_System_InvitationTx" sourceRef="Start_System_RecruiterInvited" targetRef="Transaction_Invitation" />
    <bpmn:sequenceFlow id="Flow_System_InvitationMessage" sourceRef="Transaction_Invitation" targetRef="Throw_InvitationSent" />
    <bpmn:sequenceFlow id="Flow_System_ResponseTx" sourceRef="Start_System_CandidateResponded" targetRef="Transaction_Response" />
    <bpmn:sequenceFlow id="Flow_System_ResponseMessage" sourceRef="Transaction_Response" targetRef="Throw_ResponseStored" />
    <bpmn:sequenceFlow id="Flow_System_TimeoutTx" sourceRef="Start_System_TimeoutScan" targetRef="Transaction_TimeoutBatch" />
    <bpmn:sequenceFlow id="Flow_System_TimeoutMessage" sourceRef="Transaction_TimeoutBatch" targetRef="Throw_TimeoutClosed" />
    <bpmn:sequenceFlow id="Flow_System_CloseVacancyTx" sourceRef="Start_System_CloseVacancy" targetRef="Transaction_CloseVacancy" />
    <bpmn:sequenceFlow id="Flow_System_VacancyClosedMessage" sourceRef="Transaction_CloseVacancy" targetRef="Throw_VacancyClosed" />
    <bpmn:sequenceFlow id="Flow_System_AdminResetTx" sourceRef="Start_System_AdminReset" targetRef="Transaction_AdminReset" />
    <bpmn:sequenceFlow id="Flow_System_AdminResetMessage" sourceRef="Transaction_AdminReset" targetRef="Throw_InterviewReset" />
  </bpmn:process>

  <bpmn:process id="Process_Scheduler_Overview" name="Шедулер" isExecutable="false">
    <bpmn:startEvent id="Start_Scheduler_Timer" name="Периодический таймер">
      <bpmn:outgoing>Flow_Scheduler_TimeoutScan</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT1M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="Throw_TimeoutScan" name="Запустить проверку просрочек">
      <bpmn:incoming>Flow_Scheduler_TimeoutScan</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_TimeoutScan" />
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_Scheduler_TimeoutScan" sourceRef="Start_Scheduler_Timer" targetRef="Throw_TimeoutScan" />
  </bpmn:process>

  <bpmn:process id="Process_Admin_Overview" name="Админ" isExecutable="false">
    <bpmn:startEvent id="Start_Admin_Reset" name="Нужно сбросить интервью">
      <bpmn:outgoing>Flow_Admin_ResetTask</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Admin_ResetInterview" name="Сбросить интервью без шедулера">
      <bpmn:incoming>Flow_Admin_ResetTask</bpmn:incoming>
      <bpmn:outgoing>Flow_Admin_SendReset</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateThrowEvent id="Throw_AdminResetInterview" name="Отправить запрос на сброс">
      <bpmn:incoming>Flow_Admin_SendReset</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_AdminResetInterview" />
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_Admin_ResetTask" sourceRef="Start_Admin_Reset" targetRef="Task_Admin_ResetInterview" />
    <bpmn:sequenceFlow id="Flow_Admin_SendReset" sourceRef="Task_Admin_ResetInterview" targetRef="Throw_AdminResetInterview" />
  </bpmn:process>

