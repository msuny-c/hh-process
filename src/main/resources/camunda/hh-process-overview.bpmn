<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_hh_v3" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:message id="Message_VacancyClosed" name="MSG_VACANCY_CLOSED" />
  <bpmn:collaboration id="Collaboration_hhProcessOverview" name="Пул: обзор ролей и процессов системы найма">
    <bpmn:participant id="Participant_hhProcessOverview" name="Пул: обзор ролей и процессов системы найма" processRef="hhProcessOverview" />
  </bpmn:collaboration>
  <bpmn:process id="hhProcessOverview" name="Обзор ролей и процессов системы найма" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Overview">
      <bpmn:lane id="Lane_System_O" name="Система">
        <bpmn:flowNodeRef>OverviewDecisionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewAutoScreen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewVacancyClosedMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewTimeout</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin_O" name="Администратор">
        <bpmn:flowNodeRef>OverviewAdminReset</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Recruiter_O" name="Рекрутер">
        <bpmn:flowNodeRef>OverviewRecruiterDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewCloseVacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewInvitation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Candidate_O" name="Кандидат">
        <bpmn:flowNodeRef>OverviewCandidateApply</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OverviewResultForms</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="OverviewCandidateApply" name="Кандидат заполняет отклик" camunda:formRef="apply-to-vacancy-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE" />
    <bpmn:exclusiveGateway id="OverviewDecisionGateway" name="Выбор ветки процесса" />
    <bpmn:startEvent id="OverviewStart" name="Начало обзорной схемы" />
    <bpmn:serviceTask id="OverviewAutoScreen" name="Система оценивает отклик через автоскрининг" camunda:type="external" camunda:topic="application-auto-screening" />
    <bpmn:userTask id="OverviewRecruiterDecision" name="Рекрутер принимает решение" camunda:formRef="recruiter-decision-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>OF5</bpmn:incoming>
      <bpmn:incoming>OF15</bpmn:incoming>
      <bpmn:outgoing>Flow_0rjoo46</bpmn:outgoing>
      <bpmn:outgoing>Flow_1rw6o35</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="OF1" sourceRef="OverviewStart" targetRef="OverviewCandidateApply" />
    <bpmn:sequenceFlow id="OF2" sourceRef="OverviewCandidateApply" targetRef="OverviewAutoScreen" />
    <bpmn:sequenceFlow id="OF4" sourceRef="OverviewRecruiterDecision" targetRef="OverviewDecisionGateway" />
    <bpmn:sequenceFlow id="OF5" sourceRef="OverviewDecisionGateway" targetRef="OverviewRecruiterDecision" />
    <bpmn:sequenceFlow id="OF8" sourceRef="OverviewDecisionGateway" targetRef="OverviewEnd" />
    <bpmn:sequenceFlow id="OF14" name="переход к закрытию вакансии" sourceRef="OverviewDecisionGateway" targetRef="OverviewInvitation" />
    <bpmn:sequenceFlow id="OF16" name="переход к проверке таймаутов" sourceRef="OverviewCandidateResponse" targetRef="OverviewTimeout" />
    <bpmn:sequenceFlow id="OF11" sourceRef="OverviewTimeout" targetRef="OverviewEnd" />
    <bpmn:sequenceFlow id="OF9" sourceRef="OverviewCloseVacancy" targetRef="OverviewEnd" />
    <bpmn:sequenceFlow id="OF10" sourceRef="OverviewAdminReset" targetRef="OverviewEnd" />
    <bpmn:sequenceFlow id="OF17" name="результат операции показан" sourceRef="OverviewResultForms" targetRef="OverviewEnd" />
    <bpmn:sequenceFlow id="Flow_1q3d668" sourceRef="OverviewVacancyClosedMessage" targetRef="OverviewEnd" />
    <bpmn:sequenceFlow id="OF3" sourceRef="OverviewAutoScreen" targetRef="OverviewRecruiterDecision" />
    <bpmn:sequenceFlow id="OF15" name="переход к админскому сбросу интервью" sourceRef="OverviewCandidateResponse" targetRef="OverviewRecruiterDecision" />
    <bpmn:sequenceFlow id="Flow_0rjoo46" sourceRef="OverviewRecruiterDecision" targetRef="OverviewAdminReset" />
    <bpmn:sequenceFlow id="Flow_1rw6o35" sourceRef="OverviewRecruiterDecision" targetRef="OverviewInvitation" />
    <bpmn:sequenceFlow id="Flow_1c9hlw5" sourceRef="OverviewInvitation" targetRef="OverviewCloseVacancy" />
    <bpmn:sequenceFlow id="OF12" sourceRef="OverviewCloseVacancy" targetRef="OverviewVacancyClosedMessage" />
    <bpmn:sequenceFlow id="Flow_1xvdpsg" sourceRef="OverviewResultForms" targetRef="OverviewVacancyClosedMessage" />
    <bpmn:sequenceFlow id="OF13" sourceRef="OverviewVacancyClosedMessage" targetRef="OverviewInvitation" />
    <bpmn:sequenceFlow id="Flow_1eylqyb" sourceRef="OverviewInvitation" targetRef="OverviewResultForms" />
    <bpmn:sequenceFlow id="OF7" sourceRef="OverviewCandidateResponse" targetRef="OverviewResultForms" />
    <bpmn:sequenceFlow id="OF6" sourceRef="OverviewInvitation" targetRef="OverviewCandidateResponse" />
    <bpmn:serviceTask id="OverviewVacancyClosedMessage" name="Сообщение о закрытии вакансии завершает активные отклики">
      <bpmn:incoming>Flow_1xvdpsg</bpmn:incoming>
      <bpmn:outgoing>Flow_1q3d668</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="OverviewCloseVacancy" name="Рекрутер закрывает вакансию" camunda:formRef="close-vacancy-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>Flow_1c9hlw5</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:userTask id="OverviewCandidateResponse" name="Кандидат отвечает на приглашение" camunda:formRef="invitation-response-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE" />
    <bpmn:userTask id="OverviewInvitation" name="Рекрутер готовит приглашение" camunda:formRef="invitation-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>OF13</bpmn:incoming>
      <bpmn:incoming>Flow_1rw6o35</bpmn:incoming>
      <bpmn:incoming>OF14</bpmn:incoming>
      <bpmn:outgoing>Flow_1eylqyb</bpmn:outgoing>
      <bpmn:outgoing>Flow_1c9hlw5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="OverviewResultForms" name="Формы Camunda показывают итог операции пользователю">
      <bpmn:incoming>Flow_1eylqyb</bpmn:incoming>
      <bpmn:incoming>OF7</bpmn:incoming>
      <bpmn:outgoing>Flow_1xvdpsg</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="OverviewEnd" name="Обзорный процесс завершён">
      <bpmn:incoming>Flow_1q3d668</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="OverviewAdminReset" name="Админ сбрасывает интервью" camunda:formRef="reset-interview-form" camunda:formRefBinding="latest" camunda:candidateGroups="ADMIN">
      <bpmn:incoming>Flow_0rjoo46</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:serviceTask id="OverviewTimeout" name="Планировщик закрывает просроченные приглашения" camunda:type="external" camunda:topic="timeout-close-expired" />
  </bpmn:process>
