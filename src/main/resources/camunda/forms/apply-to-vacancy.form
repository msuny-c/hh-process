{
  "schemaVersion": 11,
  "exporter": { "name": "Camunda Modeler", "version": "standalone-lab" },
  "type": "default",
  "id": "apply-to-vacancy-form",
  "components": [
    {
      "type": "html",
      "id": "errorBanner",
      "content": "<div style=\"padding:12px;border-radius:6px;background:#fee2e2;color:#991b1b;\"><strong>Ошибка формы:</strong> {{formErrorMessage}}<br/><span>Поля: {{formErrorFields}}</span></div>",
      "conditional": { "hide": "=formErrorMessage = null or formErrorMessage = \"\"" }
    },
    { "type": "text", "id": "contextHeader", "text": "## Контекст отклика" },
    { "type": "textfield", "id": "vacancyTitle", "key": "vacancyTitle", "label": "Вакансия", "readonly": true },
    { "type": "textfield", "id": "candidateUserId", "key": "candidateUserId", "label": "ID кандидата", "readonly": true },
    { "type": "textfield", "id": "vacancyId", "key": "vacancyId", "label": "ID вакансии", "validate": { "required": true } },
    { "type": "text", "id": "inputHeader", "text": "## Данные резюме" },
    { "type": "textarea", "id": "resumeText", "key": "resumeText", "label": "Текст резюме", "validate": { "required": true, "minLength": 20, "maxLength": 50000 } },
    { "type": "textarea", "id": "coverLetter", "key": "coverLetter", "label": "Сопроводительное письмо", "validate": { "maxLength": 10000 } }
  ]
}
