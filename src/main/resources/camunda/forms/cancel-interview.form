{
  "schemaVersion": 11,
  "exporter": { "name": "Camunda Modeler", "version": "standalone-lab" },
  "type": "default",
  "id": "cancel-interview-form",
  "components": [
    {
      "type": "html",
      "id": "errorBanner",
      "content": "<div style=\"padding:12px;border-radius:6px;background:#fee2e2;color:#991b1b;\"><strong>Ошибка формы:</strong> {{formErrorMessage}}<br/><span>Поля: {{formErrorFields}}</span></div>",
      "conditional": { "hide": "=formErrorMessage = null or formErrorMessage = \"\"" }
    },
    { "type": "text", "id": "contextHeader", "text": "## Контекст интервью" },
    { "type": "textfield", "id": "applicationId", "key": "applicationId", "label": "ID отклика", "readonly": true },
    { "type": "textfield", "id": "interviewId", "key": "interviewId", "label": "ID интервью", "validate": { "required": true } },
    { "type": "text", "id": "inputHeader", "text": "## Отмена интервью" },
    { "type": "textarea", "id": "cancelReason", "key": "cancelReason", "label": "Причина отмены", "validate": { "required": true, "maxLength": 5000 } }
  ]
}
