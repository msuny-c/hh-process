{
  "schemaVersion": 11,
  "exporter": {
    "name": "Camunda Modeler",
    "version": "standalone-lab"
  },
  "type": "default",
  "id": "reset-interview-form",
  "components": [
    {
      "type": "textfield",
      "id": "formErrorMessage",
      "key": "formErrorMessage",
      "label": "Ошибка предыдущей отправки формы",
      "disabled": true
    },
    {
      "type": "textarea",
      "id": "resetReason",
      "key": "resetReason",
      "label": "Причина административного сброса интервью",
      "validate": {
        "required": true,
        "maxLength": 5000
      }
    }
  ]
}