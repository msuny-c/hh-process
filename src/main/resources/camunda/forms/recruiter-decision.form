{
  "schemaVersion": 11,
  "exporter": { "name": "Camunda Modeler", "version": "standalone-lab" },
  "type": "default",
  "id": "recruiter-decision-form",
  "components": [
    {
      "type": "html",
      "id": "errorBanner",
      "content": "<div style=\"padding:12px;border-radius:6px;background:#fee2e2;color:#991b1b;\">{{formErrorMessage}}</div>",
      "conditional": { "hide": "=formErrorMessage = null or formErrorMessage = \"\"" }
    },
    { "type": "text", "id": "contextHeader", "text": "## Контекст отклика" },
    { "type": "textfield", "id": "applicationId", "key": "applicationId", "label": "ID отклика", "readonly": true },
    { "type": "textfield", "id": "vacancyTitle", "key": "vacancyTitle", "label": "Вакансия", "readonly": true },
    { "type": "textfield", "id": "status", "key": "status", "label": "Текущий статус", "readonly": true },
    { "type": "text", "id": "decisionHeader", "text": "## Решение рекрутера" },
    {
      "type": "select",
      "id": "decision",
      "key": "decision",
      "label": "Решение по отклику",
      "values": [
        { "label": "Пригласить", "value": "INVITE" },
        { "label": "Отказать", "value": "REJECT" },
        { "label": "Вакансия закрыта", "value": "VACANCY_CLOSED" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "textarea",
      "id": "recruiterComment",
      "key": "recruiterComment",
      "label": "Комментарий",
      "validate": { "maxLength": 5000 }
    }
  ]
}
