{
  "schemaVersion": 11,
  "exporter": { "name": "Camunda Modeler", "version": "standalone-lab" },
  "type": "default",
  "id": "invitation-response-form",
  "components": [
    {
      "type": "html",
      "id": "errorBanner",
      "content": "<div style=\"padding:12px;border-radius:6px;background:#fee2e2;color:#991b1b;\"><strong>Ошибка формы:</strong> {{formErrorMessage}}<br/><span>Поля: {{formErrorFields}}</span></div>",
      "conditional": { "hide": "=formErrorMessage = null or formErrorMessage = \"\"" }
    },
    { "type": "text", "id": "contextHeader", "text": "## Контекст приглашения" },
    { "type": "textfield", "id": "applicationId", "key": "applicationId", "label": "ID отклика", "readonly": true },
    { "type": "textfield", "id": "vacancyTitle", "key": "vacancyTitle", "label": "Вакансия", "readonly": true },
    { "type": "textfield", "id": "invitationExpiresAt", "key": "invitationExpiresAt", "label": "Срок ответа", "readonly": true },
    { "type": "text", "id": "inputHeader", "text": "## Ответ кандидата" },
    {
      "type": "select",
      "id": "responseType",
      "key": "responseType",
      "label": "Ответ на приглашение",
      "values": [
        { "label": "Принять", "value": "ACCEPT" },
        { "label": "Отклонить", "value": "DECLINE" },
        { "label": "Другой ответ", "value": "OTHER" }
      ],
      "validate": { "required": true }
    },
    { "type": "textarea", "id": "responseMessage", "key": "responseMessage", "label": "Комментарий", "validate": { "maxLength": 5000 } }
  ]
}
