{
  "schemaVersion": 11,
  "exporter": { "name": "Camunda Modeler", "version": "standalone-lab" },
  "type": "default",
  "id": "admin-timeout-run-form",
  "components": [
    {
      "type": "html",
      "id": "errorBanner",
      "content": "<div style=\"padding:12px;border-radius:6px;background:#fee2e2;color:#991b1b;\">{{formErrorMessage}}</div>",
      "conditional": { "hide": "=formErrorMessage = null or formErrorMessage = \"\"" }
    },
    { "type": "text", "id": "header", "text": "## Ручная проверка таймаутов" },
    { "type": "textfield", "id": "starterUserId", "key": "starterUserId", "label": "Camunda пользователь", "readonly": true },
    { "type": "checkbox", "id": "confirmed", "key": "confirmed", "label": "Запустить ручную проверку просроченных приглашений", "validate": { "required": true } }
  ]
}
