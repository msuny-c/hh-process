<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_hh_ui_recruiter_application_view" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED" />
  <bpmn:collaboration id="Collaboration_hhUiRecruiterApplicationView" name="Пул: экран одного отклика рекрутера">
    <bpmn:participant id="Participant_hhUiRecruiterApplicationView" name="Пул: экран одного отклика рекрутера" processRef="hhUiRecruiterApplicationView" />
  </bpmn:collaboration>
  <bpmn:process id="hhUiRecruiterApplicationView" name="Экран одного отклика рекрутера" isExecutable="true" camunda:candidateStarterGroups="RECRUITER" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_hhUiRecruiterApplicationView">
      <bpmn:lane id="Lane_hhUiRecruiterApplicationView_RoleSystem" name="Рекрутер / администратор / система">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EnterRecruiterApplicationId</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LoadRecruiterApplicationView</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterApplicationViewValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>DisplayRecruiterApplicationView</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" camunda:initiator="starterUserId" name="Рекрутер открыл карточку отклика" />
    <bpmn:userTask id="EnterRecruiterApplicationId" name="Ввести или выбрать идентификатор отклика" camunda:formRef="application-id-input-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:serviceTask id="LoadRecruiterApplicationView" name="Загрузить отклик с проверкой владельца-вакансии" camunda:type="external" camunda:topic="ui-query" />
    <bpmn:boundaryEvent id="RecruiterApplicationViewValidationError" attachedToRef="LoadRecruiterApplicationView">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="DisplayRecruiterApplicationView" name="Показать рекрутеру детали отклика" camunda:formRef="ui-json-display-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:endEvent id="End" name="Карточка отклика показана рекрутеру" />
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="EnterRecruiterApplicationId" />
    <bpmn:sequenceFlow id="F2" sourceRef="EnterRecruiterApplicationId" targetRef="LoadRecruiterApplicationView" />
    <bpmn:sequenceFlow id="F2e" name="ошибка формы: повторить ввод" sourceRef="RecruiterApplicationViewValidationError" targetRef="EnterRecruiterApplicationId" />
    <bpmn:sequenceFlow id="F3" sourceRef="LoadRecruiterApplicationView" targetRef="DisplayRecruiterApplicationView" />
    <bpmn:sequenceFlow id="F4" sourceRef="DisplayRecruiterApplicationView" targetRef="End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_hhUiRecruiterApplicationView">
    <bpmndi:BPMNPlane id="BPMNPlane_hhUiRecruiterApplicationView" bpmnElement="Collaboration_hhUiRecruiterApplicationView">
      <bpmndi:BPMNShape id="BPMNShape_Participant_hhUiRecruiterApplicationView" bpmnElement="Participant_hhUiRecruiterApplicationView" isHorizontal="true">
        <dc:Bounds x="80" y="60" width="1536" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_hhUiRecruiterApplicationView_RoleSystem" bpmnElement="Lane_hhUiRecruiterApplicationView_RoleSystem" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="1416" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Start" bpmnElement="Start">
        <dc:Bounds x="220" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EnterRecruiterApplicationId" bpmnElement="EnterRecruiterApplicationId">
        <dc:Bounds x="380" y="120" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_LoadRecruiterApplicationView" bpmnElement="LoadRecruiterApplicationView">
        <dc:Bounds x="640" y="120" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RecruiterApplicationViewValidationError" bpmnElement="RecruiterApplicationViewValidationError">
        <dc:Bounds x="812" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_DisplayRecruiterApplicationView" bpmnElement="DisplayRecruiterApplicationView">
        <dc:Bounds x="900" y="120" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End" bpmnElement="End">
        <dc:Bounds x="1160" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_F1" bpmnElement="F1">
        <di:waypoint x="256" y="160.0" /><di:waypoint x="380" y="160.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F2" bpmnElement="F2">
        <di:waypoint x="570" y="160.0" /><di:waypoint x="640" y="160.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F2e" bpmnElement="F2e">
        <di:waypoint x="812" y="200.0" /><di:waypoint x="570" y="200.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F3" bpmnElement="F3">
        <di:waypoint x="830" y="160.0" /><di:waypoint x="900" y="160.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F4" bpmnElement="F4">
        <di:waypoint x="1090" y="160.0" /><di:waypoint x="1160" y="160.0" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
