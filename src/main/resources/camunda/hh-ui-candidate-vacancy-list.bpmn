<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_hh_ui_candidate_vacancy_list" targetNamespace="http://itmo.ru/hhprocess/camunda">
  <bpmn:process id="hhUiCandidateVacancyList" name="HH UI candidate vacancy list" isExecutable="true" camunda:candidateStarterGroups="CANDIDATE,ADMIN" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="Start" camunda:initiator="starterUserId"/>
    <bpmn:serviceTask id="LoadCandidateVacancyList" name="Загрузить активные вакансии" camunda:type="external" camunda:topic="ui-query"/>
    <bpmn:userTask id="DisplayCandidateVacancyList" name="Список вакансий кандидата" camunda:formRef="ui-json-display-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE,ADMIN"/>
    <bpmn:endEvent id="End"/>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="LoadCandidateVacancyList"/>
    <bpmn:sequenceFlow id="F2" sourceRef="LoadCandidateVacancyList" targetRef="DisplayCandidateVacancyList"/>
    <bpmn:sequenceFlow id="F3" sourceRef="DisplayCandidateVacancyList" targetRef="End"/>
  </bpmn:process>
</bpmn:definitions>
