        <bpmndi:BPMNLabel>
          <dc:Bounds x="1369" y="265" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VS7" bpmnElement="VS7">
        <di:waypoint x="1455" y="350" />
