<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_hh_vacancy_status_update" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED" />
  <bpmn:collaboration id="Collaboration_hhVacancyStatusUpdateProcess" name="Пул: изменение статуса вакансии">
    <bpmn:participant id="Participant_hhVacancyStatusUpdateProcess" name="Пул: изменение статуса вакансии" processRef="hhVacancyStatusUpdateProcess" />
  </bpmn:collaboration>
  <bpmn:process id="hhVacancyStatusUpdateProcess" name="Изменение статуса вакансии" isExecutable="true" camunda:candidateStarterGroups="RECRUITER" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_hhVacancyStatusUpdateProcess">
      <bpmn:lane id="Lane_hhVacancyStatusUpdateProcess_RoleSystem" name="Рекрутер / администратор / система">
        <bpmn:flowNodeRef>VacancyStatusUpdateStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PrepareVacancyStatusTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateVacancyStatusTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyStatusTransitionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApplyVacancyStatusUpdate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyStatusResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyStatusUpdateEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UpdateVacancyStatusTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateVacancyStatusUpdate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyStatusValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyStatusTransitionDenied</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="VacancyStatusUpdateStart" name="Рекрутер запросил изменение статуса вакансии" camunda:initiator="starterUserId" />
    <bpmn:serviceTask id="PrepareVacancyStatusTransition" name="Система: подготовить текущий и новый статус вакансии для таблицы решений" camunda:type="external" camunda:topic="status-transition" />
    <bpmn:businessRuleTask id="EvaluateVacancyStatusTransition" name="Таблица решений: разрешить или запретить новый статус вакансии" camunda:resultVariable="statusTransition" camunda:decisionRef="hhStatusTransitions" camunda:mapDecisionResult="singleResult" camunda:decisionRefBinding="latest" />
    <bpmn:exclusiveGateway id="VacancyStatusTransitionGateway" name="Таблица решений разрешила новый статус вакансии?" />
    <bpmn:serviceTask id="ApplyVacancyStatusUpdate" name="Сохранить новый статус вакансии" camunda:type="external" camunda:topic="vacancy-status-update" />
    <bpmn:userTask id="VacancyStatusResultTask" name="Показать результат изменения статуса вакансии" camunda:formRef="vacancy-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:endEvent id="VacancyStatusUpdateEnd" name="Статус вакансии обновлён" />
    <bpmn:userTask id="UpdateVacancyStatusTask" name="Рекрутер выбирает новый статус вакансии" camunda:formRef="vacancy-status-update-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER" />
    <bpmn:serviceTask id="ValidateVacancyStatusUpdate" name="Проверить форму и что вакансия принадлежит рекрутеру" camunda:type="external" camunda:topic="vacancy-status-update" />
    <bpmn:boundaryEvent id="VacancyStatusValidationError" attachedToRef="ValidateVacancyStatusUpdate">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="VS1" sourceRef="VacancyStatusUpdateStart" targetRef="UpdateVacancyStatusTask" />
    <bpmn:sequenceFlow id="VS3" sourceRef="ValidateVacancyStatusUpdate" targetRef="PrepareVacancyStatusTransition" />
    <bpmn:sequenceFlow id="VS4" name="данные статуса подготовлены" sourceRef="PrepareVacancyStatusTransition" targetRef="EvaluateVacancyStatusTransition" />
    <bpmn:sequenceFlow id="VS5" name="таблица решений вернула разрешение и следующий статус" sourceRef="EvaluateVacancyStatusTransition" targetRef="VacancyStatusTransitionGateway" />
    <bpmn:sequenceFlow id="VS6" name="таблица решений разрешила доступ" sourceRef="VacancyStatusTransitionGateway" targetRef="ApplyVacancyStatusUpdate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="VS7" name="таблица решений запретила доступ" sourceRef="VacancyStatusTransitionGateway" targetRef="VacancyStatusTransitionDenied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed != true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="VS8" sourceRef="ApplyVacancyStatusUpdate" targetRef="VacancyStatusResultTask" />
    <bpmn:sequenceFlow id="VS9" sourceRef="VacancyStatusResultTask" targetRef="VacancyStatusUpdateEnd" />
    <bpmn:sequenceFlow id="VS2e" sourceRef="VacancyStatusValidationError" targetRef="UpdateVacancyStatusTask" />
    <bpmn:sequenceFlow id="VS2" sourceRef="UpdateVacancyStatusTask" targetRef="ValidateVacancyStatusUpdate" />
    <bpmn:endEvent id="VacancyStatusTransitionDenied" name="Таблица решений запретила новый статус вакансии" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_hhVacancyStatusUpdateProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_hhVacancyStatusUpdateProcess" bpmnElement="Collaboration_hhVacancyStatusUpdateProcess">
      <bpmndi:BPMNShape id="BPMNShape_Participant_hhVacancyStatusUpdateProcess" bpmnElement="Participant_hhVacancyStatusUpdateProcess" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2488" height="376" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_hhVacancyStatusUpdateProcess_RoleSystem" bpmnElement="Lane_hhVacancyStatusUpdateProcess_RoleSystem" isHorizontal="true">
        <dc:Bounds x="260" y="100" width="2368" height="336" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStatusUpdateStart" bpmnElement="VacancyStatusUpdateStart">
        <dc:Bounds x="300" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="289" y="268" width="59" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_PrepareVacancyStatusTransition" bpmnElement="PrepareVacancyStatusTransition">
        <dc:Bounds x="950" y="140" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EvaluateVacancyStatusTransition" bpmnElement="EvaluateVacancyStatusTransition">
        <dc:Bounds x="950" y="310" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStatusTransitionGateway" bpmnElement="VacancyStatusTransitionGateway" isMarkerVisible="true">
        <dc:Bounds x="1405" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1465" y="330" width="86" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ApplyVacancyStatusUpdate" bpmnElement="ApplyVacancyStatusUpdate">
        <dc:Bounds x="1660" y="180" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStatusResultTask" bpmnElement="VacancyStatusResultTask">
        <dc:Bounds x="1920" y="180" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStatusUpdateEnd" bpmnElement="VacancyStatusUpdateEnd">
        <dc:Bounds x="2192" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2167" y="238" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_UpdateVacancyStatusTask" bpmnElement="UpdateVacancyStatusTask">
        <dc:Bounds x="405" y="210" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateVacancyStatusUpdate" bpmnElement="ValidateVacancyStatusUpdate">
        <dc:Bounds x="700" y="210" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStatusTransitionDenied" bpmnElement="VacancyStatusTransitionDenied">
        <dc:Bounds x="1722" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1696" y="368" width="88" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStatusValidationError" bpmnElement="VacancyStatusValidationError">
        <dc:Bounds x="850" y="272" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_VS1" bpmnElement="VS1">
        <di:waypoint x="336" y="250" />
        <di:waypoint x="405" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VS3" bpmnElement="VS3">
        <di:waypoint x="890" y="250" />
        <di:waypoint x="920" y="250" />
        <di:waypoint x="920" y="180" />
        <di:waypoint x="950" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VS4" bpmnElement="VS4">
        <di:waypoint x="1060" y="220" />
        <di:waypoint x="1060" y="310" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1028" y="251" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VS5" bpmnElement="VS5">
        <di:waypoint x="1170" y="350" />
        <di:waypoint x="1405" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1244" y="325" width="87" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VS6" bpmnElement="VS6">
        <di:waypoint x="1455" y="340" />
