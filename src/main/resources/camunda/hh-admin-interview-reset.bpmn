<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_hh_v3" targetNamespace="http://itmo.ru/hhprocess/camunda">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED"/>
  <bpmn:error id="Error_AdminResetFailed" name="ADMIN_RESET_FAILED" errorCode="ADMIN_RESET_FAILED"/>
  <bpmn:process id="hhAdminInterviewResetProcess" name="HH admin interview reset with roles" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_AdminReset">
      <bpmn:lane id="Lane_Admin_A" name="ADMIN">
        <bpmn:flowNodeRef>AdminResetStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetApprovalTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetRollbackEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetResultTask</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System_A" name="SYSTEM">
        <bpmn:flowNodeRef>ValidateAdminResetForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_AdminInterviewReset</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyAdminResetParticipants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RollbackAdminReset</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="AdminResetStart" name="Админ запросил сброс интервью"/>
    <bpmn:userTask id="AdminResetApprovalTask" name="Подтвердить сброс интервью" camunda:formRef="reset-interview-form" camunda:formRefBinding="latest" camunda:candidateGroups="ADMIN"/>
    <bpmn:serviceTask id="ValidateAdminResetForm" name="Проверить форму админского сброса" camunda:type="external" camunda:topic="admin-interview-reset"/>
    <bpmn:boundaryEvent id="AdminResetFormError" attachedToRef="ValidateAdminResetForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:transaction id="Transaction_AdminInterviewReset" name="TX: административный сброс интервью">
      <bpmn:startEvent id="Transaction_AdminInterviewReset_Start" name="Начать транзакционный блок"/>
      <bpmn:serviceTask id="ValidateInterviewCanBeReset" name="Проверить возможность сброса интервью" camunda:type="external" camunda:topic="admin-interview-reset"/>
      <bpmn:serviceTask id="CancelInterviewByAdmin" name="Отменить интервью" camunda:type="external" camunda:topic="admin-interview-reset"/>
      <bpmn:serviceTask id="ReleaseAdminResetSlot" name="Освободить слот интервью" camunda:type="external" camunda:topic="admin-interview-reset"/>
      <bpmn:serviceTask id="ReturnApplicationToReview" name="Вернуть отклик на рассмотрение" camunda:type="external" camunda:topic="admin-interview-reset"/>
      <bpmn:serviceTask id="RecordAdminResetHistory" name="Записать историю админского сброса" camunda:type="external" camunda:topic="admin-interview-reset"/>
      <bpmn:endEvent id="Transaction_AdminInterviewReset_End" name="Завершить транзакционный блок"/>
      <bpmn:sequenceFlow id="Transaction_AdminInterviewReset_SF_Start" sourceRef="Transaction_AdminInterviewReset_Start" targetRef="ValidateInterviewCanBeReset"/>
      <bpmn:sequenceFlow id="ATX1" sourceRef="ValidateInterviewCanBeReset" targetRef="CancelInterviewByAdmin"/>
      <bpmn:sequenceFlow id="ATX2" sourceRef="CancelInterviewByAdmin" targetRef="ReleaseAdminResetSlot"/>
      <bpmn:sequenceFlow id="ATX3" sourceRef="ReleaseAdminResetSlot" targetRef="ReturnApplicationToReview"/>
      <bpmn:sequenceFlow id="ATX4" sourceRef="ReturnApplicationToReview" targetRef="RecordAdminResetHistory"/>
      <bpmn:sequenceFlow id="Transaction_AdminInterviewReset_SF_End" sourceRef="RecordAdminResetHistory" targetRef="Transaction_AdminInterviewReset_End"/>
    </bpmn:transaction>
    <bpmn:boundaryEvent id="AdminResetErrorBoundary" attachedToRef="Transaction_AdminInterviewReset">
      <bpmn:errorEventDefinition errorRef="Error_AdminResetFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="NotifyAdminResetParticipants" name="Уведомить участников о сбросе интервью" camunda:type="external" camunda:topic="admin-interview-reset"/>
    <bpmn:serviceTask id="RollbackAdminReset" name="Выполнить recovery админского сброса" camunda:type="external" camunda:topic="transaction-rollback"/>
    <bpmn:endEvent id="AdminResetEnd" name="Админский сброс выполнен"/>
    <bpmn:endEvent id="AdminResetRollbackEnd" name="Recovery сброса завершён"/>
    <bpmn:userTask id="AdminResetResultTask" name="Показать результат сброса интервью" camunda:formRef="admin-reset-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="ADMIN"/>
    <bpmn:sequenceFlow id="AF1" sourceRef="AdminResetStart" targetRef="AdminResetApprovalTask"/>
    <bpmn:sequenceFlow id="AF2" sourceRef="AdminResetApprovalTask" targetRef="ValidateAdminResetForm"/>
    <bpmn:sequenceFlow id="AF2e" sourceRef="AdminResetFormError" targetRef="AdminResetApprovalTask"/>
    <bpmn:sequenceFlow id="AF3" sourceRef="ValidateAdminResetForm" targetRef="Transaction_AdminInterviewReset"/>
    <bpmn:sequenceFlow id="AF4" sourceRef="Transaction_AdminInterviewReset" targetRef="NotifyAdminResetParticipants"/>
    <bpmn:sequenceFlow id="AF5" sourceRef="NotifyAdminResetParticipants" targetRef="AdminResetResultTask"/>
    <bpmn:sequenceFlow id="AF6" sourceRef="AdminResetErrorBoundary" targetRef="RollbackAdminReset"/>
    <bpmn:sequenceFlow id="AF7" sourceRef="RollbackAdminReset" targetRef="AdminResetRollbackEnd"/>
    <bpmn:sequenceFlow id="AF_Result_End" sourceRef="AdminResetResultTask" targetRef="AdminResetEnd"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AutoLayout">
    <bpmndi:BPMNPlane id="BPMNPlane_AutoLayout" bpmnElement="hhAdminInterviewResetProcess">
      <bpmndi:BPMNShape id="BPMNShape_Lane_Admin_A" bpmnElement="Lane_Admin_A" isHorizontal="true">
        <dc:Bounds x="20" y="40" width="2600" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_System_A" bpmnElement="Lane_System_A" isHorizontal="true">
        <dc:Bounds x="20" y="210" width="2600" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetStart" bpmnElement="AdminResetStart">
        <dc:Bounds x="80" y="85" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetApprovalTask" bpmnElement="AdminResetApprovalTask">
        <dc:Bounds x="300" y="85" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateAdminResetForm" bpmnElement="ValidateAdminResetForm">
        <dc:Bounds x="80" y="255" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetFormError" bpmnElement="AdminResetFormError">
        <dc:Bounds x="520" y="85" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_AdminInterviewReset" bpmnElement="Transaction_AdminInterviewReset" isExpanded="true">
        <dc:Bounds x="300" y="255" width="210" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_AdminInterviewReset_Start" bpmnElement="Transaction_AdminInterviewReset_Start">
        <dc:Bounds x="330" y="290" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateInterviewCanBeReset" bpmnElement="ValidateInterviewCanBeReset">
        <dc:Bounds x="495" y="290" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CancelInterviewByAdmin" bpmnElement="CancelInterviewByAdmin">
        <dc:Bounds x="660" y="290" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ReleaseAdminResetSlot" bpmnElement="ReleaseAdminResetSlot">
        <dc:Bounds x="825" y="290" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ReturnApplicationToReview" bpmnElement="ReturnApplicationToReview">
        <dc:Bounds x="990" y="290" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RecordAdminResetHistory" bpmnElement="RecordAdminResetHistory">
        <dc:Bounds x="1155" y="290" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_AdminInterviewReset_End" bpmnElement="Transaction_AdminInterviewReset_End">
        <dc:Bounds x="2310" y="290" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetErrorBoundary" bpmnElement="AdminResetErrorBoundary">
        <dc:Bounds x="740" y="85" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_NotifyAdminResetParticipants" bpmnElement="NotifyAdminResetParticipants">
        <dc:Bounds x="740" y="255" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RollbackAdminReset" bpmnElement="RollbackAdminReset">
        <dc:Bounds x="960" y="255" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetEnd" bpmnElement="AdminResetEnd">
        <dc:Bounds x="1180" y="85" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetRollbackEnd" bpmnElement="AdminResetRollbackEnd">
        <dc:Bounds x="1400" y="85" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_AdminResetResultTask" bpmnElement="AdminResetResultTask">
        <dc:Bounds x="1620" y="85" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Transaction_AdminInterviewReset_SF_Start" bpmnElement="Transaction_AdminInterviewReset_SF_Start">
        <di:waypoint x="366" y="308.0"/>
        <di:waypoint x="495" y="320.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ATX1" bpmnElement="ATX1">
        <di:waypoint x="635" y="320.0"/>
        <di:waypoint x="660" y="320.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ATX2" bpmnElement="ATX2">
        <di:waypoint x="800" y="320.0"/>
        <di:waypoint x="825" y="320.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ATX3" bpmnElement="ATX3">
        <di:waypoint x="965" y="320.0"/>
        <di:waypoint x="990" y="320.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ATX4" bpmnElement="ATX4">
        <di:waypoint x="1130" y="320.0"/>
        <di:waypoint x="1155" y="320.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Transaction_AdminInterviewReset_SF_End" bpmnElement="Transaction_AdminInterviewReset_SF_End">
        <di:waypoint x="1295" y="320.0"/>
        <di:waypoint x="2310" y="308.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF1" bpmnElement="AF1">
        <di:waypoint x="116" y="103.0"/>
        <di:waypoint x="300" y="125.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF2" bpmnElement="AF2">
        <di:waypoint x="470" y="125.0"/>
        <di:waypoint x="80" y="295.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF2e" bpmnElement="AF2e">
        <di:waypoint x="556" y="103.0"/>
        <di:waypoint x="300" y="125.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF3" bpmnElement="AF3">
        <di:waypoint x="250" y="295.0"/>
        <di:waypoint x="300" y="315.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF4" bpmnElement="AF4">
        <di:waypoint x="510" y="315.0"/>
        <di:waypoint x="740" y="295.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF5" bpmnElement="AF5">
        <di:waypoint x="910" y="295.0"/>
        <di:waypoint x="1620" y="125.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF6" bpmnElement="AF6">
        <di:waypoint x="776" y="103.0"/>
        <di:waypoint x="960" y="295.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF7" bpmnElement="AF7">
        <di:waypoint x="1130" y="295.0"/>
        <di:waypoint x="1400" y="103.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_AF_Result_End" bpmnElement="AF_Result_End">
        <di:waypoint x="1790" y="125.0"/>
        <di:waypoint x="1180" y="103.0"/>
      </bpmndi:BPMNEdge>
      </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
