<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_hh_v3" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:collaboration id="Collaboration_hhTimeoutSchedulerProcess" name="Пул: планировщик просроченных приглашений">
    <bpmn:participant id="Participant_hhTimeoutSchedulerProcess" name="Пул: планировщик просроченных приглашений" processRef="hhTimeoutSchedulerProcess" />
  </bpmn:collaboration>
  <bpmn:process id="hhTimeoutSchedulerProcess" name="Планировщик просроченных приглашений" isExecutable="true" camunda:candidateStarterGroups="ADMIN" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_Timeout">
      <bpmn:lane id="Lane_Timer_T" name="Таймер">
        <bpmn:flowNodeRef>TimeoutTimerStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>FindOneExpiredInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExpiredFoundGateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System_T" name="Система">
        <bpmn:flowNodeRef>NotifyExpiredInvitationParticipants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_TimeoutOneInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowCompensationTimeoutRollback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompleteExpiredInvitationProcess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_TimeoutOneInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Cancel_Transaction_TimeoutOneInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_TimeoutOneInvitation_Boundary</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="TimeoutTimerStart" name="Таймер запускает проверку просроченных приглашений">
      <bpmn:timerEventDefinition>
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT5M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="FindOneExpiredInvitation" name="Найти приглашение, срок ответа по которому истёк" camunda:type="external" camunda:topic="timeout-close-expired" />
    <bpmn:endEvent id="NoExpiredInvitationsEnd" name="Просроченных приглашений нет" />
    <bpmn:callActivity id="NotifyExpiredInvitationParticipants" name="Подпроцесс: уведомить участников о таймауте" calledElement="hhNotificationProcess" camunda:calledElementBinding="latest">
      <bpmn:extensionElements>
        <camunda:in sourceExpression="${'TIMEOUT'}" target="notificationKind" />
        <camunda:in source="expiredApplicationId" target="applicationId" />
        <camunda:in source="expiredApplicationId" target="expiredApplicationId" />
        <camunda:out source="notificationDispatched" target="NotifyExpiredInvitationParticipantsDispatched" />
        <camunda:out source="notificationKind" target="lastNotificationKind" />
      </bpmn:extensionElements>
    </bpmn:callActivity>
    <bpmn:serviceTask id="Compensate_Transaction_TimeoutOneInvitation" name="Компенсация: откатить закрытие по таймауту" isForCompensation="true" camunda:type="external" camunda:topic="transaction-rollback" />
    <bpmn:exclusiveGateway id="ExpiredFoundGateway" name="Есть просроченное приглашение?" />
    <bpmn:intermediateThrowEvent id="ThrowCompensationTimeoutRollback" name="Запустить компенсацию отката после ошибки">
      <bpmn:compensateEventDefinition waitForCompletion="true" />
    </bpmn:intermediateThrowEvent>
    <bpmn:serviceTask id="CompleteExpiredInvitationProcess" name="Сообщить процессу отклика о таймауте" camunda:type="external" camunda:topic="timeout-close-expired" />
    <bpmn:transaction id="Transaction_TimeoutOneInvitation" name="Транзакция: обработка одной просрочки">
      <bpmn:startEvent id="Transaction_TimeoutOneInvitation_Start" name="Начать транзакцию бизнес-операции" />
      <bpmn:serviceTask id="CancelExpiredInvitationInterview" name="Отменить интервью из-за таймаута ответа" camunda:type="external" camunda:topic="timeout-close-expired">
        <bpmn:outgoing>TTX1</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="CloseExpiredInvitationApplication" name="Закрыть отклик из-за просроченного ответа" camunda:type="external" camunda:topic="timeout-close-expired">
        <bpmn:incoming>TTX2</bpmn:incoming>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="RecordExpiredInvitationHistory" name="Записать историю закрытия по таймауту" camunda:type="external" camunda:topic="timeout-close-expired" />
      <bpmn:endEvent id="Transaction_TimeoutOneInvitation_End" name="Завершить транзакцию бизнес-операции" />
      <bpmn:sequenceFlow id="Transaction_TimeoutOneInvitation_SF_Start" sourceRef="Transaction_TimeoutOneInvitation_Start" targetRef="CancelExpiredInvitationInterview" />
      <bpmn:sequenceFlow id="TTX3" sourceRef="CloseExpiredInvitationApplication" targetRef="RecordExpiredInvitationHistory" />
      <bpmn:sequenceFlow id="Transaction_TimeoutOneInvitation_SF_End" sourceRef="RecordExpiredInvitationHistory" targetRef="Transaction_TimeoutOneInvitation_End" />
      <bpmn:sequenceFlow id="TTX2" sourceRef="ReleaseExpiredInvitationSlot" targetRef="CloseExpiredInvitationApplication" />
      <bpmn:sequenceFlow id="TTX1" sourceRef="CancelExpiredInvitationInterview" targetRef="ReleaseExpiredInvitationSlot" />
      <bpmn:serviceTask id="ReleaseExpiredInvitationSlot" name="Освободить слот интервью после таймаута" camunda:type="external" camunda:topic="timeout-close-expired">
        <bpmn:incoming>TTX1</bpmn:incoming>
        <bpmn:outgoing>TTX2</bpmn:outgoing>
      </bpmn:serviceTask>
    </bpmn:transaction>
    <bpmn:boundaryEvent id="Cancel_Transaction_TimeoutOneInvitation" name="Ошибка транзакции: обработка таймаута приглашения" attachedToRef="Transaction_TimeoutOneInvitation">
      <bpmn:cancelEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Compensate_Transaction_TimeoutOneInvitation_Boundary" name="Компенсация: откат обработки таймаута" attachedToRef="Transaction_TimeoutOneInvitation">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="TF1" sourceRef="TimeoutTimerStart" targetRef="FindOneExpiredInvitation" />
    <bpmn:sequenceFlow id="TF7" sourceRef="CompleteExpiredInvitationProcess" targetRef="FindOneExpiredInvitation" />
    <bpmn:sequenceFlow id="TF2" sourceRef="FindOneExpiredInvitation" targetRef="ExpiredFoundGateway" />
    <bpmn:sequenceFlow id="TF3" sourceRef="ExpiredFoundGateway" targetRef="NoExpiredInvitationsEnd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${expiredFound == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="TF5" sourceRef="Transaction_TimeoutOneInvitation" targetRef="NotifyExpiredInvitationParticipants" />
    <bpmn:sequenceFlow id="TF6" sourceRef="NotifyExpiredInvitationParticipants" targetRef="CompleteExpiredInvitationProcess" />
    <bpmn:sequenceFlow id="TF4" sourceRef="ExpiredFoundGateway" targetRef="Transaction_TimeoutOneInvitation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${expiredFound == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Cancel_Transaction_TimeoutOneInvitation_Recovery" name="отмена транзакции: запустить компенсацию" sourceRef="Cancel_Transaction_TimeoutOneInvitation" targetRef="ThrowCompensationTimeoutRollback" />
    <bpmn:sequenceFlow id="TF_CANCEL_COMPENSATED" name="компенсация выполнена" sourceRef="ThrowCompensationTimeoutRollback" targetRef="CompleteExpiredInvitationProcess" />
    <bpmn:association id="Association_Compensate_Transaction_TimeoutOneInvitation" sourceRef="Compensate_Transaction_TimeoutOneInvitation_Boundary" targetRef="Compensate_Transaction_TimeoutOneInvitation" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AutoLayout">
    <bpmndi:BPMNPlane id="BPMNPlane_AutoLayout" bpmnElement="Collaboration_hhTimeoutSchedulerProcess">
      <bpmndi:BPMNShape id="BPMNShape_Participant_hhTimeoutSchedulerProcess" bpmnElement="Participant_hhTimeoutSchedulerProcess" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="3080" height="900" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_Timer_T" bpmnElement="Lane_Timer_T" isHorizontal="true">
        <dc:Bounds x="260" y="340" width="2960" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_System_T" bpmnElement="Lane_System_T" isHorizontal="true">
        <dc:Bounds x="260" y="510" width="2960" height="380" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_TimeoutTimerStart" bpmnElement="TimeoutTimerStart">
        <dc:Bounds x="320" y="385" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="302" y="421" width="74" height="66" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_FindOneExpiredInvitation" bpmnElement="FindOneExpiredInvitation">
        <dc:Bounds x="455" y="363" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_NoExpiredInvitationsEnd" bpmnElement="NoExpiredInvitationsEnd">
        <dc:Bounds x="1582" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1557" y="208" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_NotifyExpiredInvitationParticipants" bpmnElement="NotifyExpiredInvitationParticipants">
        <dc:Bounds x="1265" y="640" width="170" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Compensate_Transaction_TimeoutOneInvitation" bpmnElement="Compensate_Transaction_TimeoutOneInvitation">
        <dc:Bounds x="1325" y="754" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ExpiredFoundGateway" bpmnElement="ExpiredFoundGateway" isMarkerVisible="true">
        <dc:Bounds x="855" y="440" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="915" y="445" width="74" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ThrowCompensationTimeoutRollback" bpmnElement="ThrowCompensationTimeoutRollback">
        <dc:Bounds x="1672" y="522" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1655" y="558" width="70" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CompleteExpiredInvitationProcess" bpmnElement="CompleteExpiredInvitationProcess">
        <dc:Bounds x="2005" y="550" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_TimeoutOneInvitation" bpmnElement="Transaction_TimeoutOneInvitation" isExpanded="true">
        <dc:Bounds x="470" y="600" width="750" height="230" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_TimeoutOneInvitation_Start" bpmnElement="Transaction_TimeoutOneInvitation_Start">
        <dc:Bounds x="500" y="632" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="486" y="668" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CancelExpiredInvitationInterview" bpmnElement="CancelExpiredInvitationInterview">
        <dc:Bounds x="580" y="620" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ReleaseExpiredInvitationSlot" bpmnElement="ReleaseExpiredInvitationSlot">
        <dc:Bounds x="590" y="740" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CloseExpiredInvitationApplication" bpmnElement="CloseExpiredInvitationApplication">
        <dc:Bounds x="770" y="630" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RecordExpiredInvitationHistory" bpmnElement="RecordExpiredInvitationHistory">
        <dc:Bounds x="890" y="720" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_TimeoutOneInvitation_End" bpmnElement="Transaction_TimeoutOneInvitation_End">
        <dc:Bounds x="1092" y="662" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1067" y="698" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Transaction_TimeoutOneInvitation_SF_Start" bpmnElement="Transaction_TimeoutOneInvitation_SF_Start">
        <di:waypoint x="536" y="650" />
        <di:waypoint x="580" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TTX1" bpmnElement="TTX1">
        <di:waypoint x="650" y="680" />
        <di:waypoint x="650" y="710" />
        <di:waypoint x="660" y="710" />
        <di:waypoint x="660" y="740" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TTX2" bpmnElement="TTX2">
        <di:waypoint x="730" y="770" />
        <di:waypoint x="810" y="770" />
        <di:waypoint x="810" y="690" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TTX3" bpmnElement="TTX3">
        <di:waypoint x="910" y="660" />
        <di:waypoint x="960" y="660" />
        <di:waypoint x="960" y="720" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Transaction_TimeoutOneInvitation_SF_End" bpmnElement="Transaction_TimeoutOneInvitation_SF_End">
        <di:waypoint x="1030" y="750" />
        <di:waypoint x="1060" y="750" />
        <di:waypoint x="1060" y="680" />
        <di:waypoint x="1092" y="680" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Association_Compensate_Transaction_TimeoutOneInvitation" bpmnElement="Association_Compensate_Transaction_TimeoutOneInvitation">
        <di:waypoint x="1237" y="794" />
        <di:waypoint x="1282" y="794" />
        <di:waypoint x="1282" y="820" />
        <di:waypoint x="1325" y="820" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="BPMNShape_Cancel_Transaction_TimeoutOneInvitation" bpmnElement="Cancel_Transaction_TimeoutOneInvitation">
        <dc:Bounds x="1576" y="827" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1622" y="805" width="68" height="66" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Compensate_Transaction_TimeoutOneInvitation_Boundary" bpmnElement="Compensate_Transaction_TimeoutOneInvitation_Boundary">
        <dc:Bounds x="1202" y="782" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3695" y="818" width="83" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_TF1" bpmnElement="TF1">
        <di:waypoint x="356" y="403" />
        <di:waypoint x="455" y="403" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF2" bpmnElement="TF2">
        <di:waypoint x="540" y="443" />
        <di:waypoint x="540" y="465" />
        <di:waypoint x="855" y="465" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF3" bpmnElement="TF3">
        <di:waypoint x="880" y="440" />
        <di:waypoint x="880" y="190" />
        <di:waypoint x="1582" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF4" bpmnElement="TF4">
        <di:waypoint x="880" y="490" />
        <di:waypoint x="880" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF5" bpmnElement="TF5">
        <di:waypoint x="1220" y="680" />
        <di:waypoint x="1265" y="680" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF6" bpmnElement="TF6">
        <di:waypoint x="1435" y="680" />
        <di:waypoint x="2090" y="680" />
        <di:waypoint x="2090" y="630" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF7" bpmnElement="TF7">
        <di:waypoint x="2005" y="613" />
