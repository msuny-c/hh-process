        <di:waypoint x="1310" y="370" />
        <di:waypoint x="624" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_Cancel_Transaction_TimeoutOneInvitation_Recovery" bpmnElement="Flow_Cancel_Transaction_TimeoutOneInvitation_Recovery">
        <di:waypoint x="1594" y="827" />
        <di:waypoint x="1594" y="541" />
        <di:waypoint x="1672" y="541" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1562" y="509" width="70" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_TF_CANCEL_COMPENSATED" bpmnElement="TF_CANCEL_COMPENSATED">
        <di:waypoint x="1708" y="540" />
        <di:waypoint x="1857" y="540" />
        <di:waypoint x="1857" y="560" />
        <di:waypoint x="2005" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1827" y="538" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>