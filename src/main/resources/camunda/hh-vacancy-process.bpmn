<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_hh_v3" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED" />
  <bpmn:error id="Error_VacancyTxFailed" name="VACANCY_TX_FAILED" errorCode="VACANCY_TX_FAILED" />
  <bpmn:message id="Message_VacancyClosed" name="MSG_VACANCY_CLOSED" />
  <bpmn:collaboration id="Collaboration_hhVacancyProcess" name="Пул: процесс вакансии">
    <bpmn:participant id="Participant_hhVacancyProcess" name="Пул: процесс вакансии" processRef="hhVacancyProcess" />
  </bpmn:collaboration>
  <bpmn:process id="hhVacancyProcess" name="Процесс вакансии" isExecutable="true" camunda:candidateStarterGroups="RECRUITER" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_Vacancy">
      <bpmn:lane id="Lane_Recruiter_V" name="Рекрутер">
        <bpmn:flowNodeRef>VacancyCreatedResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CreateVacancyTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ManageVacancyTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedResultTask</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System_V" name="Система">
        <bpmn:flowNodeRef>VacancyStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyCreationModeGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateCreateVacancyForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateCloseVacancyForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateCloseVacancyTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseVacancyTransitionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseVacancyTransitionDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CreateVacancyFromForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PrepareCloseVacancyTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowCompensationVacancyRollback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RollbackVacancyTransaction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyRollbackEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CorrelateVacancyClosedApplications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyVacancyClosedCandidates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_CloseVacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseVacancyFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CreateVacancyFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CreateVacancyPersistError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseActiveApplicationsErrorBoundary</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="VacancyStart" name="Запущен процесс создания или управления вакансией" camunda:initiator="starterUserId" />
    <bpmn:exclusiveGateway id="VacancyCreationModeGateway" name="Способ запуска вакансии" default="VF2a" />
    <bpmn:serviceTask id="ValidateCreateVacancyForm" name="Проверить обязательные поля вакансии" camunda:type="external" camunda:topic="vacancy-create" />
    <bpmn:userTask id="VacancyCreatedResultTask" name="Показать рекрутеру результат создания вакансии" camunda:formRef="vacancy-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:serviceTask id="ValidateCloseVacancyForm" name="Проверить причину закрытия вакансии" camunda:type="external" camunda:topic="vacancy-close-applications" />
    <bpmn:businessRuleTask id="EvaluateCloseVacancyTransition" name="Таблица решений: разрешить или запретить закрытие вакансии" camunda:resultVariable="statusTransition" camunda:decisionRef="hhStatusTransitions" camunda:mapDecisionResult="singleResult" camunda:decisionRefBinding="latest" />
    <bpmn:exclusiveGateway id="CloseVacancyTransitionGateway" name="Таблица решений разрешила закрыть вакансию?" />
    <bpmn:endEvent id="CloseVacancyTransitionDenied" name="Таблица решений запретила закрытие вакансии" />
    <bpmn:userTask id="CreateVacancyTask" name="Рекрутер заполняет форму вакансии" camunda:formRef="create-vacancy-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>VF2a</bpmn:incoming>
      <bpmn:outgoing>VF2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="CreateVacancyFromForm" name="Создать вакансию и связать её с рекрутером" camunda:type="external" camunda:topic="vacancy-create" />
    <bpmn:userTask id="ManageVacancyTask" name="Рекрутер выбирает действие по вакансии" camunda:formRef="close-vacancy-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>VF2g</bpmn:incoming>
      <bpmn:outgoing>VF3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="PrepareCloseVacancyTransition" name="Система: подготовить текущий статус и закрытие вакансии для таблицы решений" camunda:type="external" camunda:topic="status-transition" />
    <bpmn:intermediateThrowEvent id="ThrowCompensationVacancyRollback" name="Запустить компенсацию отката закрытия вакансии">
      <bpmn:compensateEventDefinition waitForCompletion="true" />
    </bpmn:intermediateThrowEvent>
    <bpmn:serviceTask id="RollbackVacancyTransaction" name="Восстановить данные вакансии после ошибки" camunda:type="external" camunda:topic="transaction-rollback" />
    <bpmn:endEvent id="VacancyRollbackEnd" name="Восстановление после закрытия вакансии завершено" />
    <bpmn:userTask id="VacancyClosedResultTask" name="Показать результат закрытия вакансии" camunda:formRef="vacancy-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER,ADMIN" />
    <bpmn:endEvent id="VacancyClosedEnd" name="Вакансия закрыта, интервью и отклики обработаны" />
    <bpmn:serviceTask id="CorrelateVacancyClosedApplications" name="Сообщить активным откликам о закрытии вакансии" camunda:type="external" camunda:topic="vacancy-close-applications" />
    <bpmn:serviceTask id="NotifyVacancyClosedCandidates" name="Создать уведомления кандидатам о закрытии вакансии" camunda:type="external" camunda:topic="vacancy-close-applications" />
    <bpmn:transaction id="Transaction_CloseVacancy" name="Транзакция: закрытие вакансии">
      <bpmn:startEvent id="Transaction_CloseVacancy_Start" name="Начать транзакцию бизнес-операции" />
      <bpmn:serviceTask id="MarkVacancyClosed" name="Перевести вакансию в закрытый статус" camunda:type="external" camunda:topic="vacancy-close-applications" />
      <bpmn:serviceTask id="CancelActiveInterviewsForVacancy" name="Отменить активные интервью по закрытой вакансии" camunda:type="external" camunda:topic="vacancy-close-applications" />
      <bpmn:serviceTask id="ReleaseScheduleSlotsForClosedVacancy" name="Освободить слоты отменённых интервью" camunda:type="external" camunda:topic="vacancy-close-applications" />
      <bpmn:serviceTask id="CloseActiveApplicationsForVacancy" name="Закрыть активные отклики по вакансии" camunda:type="external" camunda:topic="vacancy-close-applications" />
      <bpmn:serviceTask id="RecordVacancyClosedHistory" name="Записать историю закрытия вакансии" camunda:type="external" camunda:topic="vacancy-close-applications" />
      <bpmn:endEvent id="Transaction_CloseVacancy_End" name="Завершить транзакцию бизнес-операции" />
      <bpmn:sequenceFlow id="Transaction_CloseVacancy_SF_Start" sourceRef="Transaction_CloseVacancy_Start" targetRef="MarkVacancyClosed" />
      <bpmn:sequenceFlow id="VTX1" sourceRef="MarkVacancyClosed" targetRef="CancelActiveInterviewsForVacancy" />
      <bpmn:sequenceFlow id="VTX2" sourceRef="CancelActiveInterviewsForVacancy" targetRef="ReleaseScheduleSlotsForClosedVacancy" />
      <bpmn:sequenceFlow id="VTX3" sourceRef="ReleaseScheduleSlotsForClosedVacancy" targetRef="CloseActiveApplicationsForVacancy" />
      <bpmn:sequenceFlow id="VTX4" sourceRef="CloseActiveApplicationsForVacancy" targetRef="RecordVacancyClosedHistory" />
      <bpmn:sequenceFlow id="Transaction_CloseVacancy_SF_End" sourceRef="RecordVacancyClosedHistory" targetRef="Transaction_CloseVacancy_End" />
    </bpmn:transaction>
    <bpmn:boundaryEvent id="CloseVacancyFormError" attachedToRef="ValidateCloseVacancyForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="CreateVacancyFormError" attachedToRef="ValidateCreateVacancyForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="CreateVacancyPersistError" attachedToRef="CreateVacancyFromForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="CloseActiveApplicationsErrorBoundary" attachedToRef="Transaction_CloseVacancy">
      <bpmn:errorEventDefinition errorRef="Error_VacancyTxFailed" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="VF1" sourceRef="VacancyStart" targetRef="VacancyCreationModeGateway" />
    <bpmn:sequenceFlow id="VF2a" name="запуск из списка задач Camunda" sourceRef="VacancyCreationModeGateway" targetRef="CreateVacancyTask" />
    <bpmn:sequenceFlow id="VF2b" sourceRef="VacancyCreationModeGateway" targetRef="ValidateCreateVacancyForm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${execution.hasVariable('restAutoSubmit') &amp;&amp; restAutoSubmit == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="VF2" sourceRef="CreateVacancyTask" targetRef="ValidateCreateVacancyForm" />
    <bpmn:sequenceFlow id="VF2d" sourceRef="ValidateCreateVacancyForm" targetRef="CreateVacancyFromForm" />
    <bpmn:sequenceFlow id="VF2f" sourceRef="CreateVacancyFromForm" targetRef="VacancyCreatedResultTask" />
    <bpmn:sequenceFlow id="VF2g" sourceRef="VacancyCreatedResultTask" targetRef="ManageVacancyTask" />
    <bpmn:sequenceFlow id="VF3" sourceRef="ManageVacancyTask" targetRef="ValidateCloseVacancyForm" />
    <bpmn:sequenceFlow id="VF4a" name="форма прошла проверку" sourceRef="ValidateCloseVacancyForm" targetRef="PrepareCloseVacancyTransition" />
    <bpmn:sequenceFlow id="VF4b" name="данные статуса подготовлены" sourceRef="PrepareCloseVacancyTransition" targetRef="EvaluateCloseVacancyTransition" />
    <bpmn:sequenceFlow id="VF4c" name="таблица решений вернула разрешение и следующий статус" sourceRef="EvaluateCloseVacancyTransition" targetRef="CloseVacancyTransitionGateway" />
    <bpmn:sequenceFlow id="VF4" name="таблица решений разрешила переход" sourceRef="CloseVacancyTransitionGateway" targetRef="Transaction_CloseVacancy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="VF4_DENIED" name="таблица решений запретила переход" sourceRef="CloseVacancyTransitionGateway" targetRef="CloseVacancyTransitionDenied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed != true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="VF2c" sourceRef="CreateVacancyFormError" targetRef="CreateVacancyTask" />
    <bpmn:sequenceFlow id="VF2e" sourceRef="CreateVacancyPersistError" targetRef="CreateVacancyTask" />
    <bpmn:sequenceFlow id="VF3e" sourceRef="CloseVacancyFormError" targetRef="ManageVacancyTask" />
    <bpmn:sequenceFlow id="VF7" name="ошибка транзакции: запустить компенсацию" sourceRef="CloseActiveApplicationsErrorBoundary" targetRef="ThrowCompensationVacancyRollback" />
    <bpmn:sequenceFlow id="VF7b" name="после компенсации восстановить данные" sourceRef="ThrowCompensationVacancyRollback" targetRef="RollbackVacancyTransaction" />
    <bpmn:sequenceFlow id="VF8" sourceRef="RollbackVacancyTransaction" targetRef="VacancyRollbackEnd" />
    <bpmn:sequenceFlow id="VF6b" sourceRef="CorrelateVacancyClosedApplications" targetRef="VacancyClosedResultTask" />
    <bpmn:sequenceFlow id="VF6c" sourceRef="VacancyClosedResultTask" targetRef="VacancyClosedEnd" />
    <bpmn:sequenceFlow id="VF6" sourceRef="NotifyVacancyClosedCandidates" targetRef="CorrelateVacancyClosedApplications" />
    <bpmn:sequenceFlow id="VF5" sourceRef="Transaction_CloseVacancy" targetRef="NotifyVacancyClosedCandidates" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_hhVacancyProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_hhVacancyProcess" bpmnElement="Collaboration_hhVacancyProcess">
      <bpmndi:BPMNShape id="BPMNShape_Participant_hhVacancyProcess" bpmnElement="Participant_hhVacancyProcess" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="3560" height="640" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_Recruiter_V" bpmnElement="Lane_Recruiter_V" isHorizontal="true">
        <dc:Bounds x="260" y="100" width="3440" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_System_V" bpmnElement="Lane_System_V" isHorizontal="true">
        <dc:Bounds x="260" y="270" width="3440" height="430" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyStart" bpmnElement="VacancyStart">
        <dc:Bounds x="320" y="420" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="294" y="456" width="90" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyCreationModeGateway" bpmnElement="VacancyCreationModeGateway" isMarkerVisible="true">
        <dc:Bounds x="485" y="450" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="470" y="500" width="81" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateCreateVacancyForm" bpmnElement="ValidateCreateVacancyForm">
        <dc:Bounds x="750" y="435" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyCreatedResultTask" bpmnElement="VacancyCreatedResultTask">
        <dc:Bounds x="1250" y="170" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateCloseVacancyForm" bpmnElement="ValidateCloseVacancyForm">
        <dc:Bounds x="1465" y="415" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EvaluateCloseVacancyTransition" bpmnElement="EvaluateCloseVacancyTransition">
        <dc:Bounds x="1911" y="580" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CloseVacancyTransitionGateway" bpmnElement="CloseVacancyTransitionGateway" isMarkerVisible="true">
        <dc:Bounds x="2265" y="595" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2262" y="645" width="57" height="66" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CloseVacancyTransitionDenied" bpmnElement="CloseVacancyTransitionDenied">
        <dc:Bounds x="2442" y="602" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2434" y="638" width="53" height="66" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CreateVacancyTask" bpmnElement="CreateVacancyTask">
        <dc:Bounds x="745" y="150" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CreateVacancyFromForm" bpmnElement="CreateVacancyFromForm">
        <dc:Bounds x="985" y="450" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ManageVacancyTask" bpmnElement="ManageVacancyTask">
        <dc:Bounds x="1465" y="139" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_PrepareCloseVacancyTransition" bpmnElement="PrepareCloseVacancyTransition">
        <dc:Bounds x="1480" y="580" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ThrowCompensationVacancyRollback" bpmnElement="ThrowCompensationVacancyRollback">
        <dc:Bounds x="2582" y="602" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2558" y="638" width="84" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RollbackVacancyTransaction" bpmnElement="RollbackVacancyTransaction">
        <dc:Bounds x="2995" y="580" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyRollbackEnd" bpmnElement="VacancyRollbackEnd">
        <dc:Bounds x="3232" y="602" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3208" y="638" width="85" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyClosedResultTask" bpmnElement="VacancyClosedResultTask">
        <dc:Bounds x="2890" y="139" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_VacancyClosedEnd" bpmnElement="VacancyClosedEnd">
        <dc:Bounds x="3412" y="365" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3400" y="401" width="62" height="66" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CorrelateVacancyClosedApplications" bpmnElement="CorrelateVacancyClosedApplications">
        <dc:Bounds x="3015" y="360" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_NotifyVacancyClosedCandidates" bpmnElement="NotifyVacancyClosedCandidates">
        <dc:Bounds x="2755" y="360" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_CloseVacancy" bpmnElement="Transaction_CloseVacancy" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="1750" y="365" width="910" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_CloseVacancy_Start" bpmnElement="Transaction_CloseVacancy_Start">
        <dc:Bounds x="1780" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1755" y="468" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_MarkVacancyClosed" bpmnElement="MarkVacancyClosed">
        <dc:Bounds x="1846" y="420" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CancelActiveInterviewsForVacancy" bpmnElement="CancelActiveInterviewsForVacancy">
        <dc:Bounds x="2001" y="420" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ReleaseScheduleSlotsForClosedVacancy" bpmnElement="ReleaseScheduleSlotsForClosedVacancy">
        <dc:Bounds x="2156" y="420" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_CloseActiveApplicationsForVacancy" bpmnElement="CloseActiveApplicationsForVacancy">
        <dc:Bounds x="2311" y="420" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RecordVacancyClosedHistory" bpmnElement="RecordVacancyClosedHistory">
        <dc:Bounds x="2464" y="420" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Transaction_CloseVacancy_End" bpmnElement="Transaction_CloseVacancy_End">
        <dc:Bounds x="2602" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2577" y="468" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Transaction_CloseVacancy_SF_Start" bpmnElement="Transaction_CloseVacancy_SF_Start">
        <di:waypoint x="1816" y="450" />
        <di:waypoint x="1846" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VTX1" bpmnElement="VTX1">
        <di:waypoint x="1976" y="450" />
        <di:waypoint x="2001" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VTX2" bpmnElement="VTX2">
        <di:waypoint x="2131" y="450" />
        <di:waypoint x="2156" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VTX3" bpmnElement="VTX3">
        <di:waypoint x="2286" y="450" />
        <di:waypoint x="2311" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_VTX4" bpmnElement="VTX4">
        <di:waypoint x="2441" y="450" />
        <di:waypoint x="2464" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Transaction_CloseVacancy_SF_End" bpmnElement="Transaction_CloseVacancy_SF_End">
        <di:waypoint x="2529" y="420" />
        <di:waypoint x="2529" y="400" />
        <di:waypoint x="2620" y="400" />
        <di:waypoint x="2620" y="432" />
