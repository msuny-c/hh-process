<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_CancelInterview" targetNamespace="http://itmo.ru/hhprocess/camunda">
  <bpmn:process id="cancel-interview-process" name="Cancel Interview Process" isExecutable="true">
    <bpmn:startEvent id="Start_CancelInterview" name="Recruiter cancels interview">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="interviewId" label="Interview ID" type="string"><camunda:validation><camunda:constraint name="required" /></camunda:validation></camunda:formField>
          <camunda:formField id="recruiterUserId" label="Recruiter email" type="string"><camunda:validation><camunda:constraint name="required" /></camunda:validation></camunda:formField>
          <camunda:formField id="interviewCancelReason" label="Cancel reason" type="string"><camunda:validation><camunda:constraint name="required" /></camunda:validation></camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_Cancel</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CancelInterview" name="Cancel interview, release slot and notify candidate" camunda:type="external" camunda:topic="cancel-interview">
      <bpmn:incoming>Flow_Start_Cancel</bpmn:incoming>
      <bpmn:outgoing>Flow_Cancel_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_InterviewCancelled" name="Interview cancelled"><bpmn:incoming>Flow_Cancel_End</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Cancel" sourceRef="Start_CancelInterview" targetRef="Task_CancelInterview" />
    <bpmn:sequenceFlow id="Flow_Cancel_End" sourceRef="Task_CancelInterview" targetRef="End_InterviewCancelled" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_CancelInterview"><bpmndi:BPMNPlane id="BPMNPlane_CancelInterview" bpmnElement="cancel-interview-process">
    <bpmndi:BPMNShape id="Start_CancelInterview_di" bpmnElement="Start_CancelInterview"><dc:Bounds x="160" y="120" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Task_CancelInterview_di" bpmnElement="Task_CancelInterview"><dc:Bounds x="280" y="98" width="220" height="80" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="End_InterviewCancelled_di" bpmnElement="End_InterviewCancelled"><dc:Bounds x="580" y="120" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="Flow_Start_Cancel_di" bpmnElement="Flow_Start_Cancel"><di:waypoint x="196" y="138" /><di:waypoint x="280" y="138" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Flow_Cancel_End_di" bpmnElement="Flow_Cancel_End"><di:waypoint x="500" y="138" /><di:waypoint x="580" y="138" /></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>
