<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_hh_ui_admin_timeout_review" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED" />
  <bpmn:collaboration id="Collaboration_hhUiAdminTimeoutReview" name="Pool: HH UI admin timeout review">
    <bpmn:participant id="Participant_hhUiAdminTimeoutReview" name="POOL: HH UI admin timeout review" processRef="hhUiAdminTimeoutReview" />
  </bpmn:collaboration>
  <bpmn:process id="hhUiAdminTimeoutReview" name="HH UI admin timeout review" isExecutable="true" camunda:candidateStarterGroups="ADMIN" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_hhUiAdminTimeoutReview">
      <bpmn:lane id="Lane_hhUiAdminTimeoutReview_RoleSystem" name="ADMIN / SYSTEM">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ConfirmTimeoutReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RunTimeoutReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TimeoutReviewValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>DisplayTimeoutReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" camunda:initiator="starterUserId" name="Запущен экран проверки таймаутов" />
    <bpmn:userTask id="ConfirmTimeoutReview" name="Запустить проверку таймаутов" camunda:formRef="admin-timeout-run-form" camunda:formRefBinding="latest" camunda:candidateGroups="ADMIN" />
    <bpmn:serviceTask id="RunTimeoutReview" name="Закрыть просроченные приглашения" camunda:type="external" camunda:topic="ui-query" />
    <bpmn:boundaryEvent id="TimeoutReviewValidationError" attachedToRef="RunTimeoutReview">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="DisplayTimeoutReview" name="Результат проверки таймаутов" camunda:formRef="ui-json-display-form" camunda:formRefBinding="latest" camunda:candidateGroups="ADMIN" />
    <bpmn:endEvent id="End" name="Проверка таймаутов показана" />
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="ConfirmTimeoutReview" />
    <bpmn:sequenceFlow id="F2" sourceRef="ConfirmTimeoutReview" targetRef="RunTimeoutReview" />
    <bpmn:sequenceFlow id="F2e" name="ошибка формы -> повторить ввод" sourceRef="TimeoutReviewValidationError" targetRef="ConfirmTimeoutReview" />
    <bpmn:sequenceFlow id="F3" sourceRef="RunTimeoutReview" targetRef="DisplayTimeoutReview" />
    <bpmn:sequenceFlow id="F4" sourceRef="DisplayTimeoutReview" targetRef="End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_hhUiAdminTimeoutReview">
    <bpmndi:BPMNPlane id="BPMNPlane_hhUiAdminTimeoutReview" bpmnElement="Collaboration_hhUiAdminTimeoutReview">
      <bpmndi:BPMNShape id="BPMNShape_Participant_hhUiAdminTimeoutReview" bpmnElement="Participant_hhUiAdminTimeoutReview" isHorizontal="true">
        <dc:Bounds x="52" y="20" width="1454" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_hhUiAdminTimeoutReview_RoleSystem" bpmnElement="Lane_hhUiAdminTimeoutReview_RoleSystem" isHorizontal="true">
        <dc:Bounds x="152" y="40" width="1334" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End" bpmnElement="End">
        <dc:Bounds x="1050" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ConfirmTimeoutReview" bpmnElement="ConfirmTimeoutReview">
        <dc:Bounds x="330" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RunTimeoutReview" bpmnElement="RunTimeoutReview">
        <dc:Bounds x="570" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_TimeoutReviewValidationError" bpmnElement="TimeoutReviewValidationError">
        <dc:Bounds x="722" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_DisplayTimeoutReview" bpmnElement="DisplayTimeoutReview">
        <dc:Bounds x="810" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Start" bpmnElement="Start">
        <dc:Bounds x="192" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_F1" bpmnElement="F1">
        <di:waypoint x="228" y="120.0" /><di:waypoint x="330" y="120.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F2" bpmnElement="F2">
        <di:waypoint x="500" y="120.0" /><di:waypoint x="570" y="120.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F2e" bpmnElement="F2e">
        <di:waypoint x="722" y="160.0" /><di:waypoint x="500" y="160.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F3" bpmnElement="F3">
        <di:waypoint x="740" y="120.0" /><di:waypoint x="810" y="120.0" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_F4" bpmnElement="F4">
        <di:waypoint x="980" y="120.0" /><di:waypoint x="1050" y="120.0" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
