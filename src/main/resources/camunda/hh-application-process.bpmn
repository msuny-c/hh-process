<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_HH_Application" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_ApplicationTransactionFailed" name="Ошибка транзакции отклика" errorCode="APPLICATION_TX_FAILED" />
  <bpmn:process id="hhApplicationProcess" name="HH.ru: обработка отклика кандидата" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_Application">
      <bpmn:lane id="Lane_Scheduler" name="Шедулер">
        <bpmn:flowNodeRef>InvitationTimeoutBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseByTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Timeout</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Recruiter" name="HR / рекрутер">
        <bpmn:flowNodeRef>RecruiterDecisionTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>WriteInvitationTask</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="Система HH">
        <bpmn:flowNodeRef>AutoScreenApplication</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ScreeningPassed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyScreeningFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RecruiterDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyRecruiter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistInvitationErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistCandidateResponseErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RollbackApplicationTransaction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ApplicationRollback</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Candidate" name="Соискатель">
        <bpmn:flowNodeRef>Start_ApplicationSubmitted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateInvitationResponseTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ResponseSaved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ScreeningFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_VacancyClosed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_ApplicationSubmitted" name="Отклик отправлен">
      <bpmn:outgoing>Flow_Start_AutoScreen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="AutoScreenApplication" name="Выполнить автоскрининг резюме" camunda:type="external" camunda:topic="application-auto-screening">
      <bpmn:incoming>Flow_Start_AutoScreen</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoScreen_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ScreeningPassed" name="Автоскрининг пройден?">
      <bpmn:incoming>Flow_AutoScreen_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Screening_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Screening_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="NotifyScreeningFailed" name="Зафиксировать отказ и уведомить кандидата" camunda:type="external" camunda:topic="notification-send">
      <bpmn:incoming>Flow_Screening_No</bpmn:incoming>
      <bpmn:outgoing>Flow_ScreeningFailed_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_ScreeningFailed" name="Получен отказ">
      <bpmn:incoming>Flow_ScreeningFailed_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="NotifyRecruiter" name="Отправить уведомление рекрутеру об отклике" camunda:type="external" camunda:topic="notification-send">
      <bpmn:incoming>Flow_Screening_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_RecruiterDecision</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="RecruiterDecisionTask" name="Рассмотреть отклик и принять решение" camunda:formRef="recruiter-decision-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>Flow_Notify_RecruiterDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_RecruiterDecision" name="Решение рекрутера">
      <bpmn:incoming>Flow_Decision_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Invite</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_VacancyClosed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="PersistRejection" name="Транзакция: зафиксировать отказ и уведомить кандидата" camunda:type="external" camunda:topic="notification-send">
      <bpmn:incoming>Flow_Decision_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Rejection_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Rejected" name="Отклик отклонен">
      <bpmn:incoming>Flow_Rejection_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="WriteInvitationTask" name="Написать приглашение" camunda:formRef="invitation-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER">
      <bpmn:incoming>Flow_Decision_Invite</bpmn:incoming>
      <bpmn:outgoing>Flow_Invitation_Persist</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="PersistInvitation" name="Транзакция: сохранить приглашение, интервью, слот и уведомление" camunda:type="external" camunda:topic="notification-send">
      <bpmn:incoming>Flow_Invitation_Persist</bpmn:incoming>
      <bpmn:outgoing>Flow_Persist_ResponseTask</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="PersistInvitationErrorBoundary" name="Ошибка транзакции приглашения" attachedToRef="PersistInvitation">
      <bpmn:outgoing>Flow_PersistInvitation_Error_Rollback</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDefinition_PersistInvitation" errorRef="Error_ApplicationTransactionFailed" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="CandidateInvitationResponseTask" name="Ответить на приглашение" camunda:formRef="invitation-response-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE">
      <bpmn:incoming>Flow_Persist_ResponseTask</bpmn:incoming>
      <bpmn:outgoing>Flow_Response_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="InvitationTimeoutBoundary" name="Срок ответа истек" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:outgoing>Flow_Timeout_Close</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDefinition_InvitationTimeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT48H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_Response" name="Ответ кандидата">
      <bpmn:incoming>Flow_Response_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Response_Normal</bpmn:outgoing>
      <bpmn:outgoing>Flow_Response_VacancyClosed</bpmn:outgoing>
      <bpmn:outgoing>Flow_Response_Timeout</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="PersistCandidateResponse" name="Транзакция: сохранить ответ и уведомить рекрутера" camunda:type="external" camunda:topic="notification-send">
      <bpmn:incoming>Flow_Response_Normal</bpmn:incoming>
      <bpmn:outgoing>Flow_Response_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="PersistCandidateResponseErrorBoundary" name="Ошибка транзакции ответа" attachedToRef="PersistCandidateResponse">
      <bpmn:outgoing>Flow_Response_Error_Rollback</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDefinition_PersistCandidateResponse" errorRef="Error_ApplicationTransactionFailed" />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="RollbackApplicationTransaction" name="Откатить транзакцию отклика" camunda:type="external" camunda:topic="transaction-rollback">
      <bpmn:incoming>Flow_PersistInvitation_Error_Rollback</bpmn:incoming>
      <bpmn:incoming>Flow_Response_Error_Rollback</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplicationRollback_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_ApplicationRollback" name="Отклик возвращен после ошибки">
      <bpmn:incoming>Flow_ApplicationRollback_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="CloseByTimeout" name="Закрыть отклик по таймауту" camunda:type="external" camunda:topic="timeout-close-expired">
      <bpmn:incoming>Flow_Timeout_Close</bpmn:incoming>
      <bpmn:outgoing>Flow_Timeout_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_ResponseSaved" name="Получен ответ на приглашение">
      <bpmn:incoming>Flow_Response_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Timeout" name="Отклик закрыт по таймауту">
      <bpmn:incoming>Flow_Timeout_End</bpmn:incoming>
      <bpmn:incoming>Flow_Response_Timeout</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_VacancyClosed" name="Отклик закрыт из-за закрытия вакансии">
      <bpmn:incoming>Flow_Decision_VacancyClosed</bpmn:incoming>
      <bpmn:incoming>Flow_Response_VacancyClosed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_AutoScreen" sourceRef="Start_ApplicationSubmitted" targetRef="AutoScreenApplication" />
    <bpmn:sequenceFlow id="Flow_AutoScreen_Gateway" sourceRef="AutoScreenApplication" targetRef="Gateway_ScreeningPassed" />
    <bpmn:sequenceFlow id="Flow_Screening_No" sourceRef="Gateway_ScreeningPassed" targetRef="NotifyScreeningFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${screeningPassed == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Screening_Yes" sourceRef="Gateway_ScreeningPassed" targetRef="NotifyRecruiter">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${screeningPassed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ScreeningFailed_End" sourceRef="NotifyScreeningFailed" targetRef="End_ScreeningFailed" />
    <bpmn:sequenceFlow id="Flow_Notify_RecruiterDecision" sourceRef="NotifyRecruiter" targetRef="RecruiterDecisionTask" />
    <bpmn:sequenceFlow id="Flow_Decision_Gateway" sourceRef="RecruiterDecisionTask" targetRef="Gateway_RecruiterDecision" />
    <bpmn:sequenceFlow id="Flow_Decision_Reject" sourceRef="Gateway_RecruiterDecision" targetRef="PersistRejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'REJECT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Invite" sourceRef="Gateway_RecruiterDecision" targetRef="WriteInvitationTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'INVITE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_VacancyClosed" sourceRef="Gateway_RecruiterDecision" targetRef="End_VacancyClosed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'VACANCY_CLOSED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Rejection_End" sourceRef="PersistRejection" targetRef="End_Rejected" />
    <bpmn:sequenceFlow id="Flow_Invitation_Persist" sourceRef="WriteInvitationTask" targetRef="PersistInvitation" />
    <bpmn:sequenceFlow id="Flow_Persist_ResponseTask" sourceRef="PersistInvitation" targetRef="CandidateInvitationResponseTask" />
    <bpmn:sequenceFlow id="Flow_Response_Gateway" sourceRef="CandidateInvitationResponseTask" targetRef="Gateway_Response" />
    <bpmn:sequenceFlow id="Flow_Response_Normal" sourceRef="Gateway_Response" targetRef="PersistCandidateResponse">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'ACCEPT' || responseType == 'DECLINE' || responseType == 'OTHER'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Response_VacancyClosed" sourceRef="Gateway_Response" targetRef="End_VacancyClosed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'VACANCY_CLOSED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Response_Timeout" sourceRef="Gateway_Response" targetRef="End_Timeout">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'TIMEOUT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Response_End" sourceRef="PersistCandidateResponse" targetRef="End_ResponseSaved" />
    <bpmn:sequenceFlow id="Flow_PersistInvitation_Error_Rollback" sourceRef="PersistInvitationErrorBoundary" targetRef="RollbackApplicationTransaction" />
    <bpmn:sequenceFlow id="Flow_Response_Error_Rollback" sourceRef="PersistCandidateResponseErrorBoundary" targetRef="RollbackApplicationTransaction" />
    <bpmn:sequenceFlow id="Flow_ApplicationRollback_End" sourceRef="RollbackApplicationTransaction" targetRef="End_ApplicationRollback" />
    <bpmn:sequenceFlow id="Flow_Timeout_Close" sourceRef="InvitationTimeoutBoundary" targetRef="CloseByTimeout" />
    <bpmn:sequenceFlow id="Flow_Timeout_End" sourceRef="CloseByTimeout" targetRef="End_Timeout" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_HH_Application">
    <bpmndi:BPMNPlane id="BPMNPlane_HH_Application" bpmnElement="hhApplicationProcess">
      <bpmndi:BPMNShape id="Lane_Scheduler_di" bpmnElement="Lane_Scheduler" isHorizontal="true">
        <dc:Bounds x="240" y="480" width="2240" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Recruiter_di" bpmnElement="Lane_Recruiter" isHorizontal="true">
        <dc:Bounds x="240" y="350" width="2240" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_di" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="240" y="180" width="2240" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Candidate_di" bpmnElement="Lane_Candidate" isHorizontal="true">
        <dc:Bounds x="240" y="40" width="2240" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_ApplicationSubmitted_di" bpmnElement="Start_ApplicationSubmitted">
        <dc:Bounds x="280" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AutoScreenApplication_di" bpmnElement="AutoScreenApplication">
        <dc:Bounds x="370" y="158" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ScreeningPassed_di" bpmnElement="Gateway_ScreeningPassed" isMarkerVisible="true">
        <dc:Bounds x="580" y="173" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="NotifyScreeningFailed_di" bpmnElement="NotifyScreeningFailed">
        <dc:Bounds x="690" y="70" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ScreeningFailed_di" bpmnElement="End_ScreeningFailed">
        <dc:Bounds x="940" y="92" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="NotifyRecruiter_di" bpmnElement="NotifyRecruiter">
        <dc:Bounds x="690" y="240" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RecruiterDecisionTask_di" bpmnElement="RecruiterDecisionTask">
        <dc:Bounds x="940" y="240" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RecruiterDecision_di" bpmnElement="Gateway_RecruiterDecision" isMarkerVisible="true">
        <dc:Bounds x="1175" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PersistRejection_di" bpmnElement="PersistRejection">
        <dc:Bounds x="1290" y="120" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Rejected_di" bpmnElement="End_Rejected">
        <dc:Bounds x="1530" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="WriteInvitationTask_di" bpmnElement="WriteInvitationTask">
        <dc:Bounds x="1290" y="260" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PersistInvitation_di" bpmnElement="PersistInvitation">
        <dc:Bounds x="1530" y="260" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CandidateInvitationResponseTask_di" bpmnElement="CandidateInvitationResponseTask">
        <dc:Bounds x="1780" y="260" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Response_di" bpmnElement="Gateway_Response" isMarkerVisible="true">
        <dc:Bounds x="2020" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RollbackApplicationTransaction_di" bpmnElement="RollbackApplicationTransaction">
        <dc:Bounds x="1790" y="350" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ApplicationRollback_di" bpmnElement="End_ApplicationRollback">
        <dc:Bounds x="2070" y="372" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CloseByTimeout_di" bpmnElement="CloseByTimeout">
        <dc:Bounds x="1950" y="410" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ResponseSaved_di" bpmnElement="End_ResponseSaved">
        <dc:Bounds x="2380" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Timeout_di" bpmnElement="End_Timeout">
        <dc:Bounds x="2200" y="432" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_VacancyClosed_di" bpmnElement="End_VacancyClosed">
        <dc:Bounds x="1530" y="420" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PersistCandidateResponse_di" bpmnElement="PersistCandidateResponse">
        <dc:Bounds x="2130" y="220" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="InvitationTimeoutBoundary_di" bpmnElement="InvitationTimeoutBoundary">
        <dc:Bounds x="1852" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PersistInvitationErrorBoundary_di" bpmnElement="PersistInvitationErrorBoundary">
        <dc:Bounds x="1610" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PersistCandidateResponseErrorBoundary_di" bpmnElement="PersistCandidateResponseErrorBoundary">
        <dc:Bounds x="2210" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_AutoScreen_di" bpmnElement="Flow_Start_AutoScreen">
        <di:waypoint x="316" y="198" />
        <di:waypoint x="370" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AutoScreen_Gateway_di" bpmnElement="Flow_AutoScreen_Gateway">
        <di:waypoint x="520" y="198" />
        <di:waypoint x="580" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Screening_No_di" bpmnElement="Flow_Screening_No">
        <di:waypoint x="605" y="173" />
        <di:waypoint x="605" y="110" />
        <di:waypoint x="690" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Screening_Yes_di" bpmnElement="Flow_Screening_Yes">
        <di:waypoint x="605" y="223" />
        <di:waypoint x="605" y="280" />
        <di:waypoint x="690" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ScreeningFailed_End_di" bpmnElement="Flow_ScreeningFailed_End">
        <di:waypoint x="870" y="110" />
        <di:waypoint x="940" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Notify_RecruiterDecision_di" bpmnElement="Flow_Notify_RecruiterDecision">
        <di:waypoint x="870" y="280" />
        <di:waypoint x="940" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Decision_Gateway_di" bpmnElement="Flow_Decision_Gateway">
        <di:waypoint x="1120" y="280" />
        <di:waypoint x="1175" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Decision_Reject_di" bpmnElement="Flow_Decision_Reject">
        <di:waypoint x="1200" y="255" />
        <di:waypoint x="1200" y="160" />
        <di:waypoint x="1290" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Decision_Invite_di" bpmnElement="Flow_Decision_Invite">
        <di:waypoint x="1225" y="280" />
        <di:waypoint x="1290" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Decision_VacancyClosed_di" bpmnElement="Flow_Decision_VacancyClosed">
        <di:waypoint x="1200" y="305" />
        <di:waypoint x="1200" y="438" />
        <di:waypoint x="1530" y="438" />
      </bpmndi:BPMNEdge>
