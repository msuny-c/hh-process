<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_hh_v3" targetNamespace="http://itmo.ru/hhprocess/camunda">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED"/>
  <bpmn:error id="Error_ApplicationTxFailed" name="APPLICATION_TX_FAILED" errorCode="APPLICATION_TX_FAILED"/>
  <bpmn:message id="Message_VacancyClosed" name="MSG_VACANCY_CLOSED"/>
  <bpmn:process id="hhApplicationProcess" name="HH application process with roles" isExecutable="true" camunda:candidateStarterGroups="CANDIDATE,ADMIN" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_Application">
      <bpmn:lane id="Lane_Candidate" name="CANDIDATE">
        <bpmn:flowNodeRef>ApplyToVacancyTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApplyFormValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateInvitationResponseTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ScreeningResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RejectionResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TimeoutResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedApplicationResultTask</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Recruiter" name="RECRUITER">
        <bpmn:flowNodeRef>RecruiterDecisionTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>WriteInvitationTask</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="SYSTEM">
        <bpmn:flowNodeRef>ApplicationStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateApplyToVacancyForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CreateApplicationFromForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AutoScreenApplication</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ScreeningGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyScreeningFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ScreeningFailedEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyRecruiter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateRecruiterDecisionForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_Rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RejectionTxError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RejectedEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateInvitationForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InvitationFormValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_Invitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistInvitationErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InvitationTimeoutBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateCandidateResponseForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistCandidateResponseErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ResponseEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseByTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TimeoutEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RollbackApplicationTransaction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApplicationRollbackEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedAtRecruiterDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedAtInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedAtCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>HandleVacancyClosedMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ClosedByVacancyEnd</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="ApplicationStart" name="Отклик создан" camunda:initiator="starterUserId"/>
    <bpmn:userTask id="ApplyToVacancyTask" name="Заполнить форму отклика" camunda:formRef="apply-to-vacancy-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:serviceTask id="ValidateApplyToVacancyForm" name="Проверить данные формы отклика" camunda:type="external" camunda:topic="form-validation"/>
    <bpmn:boundaryEvent id="ApplyFormValidationError" attachedToRef="ValidateApplyToVacancyForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="CreateApplicationFromForm" name="Создать отклик в БД" camunda:type="external" camunda:topic="application-persistence"/>
    <bpmn:serviceTask id="AutoScreenApplication" name="Выполнить автоскрининг отклика" camunda:type="external" camunda:topic="application-auto-screening"/>
    <bpmn:exclusiveGateway id="ScreeningGateway" name="Скрининг пройден?"/>
    <bpmn:serviceTask id="NotifyScreeningFailed" name="Уведомить кандидата об отказе по скринингу" camunda:type="external" camunda:topic="application-notification"/>
    <bpmn:endEvent id="ScreeningFailedEnd" name="Отклик закрыт после скрининга"/>
    <bpmn:serviceTask id="NotifyRecruiter" name="Уведомить рекрутера о новом отклике" camunda:type="external" camunda:topic="application-notification"/>
    <bpmn:userTask id="RecruiterDecisionTask" name="Рассмотреть отклик рекрутером" camunda:formRef="recruiter-decision-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER"/>
    <bpmn:serviceTask id="ValidateRecruiterDecisionForm" name="Проверить решение рекрутера" camunda:type="external" camunda:topic="form-validation"/>
    <bpmn:boundaryEvent id="RecruiterDecisionFormError" attachedToRef="ValidateRecruiterDecisionForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="RecruiterDecisionGateway" name="Решение рекрутера"/>
    <bpmn:transaction id="Transaction_Rejection" name="TX: отказ рекрутера">
      <bpmn:startEvent id="Transaction_Rejection_Start" name="Начать транзакционный блок"/>
      <bpmn:serviceTask id="ValidateRejectionAllowed" name="Проверить возможность отказа" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="CancelRejectionInterviewIfAny" name="Отменить активное интервью при отказе" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="MarkApplicationRejected" name="Перевести отклик в статус отказа" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="RecordRejectionHistory" name="Записать историю отказа" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:endEvent id="Transaction_Rejection_End" name="Завершить транзакционный блок"/>
      <bpmn:sequenceFlow id="Transaction_Rejection_SF_Start" sourceRef="Transaction_Rejection_Start" targetRef="ValidateRejectionAllowed"/>
      <bpmn:sequenceFlow id="R1" sourceRef="ValidateRejectionAllowed" targetRef="CancelRejectionInterviewIfAny"/>
      <bpmn:sequenceFlow id="R2" sourceRef="CancelRejectionInterviewIfAny" targetRef="MarkApplicationRejected"/>
      <bpmn:sequenceFlow id="R3" sourceRef="MarkApplicationRejected" targetRef="RecordRejectionHistory"/>
      <bpmn:sequenceFlow id="Transaction_Rejection_SF_End" sourceRef="RecordRejectionHistory" targetRef="Transaction_Rejection_End"/>
    </bpmn:transaction>
    <bpmn:boundaryEvent id="RejectionTxError" attachedToRef="Transaction_Rejection">
      <bpmn:errorEventDefinition errorRef="Error_ApplicationTxFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="NotifyRejection" name="Уведомить кандидата об отказе" camunda:type="external" camunda:topic="application-notification"/>
    <bpmn:endEvent id="RejectedEnd" name="Отклик отклонён"/>
    <bpmn:userTask id="WriteInvitationTask" name="Подготовить приглашение на интервью" camunda:formRef="invitation-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER"/>
    <bpmn:serviceTask id="ValidateInvitationForm" name="Проверить данные формы приглашения" camunda:type="external" camunda:topic="form-validation"/>
    <bpmn:boundaryEvent id="InvitationFormValidationError" attachedToRef="ValidateInvitationForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:transaction id="Transaction_Invitation" name="TX: оформление приглашения">
      <bpmn:startEvent id="Transaction_Invitation_Start" name="Начать транзакционный блок"/>
      <bpmn:serviceTask id="PersistInvitationToDb" name="Сохранить текст приглашения" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="CreateInvitationInterview" name="Создать интервью" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="ReserveInvitationSlot" name="Зарезервировать слот рекрутера" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="RecordInvitationHistory" name="Записать историю приглашения" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:endEvent id="Transaction_Invitation_End" name="Завершить транзакционный блок"/>
      <bpmn:sequenceFlow id="Transaction_Invitation_SF_Start" sourceRef="Transaction_Invitation_Start" targetRef="PersistInvitationToDb"/>
      <bpmn:sequenceFlow id="I1" sourceRef="PersistInvitationToDb" targetRef="CreateInvitationInterview"/>
      <bpmn:sequenceFlow id="I2" sourceRef="CreateInvitationInterview" targetRef="ReserveInvitationSlot"/>
      <bpmn:sequenceFlow id="I3" sourceRef="ReserveInvitationSlot" targetRef="RecordInvitationHistory"/>
      <bpmn:sequenceFlow id="Transaction_Invitation_SF_End" sourceRef="RecordInvitationHistory" targetRef="Transaction_Invitation_End"/>
    </bpmn:transaction>
    <bpmn:boundaryEvent id="PersistInvitationErrorBoundary" attachedToRef="Transaction_Invitation">
      <bpmn:errorEventDefinition errorRef="Error_ApplicationTxFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="NotifyInvitation" name="Уведомить кандидата о приглашении" camunda:type="external" camunda:topic="application-notification"/>
    <bpmn:userTask id="CandidateInvitationResponseTask" name="Ответить на приглашение" camunda:formRef="invitation-response-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:boundaryEvent id="InvitationTimeoutBoundary" attachedToRef="CandidateInvitationResponseTask" cancelActivity="true">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">${invitationTimeoutDuration}</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="CandidateResponseGateway" name="Ответ кандидата"/>
    <bpmn:serviceTask id="ValidateCandidateResponseForm" name="Проверить ответ кандидата" camunda:type="external" camunda:topic="form-validation"/>
    <bpmn:boundaryEvent id="CandidateResponseFormError" attachedToRef="ValidateCandidateResponseForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:transaction id="Transaction_Response" name="TX: сохранение ответа кандидата">
      <bpmn:startEvent id="Transaction_Response_Start" name="Начать транзакционный блок"/>
      <bpmn:serviceTask id="CheckInvitationStillActive" name="Проверить активность приглашения" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="SaveCandidateResponse" name="Сохранить ответ кандидата" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="MarkCandidateResponseReceived" name="Обновить статус отклика" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:serviceTask id="RecordCandidateResponseHistory" name="Записать историю ответа кандидата" camunda:type="external" camunda:topic="application-persistence"/>
      <bpmn:endEvent id="Transaction_Response_End" name="Завершить транзакционный блок"/>
      <bpmn:sequenceFlow id="Transaction_Response_SF_Start" sourceRef="Transaction_Response_Start" targetRef="CheckInvitationStillActive"/>
      <bpmn:sequenceFlow id="C1" sourceRef="CheckInvitationStillActive" targetRef="SaveCandidateResponse"/>
      <bpmn:sequenceFlow id="C2" sourceRef="SaveCandidateResponse" targetRef="MarkCandidateResponseReceived"/>
      <bpmn:sequenceFlow id="C3" sourceRef="MarkCandidateResponseReceived" targetRef="RecordCandidateResponseHistory"/>
      <bpmn:sequenceFlow id="Transaction_Response_SF_End" sourceRef="RecordCandidateResponseHistory" targetRef="Transaction_Response_End"/>
    </bpmn:transaction>
    <bpmn:boundaryEvent id="PersistCandidateResponseErrorBoundary" attachedToRef="Transaction_Response">
      <bpmn:errorEventDefinition errorRef="Error_ApplicationTxFailed"/>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="NotifyCandidateResponse" name="Уведомить рекрутера об ответе кандидата" camunda:type="external" camunda:topic="application-notification"/>
    <bpmn:endEvent id="ResponseEnd" name="Ответ кандидата обработан"/>
    <bpmn:serviceTask id="CloseByTimeout" name="Закрыть отклик по таймауту приглашения" camunda:type="external" camunda:topic="timeout-close-expired"/>
    <bpmn:endEvent id="TimeoutEnd" name="Отклик закрыт по таймауту"/>
    <bpmn:serviceTask id="RollbackApplicationTransaction" name="Выполнить recovery отклика" camunda:type="external" camunda:topic="transaction-rollback"/>
    <bpmn:endEvent id="ApplicationRollbackEnd" name="Процесс завершён после recovery"/>
    <bpmn:boundaryEvent id="VacancyClosedAtRecruiterDecision" attachedToRef="RecruiterDecisionTask">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed"/>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="VacancyClosedAtInvitation" attachedToRef="WriteInvitationTask">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed"/>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="VacancyClosedAtCandidateResponse" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed"/>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="HandleVacancyClosedMessage" name="Закрыть отклик по сообщению о закрытии вакансии" camunda:type="external" camunda:topic="application-message"/>
    <bpmn:userTask id="ScreeningResultTask" name="Показать результат скрининга" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:userTask id="RejectionResultTask" name="Показать результат отказа" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:userTask id="CandidateResponseResultTask" name="Показать результат ответа кандидата" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:userTask id="TimeoutResultTask" name="Показать результат таймаута" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:userTask id="VacancyClosedApplicationResultTask" name="Показать результат закрытия вакансии" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:candidateGroups="CANDIDATE"/>
    <bpmn:endEvent id="ClosedByVacancyEnd" name="Отклик закрыт из-за закрытия вакансии"/>
    <bpmn:sequenceFlow id="F1" sourceRef="ApplicationStart" targetRef="ApplyToVacancyTask"/>
    <bpmn:sequenceFlow id="F2" sourceRef="ApplyToVacancyTask" targetRef="ValidateApplyToVacancyForm"/>
    <bpmn:sequenceFlow id="F2e" sourceRef="ApplyFormValidationError" targetRef="ApplyToVacancyTask"/>
    <bpmn:sequenceFlow id="F3" sourceRef="ValidateApplyToVacancyForm" targetRef="CreateApplicationFromForm"/>
    <bpmn:sequenceFlow id="F3_CreateApplication" sourceRef="CreateApplicationFromForm" targetRef="AutoScreenApplication"/>
    <bpmn:sequenceFlow id="F4" sourceRef="AutoScreenApplication" targetRef="ScreeningGateway"/>
    <bpmn:sequenceFlow id="F5" sourceRef="ScreeningGateway" targetRef="NotifyRecruiter">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${screeningPassed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F6" sourceRef="ScreeningGateway" targetRef="NotifyScreeningFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${screeningPassed == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F7" sourceRef="NotifyScreeningFailed" targetRef="ScreeningResultTask"/>
    <bpmn:sequenceFlow id="F8" sourceRef="NotifyRecruiter" targetRef="RecruiterDecisionTask"/>
    <bpmn:sequenceFlow id="F9" sourceRef="RecruiterDecisionTask" targetRef="ValidateRecruiterDecisionForm"/>
    <bpmn:sequenceFlow id="F9e" sourceRef="RecruiterDecisionFormError" targetRef="RecruiterDecisionTask"/>
    <bpmn:sequenceFlow id="F10" sourceRef="ValidateRecruiterDecisionForm" targetRef="RecruiterDecisionGateway"/>
    <bpmn:sequenceFlow id="F11" sourceRef="RecruiterDecisionGateway" targetRef="Transaction_Rejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'REJECT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F12" sourceRef="Transaction_Rejection" targetRef="NotifyRejection"/>
    <bpmn:sequenceFlow id="F13" sourceRef="NotifyRejection" targetRef="RejectionResultTask"/>
    <bpmn:sequenceFlow id="F14" sourceRef="RecruiterDecisionGateway" targetRef="WriteInvitationTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'INVITE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F15" sourceRef="WriteInvitationTask" targetRef="ValidateInvitationForm"/>
    <bpmn:sequenceFlow id="F15e" sourceRef="InvitationFormValidationError" targetRef="WriteInvitationTask"/>
    <bpmn:sequenceFlow id="F16" sourceRef="ValidateInvitationForm" targetRef="Transaction_Invitation"/>
    <bpmn:sequenceFlow id="F17" sourceRef="Transaction_Invitation" targetRef="NotifyInvitation"/>
    <bpmn:sequenceFlow id="F18" sourceRef="NotifyInvitation" targetRef="CandidateInvitationResponseTask"/>
    <bpmn:sequenceFlow id="F19" sourceRef="CandidateInvitationResponseTask" targetRef="CandidateResponseGateway"/>
    <bpmn:sequenceFlow id="F20" sourceRef="CandidateResponseGateway" targetRef="CloseByTimeout">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'TIMEOUT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F21" sourceRef="CandidateResponseGateway" targetRef="Transaction_Rejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'RECRUITER_REJECT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F21b" sourceRef="CandidateResponseGateway" targetRef="RecruiterDecisionTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'RECRUITER_CANCEL' || responseType == 'ADMIN_RESET'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F22" sourceRef="CandidateResponseGateway" targetRef="ValidateCandidateResponseForm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType != 'TIMEOUT' &amp;&amp; responseType != 'RECRUITER_REJECT' &amp;&amp; responseType != 'RECRUITER_CANCEL' &amp;&amp; responseType != 'ADMIN_RESET'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F22e" sourceRef="CandidateResponseFormError" targetRef="CandidateInvitationResponseTask"/>
    <bpmn:sequenceFlow id="F23" sourceRef="ValidateCandidateResponseForm" targetRef="Transaction_Response"/>
    <bpmn:sequenceFlow id="F24" sourceRef="Transaction_Response" targetRef="NotifyCandidateResponse"/>
    <bpmn:sequenceFlow id="F25" sourceRef="NotifyCandidateResponse" targetRef="CandidateResponseResultTask"/>
    <bpmn:sequenceFlow id="F26" sourceRef="InvitationTimeoutBoundary" targetRef="CloseByTimeout"/>
    <bpmn:sequenceFlow id="F27" sourceRef="CloseByTimeout" targetRef="TimeoutResultTask"/>
    <bpmn:sequenceFlow id="F31" sourceRef="RollbackApplicationTransaction" targetRef="ApplicationRollbackEnd"/>
    <bpmn:sequenceFlow id="F32" sourceRef="RecruiterDecisionGateway" targetRef="CloseByTimeout">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'VACANCY_CLOSED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F7b" sourceRef="ScreeningResultTask" targetRef="ScreeningFailedEnd"/>
    <bpmn:sequenceFlow id="F13b" sourceRef="RejectionResultTask" targetRef="RejectedEnd"/>
    <bpmn:sequenceFlow id="F25b" sourceRef="CandidateResponseResultTask" targetRef="ResponseEnd"/>
    <bpmn:sequenceFlow id="F27b" sourceRef="TimeoutResultTask" targetRef="TimeoutEnd"/>
    <bpmn:sequenceFlow id="F_MSG_VacancyClosedAtRecruiterDecision" sourceRef="VacancyClosedAtRecruiterDecision" targetRef="HandleVacancyClosedMessage"/>
    <bpmn:sequenceFlow id="F_MSG_VacancyClosedAtInvitation" sourceRef="VacancyClosedAtInvitation" targetRef="HandleVacancyClosedMessage"/>
    <bpmn:sequenceFlow id="F_MSG_VacancyClosedAtCandidateResponse" sourceRef="VacancyClosedAtCandidateResponse" targetRef="HandleVacancyClosedMessage"/>
    <bpmn:sequenceFlow id="F_MSG_Result" sourceRef="HandleVacancyClosedMessage" targetRef="VacancyClosedApplicationResultTask"/>
    <bpmn:sequenceFlow id="F_MSG_End" sourceRef="VacancyClosedApplicationResultTask" targetRef="ClosedByVacancyEnd"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AutoLayout">
    <bpmndi:BPMNPlane id="BPMNPlane_AutoLayout" bpmnElement="hhApplicationProcess">
      <bpmndi:BPMNShape id="BPMNShape_Lane_Candidate" bpmnElement="Lane_Candidate" isHorizontal="true">
        <dc:Bounds x="20" y="40" width="2600" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_Recruiter" bpmnElement="Lane_Recruiter" isHorizontal="true">
        <dc:Bounds x="20" y="210" width="2600" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Lane_System" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="20" y="380" width="2600" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ApplicationStart" bpmnElement="ApplicationStart">
        <dc:Bounds x="80" y="425" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ApplyToVacancyTask" bpmnElement="ApplyToVacancyTask">
        <dc:Bounds x="80" y="85" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateApplyToVacancyForm" bpmnElement="ValidateApplyToVacancyForm">
