<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_hh_v3" targetNamespace="http://itmo.ru/hhprocess/camunda" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:error id="Error_FormValidationFailed" name="FORM_VALIDATION_FAILED" errorCode="FORM_VALIDATION_FAILED" />
  <bpmn:error id="Error_ApplicationTxFailed" name="APPLICATION_TX_FAILED" errorCode="APPLICATION_TX_FAILED" />
  <bpmn:message id="Message_VacancyClosed" name="MSG_VACANCY_CLOSED" />
  <bpmn:message id="Message_InterviewCancelled" name="MSG_INTERVIEW_CANCELLED" />
  <bpmn:message id="Message_AdminResetDone" name="MSG_ADMIN_RESET_DONE" />
  <bpmn:message id="Message_InvitationExpired" name="MSG_INVITATION_EXPIRED" />
  <bpmn:collaboration id="Collaboration_hhApplicationProcess" name="Пул: процесс отклика кандидата">
    <bpmn:participant id="Participant_hhApplicationProcess" name="Пул: процесс отклика кандидата" processRef="hhApplicationProcess" />
  </bpmn:collaboration>
  <bpmn:process id="hhApplicationProcess" name="Процесс отклика кандидата" isExecutable="true" camunda:candidateStarterGroups="CANDIDATE" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_Application">
      <bpmn:lane id="Lane_Candidate" name="Кандидат">
        <bpmn:flowNodeRef>ApplyToVacancyTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedApplicationResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RejectionResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ScreeningResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TimeoutResultTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateInvitationResponseTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InvitationExpiredAtCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminResetDoneAtCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InterviewCancelledAtCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedAtCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InvitationTimeoutBoundary</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Recruiter" name="Рекрутер">
        <bpmn:flowNodeRef>RecruiterDecisionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>WriteInvitationTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedAtRecruiterDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VacancyClosedAtInvitation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="Система">
        <bpmn:flowNodeRef>ApplicationSubmissionModeGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ScreeningGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateRecruiterDecisionTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateRecruiterDecisionForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PrepareRecruiterDecisionTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RejectedEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PrepareCandidateResponseTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateCandidateResponseTransition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TimeoutEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>HandleVacancyClosedMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ClosedByVacancyEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponsePermissionDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_Rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyScreeningFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateApplyToVacancyForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CreateApplicationFromForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AutoScreenApplication</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateAutoScreeningDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SaveAutoScreenDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyRecruiter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ScreeningFailedEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ResolveRecruiterDecisionPermission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateRecruiterDecisionPermission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionPermissionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateInvitationForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionPermissionDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionTransitionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionTransitionDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ResponseEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyCandidateResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RollbackApplicationTransaction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApplicationRollbackEnd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowCompensationApplicationRollback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseTransitionDenied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseTransitionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CloseByTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_Rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_Invitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Transaction_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecruiterDecisionFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RejectionTxError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Cancel_Transaction_Rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_Rejection_Boundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApplyFormValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistInvitationErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Cancel_Transaction_Invitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_Invitation_Boundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InvitationFormValidationError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_Response_Boundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PersistCandidateResponseErrorBoundary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Cancel_Transaction_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidateCandidateResponseForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponseFormError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CandidateResponsePermissionGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EvaluateCandidateResponsePermission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ResolveCandidateResponsePermission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Compensate_Transaction_Invitation</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="ApplicationStart" name="Создан новый отклик кандидата" camunda:initiator="starterUserId" />
    <bpmn:exclusiveGateway id="ApplicationSubmissionModeGateway" name="Способ подачи отклика" default="F1b" />
    <bpmn:userTask id="ApplyToVacancyTask" name="Кандидат заполняет форму отклика" camunda:formRef="apply-to-vacancy-form" camunda:formRefBinding="latest" camunda:assignee="${starterUserId}" />
    <bpmn:exclusiveGateway id="ScreeningGateway" name="Скрининг пройден?" />
    <bpmn:businessRuleTask id="EvaluateRecruiterDecisionTransition" name="Таблица решений: разрешить новый статус после решения рекрутера" camunda:resultVariable="statusTransition" camunda:decisionRef="hhStatusTransitions" camunda:mapDecisionResult="singleResult" />
    <bpmn:exclusiveGateway id="RecruiterDecisionGateway" name="Какое решение принял рекрутер?" />
    <bpmn:userTask id="VacancyClosedApplicationResultTask" name="Показать результат закрытия вакансии" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:assignee="${candidateCamundaUserId}" />
    <bpmn:userTask id="RejectionResultTask" name="Показать результат отказа" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:assignee="${candidateCamundaUserId}" />
    <bpmn:serviceTask id="ValidateRecruiterDecisionForm" name="Проверить форму решения рекрутера" camunda:type="external" camunda:topic="form-validation" />
    <bpmn:serviceTask id="PrepareRecruiterDecisionTransition" name="Система: подготовить статус и действие рекрутера для таблицы решений" camunda:type="external" camunda:topic="status-transition" />
    <bpmn:endEvent id="RejectedEnd" name="Отклик закрыт отказом рекрутера" />
    <bpmn:serviceTask id="PrepareCandidateResponseTransition" name="Система: подготовить статус и ответ кандидата для таблицы решений" camunda:type="external" camunda:topic="status-transition" />
    <bpmn:businessRuleTask id="EvaluateCandidateResponseTransition" name="Таблица решений: разрешить новый статус после ответа кандидата" camunda:resultVariable="statusTransition" camunda:decisionRef="hhStatusTransitions" camunda:mapDecisionResult="singleResult" />
    <bpmn:endEvent id="TimeoutEnd" name="Отклик закрыт по таймауту приглашения" />
    <bpmn:serviceTask id="HandleVacancyClosedMessage" name="Закрыть отклик после закрытия вакансии" camunda:type="external" camunda:topic="application-message" />
    <bpmn:userTask id="ScreeningResultTask" name="Показать результат скрининга" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:assignee="${candidateCamundaUserId}" />
    <bpmn:endEvent id="ClosedByVacancyEnd" name="Отклик закрыт, потому что вакансия закрыта" />
    <bpmn:endEvent id="CandidateResponsePermissionDenied" name="Кандидату запрещено отвечать на это приглашение" />
    <bpmn:serviceTask id="Compensate_Transaction_Rejection" name="Компенсация: откатить отказ рекрутера" isForCompensation="true" camunda:type="external" camunda:topic="transaction-rollback" />
    <bpmn:callActivity id="NotifyScreeningFailed" name="Подпроцесс: уведомить кандидата об отказе по скринингу" calledElement="hhNotificationProcess">
      <bpmn:extensionElements>
        <camunda:in sourceExpression="${&#39;SCREENING_FAILED&#39;}" target="notificationKind" />
        <camunda:in source="applicationId" target="applicationId" />
        <camunda:out source="notificationDispatched" target="NotifyScreeningFailedDispatched" />
        <camunda:out source="notificationKind" target="lastNotificationKind" />
      </bpmn:extensionElements>
    </bpmn:callActivity>
    <bpmn:callActivity id="NotifyInvitation" name="Подпроцесс: уведомить кандидата о приглашении" calledElement="hhNotificationProcess">
      <bpmn:extensionElements>
        <camunda:in sourceExpression="${&#39;INVITATION&#39;}" target="notificationKind" />
        <camunda:in source="applicationId" target="applicationId" />
        <camunda:in source="invitationMessage" target="invitationMessage" />
        <camunda:out source="notificationDispatched" target="NotifyInvitationDispatched" />
        <camunda:out source="notificationKind" target="lastNotificationKind" />
      </bpmn:extensionElements>
    </bpmn:callActivity>
    <bpmn:serviceTask id="ValidateApplyToVacancyForm" name="Проверить обязательные поля отклика" camunda:type="external" camunda:topic="form-validation" />
    <bpmn:serviceTask id="CreateApplicationFromForm" name="Создать отклик кандидата в БД" camunda:type="external" camunda:topic="application-persistence" />
    <bpmn:serviceTask id="AutoScreenApplication" name="Система: подготовить балл и порог для автоскрининга" camunda:type="external" camunda:topic="application-auto-screening" />
    <bpmn:businessRuleTask id="EvaluateAutoScreeningDecision" name="Таблица решений: проверить навыки и порог автоскрининга" camunda:resultVariable="screeningPassed" camunda:decisionRef="hhAutoScreening" camunda:mapDecisionResult="singleEntry" />
    <bpmn:serviceTask id="SaveAutoScreenDecision" name="Система: сохранить результат автоскрининга" camunda:type="external" camunda:topic="application-auto-screening" />
    <bpmn:callActivity id="NotifyRecruiter" name="Подпроцесс: уведомить рекрутера о новом отклике" calledElement="hhNotificationProcess">
      <bpmn:extensionElements>
        <camunda:in sourceExpression="${&#39;NEW_APPLICATION&#39;}" target="notificationKind" />
        <camunda:in source="applicationId" target="applicationId" />
        <camunda:out source="notificationDispatched" target="NotifyRecruiterDispatched" />
        <camunda:out source="notificationKind" target="lastNotificationKind" />
      </bpmn:extensionElements>
    </bpmn:callActivity>
    <bpmn:endEvent id="ScreeningFailedEnd" name="Отклик закрыт: автоскрининг не пройден" />
    <bpmn:serviceTask id="ResolveRecruiterDecisionPermission" name="Система: собрать данные для проверки права рассматривать отклик" camunda:type="external" camunda:topic="permission-check" />
    <bpmn:businessRuleTask id="EvaluateRecruiterDecisionPermission" name="Таблица решений: проверить право рекрутера на рассмотрение отклика" camunda:resultVariable="permissionAllowed" camunda:decisionRef="hhOperationPermissions" camunda:mapDecisionResult="singleEntry" />
    <bpmn:exclusiveGateway id="RecruiterDecisionPermissionGateway" name="Рекрутер имеет право рассмотреть этот отклик?" />
    <bpmn:userTask id="RecruiterDecisionTask" name="Рекрутер рассматривает отклик" camunda:formRef="recruiter-decision-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER" />
    <bpmn:serviceTask id="ValidateInvitationForm" name="Проверить дату, длительность и текст приглашения" camunda:type="external" camunda:topic="form-validation" />
    <bpmn:endEvent id="RecruiterDecisionPermissionDenied" name="Рекрутеру запрещено рассматривать этот отклик" />
    <bpmn:exclusiveGateway id="RecruiterDecisionTransitionGateway" name="Таблица решений разрешила новый статус после решения рекрутера?" />
    <bpmn:endEvent id="RecruiterDecisionTransitionDenied" name="Таблица решений запретила новый статус отклика" />
    <bpmn:userTask id="WriteInvitationTask" name="Рекрутер заполняет приглашение на интервью" camunda:formRef="invitation-form" camunda:formRefBinding="latest" camunda:candidateGroups="RECRUITER" />
    <bpmn:endEvent id="ResponseEnd" name="Ответ кандидата обработан" />
    <bpmn:userTask id="CandidateResponseResultTask" name="Показать результат ответа кандидата" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:assignee="${candidateCamundaUserId}" />
    <bpmn:callActivity id="NotifyCandidateResponse" name="Подпроцесс: уведомить рекрутера об ответе кандидата" calledElement="hhNotificationProcess">
      <bpmn:extensionElements>
        <camunda:in sourceExpression="${&#39;CANDIDATE_RESPONSE&#39;}" target="notificationKind" />
        <camunda:in source="applicationId" target="applicationId" />
        <camunda:out source="notificationDispatched" target="NotifyCandidateResponseDispatched" />
        <camunda:out source="notificationKind" target="lastNotificationKind" />
      </bpmn:extensionElements>
    </bpmn:callActivity>
    <bpmn:serviceTask id="RollbackApplicationTransaction" name="Восстановить данные отклика после ошибки" camunda:type="external" camunda:topic="transaction-rollback" />
    <bpmn:endEvent id="ApplicationRollbackEnd" name="Процесс завершён после восстановления" />
    <bpmn:intermediateThrowEvent id="ThrowCompensationApplicationRollback" name="Запустить компенсацию отката после ошибки">
      <bpmn:compensateEventDefinition />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="CandidateResponseTransitionDenied" name="Таблица решений запретила статус после ответа кандидата" />
    <bpmn:exclusiveGateway id="CandidateResponseTransitionGateway" name="Таблица решений разрешила новый статус после ответа кандидата?" />
    <bpmn:serviceTask id="Compensate_Transaction_Response" name="Компенсация: откатить сохранённый ответ кандидата" isForCompensation="true" camunda:type="external" camunda:topic="transaction-rollback" />
    <bpmn:userTask id="TimeoutResultTask" name="Показать результат таймаута" camunda:formRef="application-result-form" camunda:formRefBinding="latest" camunda:assignee="${candidateCamundaUserId}" />
    <bpmn:serviceTask id="CloseByTimeout" name="Закрыть отклик: кандидат не ответил вовремя" camunda:type="external" camunda:topic="timeout-close-expired" />
    <bpmn:transaction id="Transaction_Rejection" name="Транзакция: отказ рекрутера">
      <bpmn:startEvent id="Transaction_Rejection_Start" name="Начать транзакцию бизнес-операции" />
      <bpmn:serviceTask id="ValidateRejectionAllowed" name="Проверить, что рекрутер может отказать кандидату" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="CancelRejectionInterviewIfAny" name="Отменить активное интервью перед отказом" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="MarkApplicationRejected" name="Сохранить отказ рекрутера по отклику" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="RecordRejectionHistory" name="Записать историю отказа рекрутера" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:endEvent id="Transaction_Rejection_End" name="Завершить транзакцию бизнес-операции" />
      <bpmn:sequenceFlow id="Transaction_Rejection_SF_Start" sourceRef="Transaction_Rejection_Start" targetRef="ValidateRejectionAllowed" />
      <bpmn:sequenceFlow id="R1" sourceRef="ValidateRejectionAllowed" targetRef="CancelRejectionInterviewIfAny" />
      <bpmn:sequenceFlow id="R2" sourceRef="CancelRejectionInterviewIfAny" targetRef="MarkApplicationRejected" />
      <bpmn:sequenceFlow id="R3" sourceRef="MarkApplicationRejected" targetRef="RecordRejectionHistory" />
      <bpmn:sequenceFlow id="Transaction_Rejection_SF_End" sourceRef="RecordRejectionHistory" targetRef="Transaction_Rejection_End" />
    </bpmn:transaction>
    <bpmn:transaction id="Transaction_Invitation" name="Транзакция: оформление приглашения">
      <bpmn:startEvent id="Transaction_Invitation_Start" name="Начать транзакцию бизнес-операции" />
      <bpmn:serviceTask id="PersistInvitationToDb" name="Сохранить приглашение в БД" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="CreateInvitationInterview" name="Создать интервью по приглашению" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="ReserveInvitationSlot" name="Зарезервировать слот в расписании рекрутера" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="RecordInvitationHistory" name="Записать историю отправки приглашения" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:endEvent id="Transaction_Invitation_End" name="Завершить транзакцию бизнес-операции" />
      <bpmn:sequenceFlow id="Transaction_Invitation_SF_Start" sourceRef="Transaction_Invitation_Start" targetRef="PersistInvitationToDb" />
      <bpmn:sequenceFlow id="I1" sourceRef="PersistInvitationToDb" targetRef="CreateInvitationInterview" />
      <bpmn:sequenceFlow id="I2" sourceRef="CreateInvitationInterview" targetRef="ReserveInvitationSlot" />
      <bpmn:sequenceFlow id="I3" sourceRef="ReserveInvitationSlot" targetRef="RecordInvitationHistory" />
      <bpmn:sequenceFlow id="Transaction_Invitation_SF_End" sourceRef="RecordInvitationHistory" targetRef="Transaction_Invitation_End" />
    </bpmn:transaction>
    <bpmn:transaction id="Transaction_Response" name="Транзакция: сохранение ответа кандидата">
      <bpmn:startEvent id="Transaction_Response_Start" name="Начать транзакцию бизнес-операции" />
      <bpmn:serviceTask id="CheckInvitationStillActive" name="Проверить, что приглашение ещё активно" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="SaveCandidateResponse" name="Сохранить ответ кандидата в БД" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="MarkCandidateResponseReceived" name="Обновить статус отклика после ответа" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:serviceTask id="RecordCandidateResponseHistory" name="Записать историю ответа кандидата" camunda:type="external" camunda:topic="application-persistence" />
      <bpmn:endEvent id="Transaction_Response_End" name="Завершить транзакцию бизнес-операции" />
      <bpmn:sequenceFlow id="Transaction_Response_SF_Start" sourceRef="Transaction_Response_Start" targetRef="CheckInvitationStillActive" />
      <bpmn:sequenceFlow id="C1" sourceRef="CheckInvitationStillActive" targetRef="SaveCandidateResponse" />
      <bpmn:sequenceFlow id="C2" sourceRef="SaveCandidateResponse" targetRef="MarkCandidateResponseReceived" />
      <bpmn:sequenceFlow id="C3" sourceRef="MarkCandidateResponseReceived" targetRef="RecordCandidateResponseHistory" />
      <bpmn:sequenceFlow id="Transaction_Response_SF_End" sourceRef="RecordCandidateResponseHistory" targetRef="Transaction_Response_End" />
    </bpmn:transaction>
    <bpmn:boundaryEvent id="RecruiterDecisionFormError" attachedToRef="ValidateRecruiterDecisionForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="RejectionTxError" attachedToRef="Transaction_Rejection">
      <bpmn:errorEventDefinition errorRef="Error_ApplicationTxFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Cancel_Transaction_Rejection" name="Ошибка транзакции: отказ рекрутера" attachedToRef="Transaction_Rejection">
      <bpmn:cancelEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Compensate_Transaction_Rejection_Boundary" name="Компенсация: откат отказа рекрутера" attachedToRef="Transaction_Rejection">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="ApplyFormValidationError" attachedToRef="ValidateApplyToVacancyForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="VacancyClosedAtRecruiterDecision" attachedToRef="RecruiterDecisionTask">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="PersistInvitationErrorBoundary" attachedToRef="Transaction_Invitation">
      <bpmn:errorEventDefinition errorRef="Error_ApplicationTxFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Cancel_Transaction_Invitation" name="Ошибка транзакции: оформление приглашения" attachedToRef="Transaction_Invitation">
      <bpmn:cancelEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Compensate_Transaction_Invitation_Boundary" name="Компенсация: откат оформления приглашения" attachedToRef="Transaction_Invitation">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="InvitationFormValidationError" attachedToRef="ValidateInvitationForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="VacancyClosedAtInvitation" attachedToRef="WriteInvitationTask">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Compensate_Transaction_Response_Boundary" name="Компенсация: откат ответа кандидата" attachedToRef="Transaction_Response">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="PersistCandidateResponseErrorBoundary" attachedToRef="Transaction_Response">
      <bpmn:errorEventDefinition errorRef="Error_ApplicationTxFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Cancel_Transaction_Response" name="Ошибка транзакции: ответ кандидата" attachedToRef="Transaction_Response">
      <bpmn:cancelEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="ApplicationStart" targetRef="ApplicationSubmissionModeGateway" />
    <bpmn:sequenceFlow id="F1b" sourceRef="ApplicationSubmissionModeGateway" targetRef="ApplyToVacancyTask" />
    <bpmn:sequenceFlow id="F1c" sourceRef="ApplicationSubmissionModeGateway" targetRef="ValidateApplyToVacancyForm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${execution.hasVariable('restAutoSubmit') &amp;&amp; restAutoSubmit == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F2e" sourceRef="ApplyFormValidationError" targetRef="ApplyToVacancyTask" />
    <bpmn:sequenceFlow id="F2" sourceRef="ApplyToVacancyTask" targetRef="ValidateApplyToVacancyForm" />
    <bpmn:sequenceFlow id="F4_SAVE" name="результат сохранён" sourceRef="SaveAutoScreenDecision" targetRef="ScreeningGateway" />
    <bpmn:sequenceFlow id="F5" sourceRef="ScreeningGateway" targetRef="NotifyRecruiter">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${screeningPassed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F6" sourceRef="ScreeningGateway" targetRef="NotifyScreeningFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${screeningPassed == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F10_DMN_PREPARED" name="статус и действие подготовлены" sourceRef="PrepareRecruiterDecisionTransition" targetRef="EvaluateRecruiterDecisionTransition" />
    <bpmn:sequenceFlow id="F10_DMN_EVALUATED" name="таблица решений вернула разрешение и следующий статус" sourceRef="EvaluateRecruiterDecisionTransition" targetRef="RecruiterDecisionTransitionGateway" />
    <bpmn:sequenceFlow id="F10_DMN_ALLOWED" name="таблица решений разрешила переход" sourceRef="RecruiterDecisionTransitionGateway" targetRef="RecruiterDecisionGateway">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F11" sourceRef="RecruiterDecisionGateway" targetRef="Transaction_Rejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'REJECT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F14" sourceRef="RecruiterDecisionGateway" targetRef="WriteInvitationTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'INVITE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F32" sourceRef="RecruiterDecisionGateway" targetRef="CloseByTimeout">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'VACANCY_CLOSED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F12" sourceRef="Transaction_Rejection" targetRef="NotifyRejection" />
    <bpmn:sequenceFlow id="F13" sourceRef="NotifyRejection" targetRef="RejectionResultTask" />
    <bpmn:sequenceFlow id="F_MSG_Result" sourceRef="HandleVacancyClosedMessage" targetRef="VacancyClosedApplicationResultTask" />
    <bpmn:sequenceFlow id="F_MSG_End" sourceRef="VacancyClosedApplicationResultTask" targetRef="ClosedByVacancyEnd" />
    <bpmn:sequenceFlow id="F13b" sourceRef="RejectionResultTask" targetRef="RejectedEnd" />
    <bpmn:sequenceFlow id="F9" sourceRef="RecruiterDecisionTask" targetRef="ValidateRecruiterDecisionForm" />
    <bpmn:sequenceFlow id="F10" sourceRef="ValidateRecruiterDecisionForm" targetRef="PrepareRecruiterDecisionTransition" />
    <bpmn:sequenceFlow id="F19" sourceRef="CandidateInvitationResponseTask" targetRef="CandidateResponseGateway" />
    <bpmn:sequenceFlow id="F_MSG_InterviewCancelled" name="тип ответа: интервью отменил рекрутер" sourceRef="InterviewCancelledAtCandidateResponse" targetRef="CandidateResponseGateway" />
    <bpmn:sequenceFlow id="F_MSG_AdminResetDone" name="тип ответа: интервью сбросил администратор" sourceRef="AdminResetDoneAtCandidateResponse" targetRef="CandidateResponseGateway" />
    <bpmn:sequenceFlow id="F_MSG_InvitationExpired" name="тип ответа: приглашение просрочено" sourceRef="InvitationExpiredAtCandidateResponse" targetRef="CandidateResponseGateway" />
    <bpmn:sequenceFlow id="F21" sourceRef="CandidateResponseGateway" targetRef="Transaction_Rejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'RECRUITER_REJECT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F20" sourceRef="CandidateResponseGateway" targetRef="CloseByTimeout">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'TIMEOUT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F21b" sourceRef="CandidateResponseGateway" targetRef="ResolveRecruiterDecisionPermission">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType == 'RECRUITER_CANCEL' || responseType == 'ADMIN_RESET'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F22" sourceRef="CandidateResponseGateway" targetRef="ValidateCandidateResponseForm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${responseType != 'TIMEOUT' &amp;&amp; responseType != 'RECRUITER_REJECT' &amp;&amp; responseType != 'RECRUITER_CANCEL' &amp;&amp; responseType != 'ADMIN_RESET'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F23" sourceRef="ValidateCandidateResponseForm" targetRef="PrepareCandidateResponseTransition" />
    <bpmn:sequenceFlow id="F23_DMN_PREPARED" name="статус и действие подготовлены" sourceRef="PrepareCandidateResponseTransition" targetRef="EvaluateCandidateResponseTransition" />
    <bpmn:sequenceFlow id="F23_DMN_EVALUATED" name="таблица решений вернула разрешение и следующий статус" sourceRef="EvaluateCandidateResponseTransition" targetRef="CandidateResponseTransitionGateway" />
    <bpmn:sequenceFlow id="F27b" sourceRef="TimeoutResultTask" targetRef="TimeoutEnd" />
    <bpmn:sequenceFlow id="F_MSG_VacancyClosedAtRecruiterDecision" sourceRef="VacancyClosedAtRecruiterDecision" targetRef="HandleVacancyClosedMessage" />
    <bpmn:sequenceFlow id="F_MSG_VacancyClosedAtInvitation" sourceRef="VacancyClosedAtInvitation" targetRef="HandleVacancyClosedMessage" />
    <bpmn:sequenceFlow id="F_MSG_VacancyClosedAtCandidateResponse" sourceRef="VacancyClosedAtCandidateResponse" targetRef="HandleVacancyClosedMessage" />
    <bpmn:sequenceFlow id="F7" sourceRef="NotifyScreeningFailed" targetRef="ScreeningResultTask" />
    <bpmn:sequenceFlow id="F7b" sourceRef="ScreeningResultTask" targetRef="ScreeningFailedEnd" />
    <bpmn:sequenceFlow id="F18" sourceRef="NotifyInvitation" targetRef="ResolveCandidateResponsePermission" />
    <bpmn:sequenceFlow id="F18_DMN_Resolve" name="данные для проверки прав подготовлены" sourceRef="ResolveCandidateResponsePermission" targetRef="EvaluateCandidateResponsePermission" />
    <bpmn:sequenceFlow id="F18_DMN_Evaluate" name="решение таблицы получено" sourceRef="EvaluateCandidateResponsePermission" targetRef="CandidateResponsePermissionGateway" />
    <bpmn:sequenceFlow id="F18_DMN_Allowed" name="таблица решений разрешила доступ" sourceRef="CandidateResponsePermissionGateway" targetRef="CandidateInvitationResponseTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${permissionAllowed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F18_DMN_Denied" name="таблица решений запретила доступ" sourceRef="CandidateResponsePermissionGateway" targetRef="CandidateResponsePermissionDenied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${permissionAllowed != true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F17" sourceRef="Transaction_Invitation" targetRef="NotifyInvitation" />
    <bpmn:sequenceFlow id="F3" sourceRef="ValidateApplyToVacancyForm" targetRef="CreateApplicationFromForm" />
    <bpmn:sequenceFlow id="F3_CreateApplication" sourceRef="CreateApplicationFromForm" targetRef="AutoScreenApplication" />
    <bpmn:sequenceFlow id="F4" name="балл и порог подготовлены" sourceRef="AutoScreenApplication" targetRef="EvaluateAutoScreeningDecision" />
    <bpmn:sequenceFlow id="F4_DMN" name="таблица решений вернула результат скрининга" sourceRef="EvaluateAutoScreeningDecision" targetRef="SaveAutoScreenDecision" />
    <bpmn:sequenceFlow id="F8" sourceRef="NotifyRecruiter" targetRef="ResolveRecruiterDecisionPermission" />
    <bpmn:sequenceFlow id="F8_DMN_Resolve" name="данные для проверки прав подготовлены" sourceRef="ResolveRecruiterDecisionPermission" targetRef="EvaluateRecruiterDecisionPermission" />
    <bpmn:sequenceFlow id="F8_DMN_Evaluate" name="решение таблицы получено" sourceRef="EvaluateRecruiterDecisionPermission" targetRef="RecruiterDecisionPermissionGateway" />
    <bpmn:sequenceFlow id="F8_DMN_Allowed" name="таблица решений разрешила доступ" sourceRef="RecruiterDecisionPermissionGateway" targetRef="RecruiterDecisionTask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${permissionAllowed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F8_DMN_Denied" name="таблица решений запретила доступ" sourceRef="RecruiterDecisionPermissionGateway" targetRef="RecruiterDecisionPermissionDenied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${permissionAllowed != true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F9e" sourceRef="RecruiterDecisionFormError" targetRef="RecruiterDecisionTask" />
    <bpmn:sequenceFlow id="F15" sourceRef="WriteInvitationTask" targetRef="ValidateInvitationForm" />
    <bpmn:sequenceFlow id="F16" sourceRef="ValidateInvitationForm" targetRef="Transaction_Invitation" />
    <bpmn:sequenceFlow id="F10_DMN_DENIED" name="таблица решений запретила переход" sourceRef="RecruiterDecisionTransitionGateway" targetRef="RecruiterDecisionTransitionDenied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed != true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F15e" sourceRef="InvitationFormValidationError" targetRef="WriteInvitationTask" />
    <bpmn:sequenceFlow id="F25b" sourceRef="CandidateResponseResultTask" targetRef="ResponseEnd" />
    <bpmn:sequenceFlow id="F25" sourceRef="NotifyCandidateResponse" targetRef="CandidateResponseResultTask" />
    <bpmn:sequenceFlow id="F24" sourceRef="Transaction_Response" targetRef="NotifyCandidateResponse" />
    <bpmn:sequenceFlow id="F30_COMPENSATE" name="компенсация выполнена" sourceRef="ThrowCompensationApplicationRollback" targetRef="RollbackApplicationTransaction" />
    <bpmn:sequenceFlow id="F31" sourceRef="RollbackApplicationTransaction" targetRef="ApplicationRollbackEnd" />
    <bpmn:sequenceFlow id="F_ERR_REJECTION_COMPENSATE" name="ошибка отказа: запустить компенсацию" sourceRef="RejectionTxError" targetRef="ThrowCompensationApplicationRollback" />
    <bpmn:sequenceFlow id="F_ERR_INVITATION_COMPENSATE" name="ошибка приглашения: запустить компенсацию" sourceRef="PersistInvitationErrorBoundary" targetRef="ThrowCompensationApplicationRollback" />
    <bpmn:sequenceFlow id="F_ERR_RESPONSE_COMPENSATE" name="ошибка ответа кандидата: запустить компенсацию" sourceRef="PersistCandidateResponseErrorBoundary" targetRef="ThrowCompensationApplicationRollback" />
    <bpmn:sequenceFlow id="Flow_Cancel_Transaction_Rejection_Recovery" name="отмена транзакции отказа: восстановить данные" sourceRef="Cancel_Transaction_Rejection" targetRef="ThrowCompensationApplicationRollback" />
    <bpmn:sequenceFlow id="Flow_Cancel_Transaction_Invitation_Recovery" name="отмена транзакции приглашения: восстановить данные" sourceRef="Cancel_Transaction_Invitation" targetRef="ThrowCompensationApplicationRollback" />
    <bpmn:sequenceFlow id="Flow_Cancel_Transaction_Response_Recovery" name="отмена транзакции ответа: восстановить данные" sourceRef="Cancel_Transaction_Response" targetRef="ThrowCompensationApplicationRollback" />
    <bpmn:sequenceFlow id="F23_DMN_DENIED" name="таблица решений запретила переход" sourceRef="CandidateResponseTransitionGateway" targetRef="CandidateResponseTransitionDenied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed != true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F23_DMN_ALLOWED" name="таблица решений разрешила переход" sourceRef="CandidateResponseTransitionGateway" targetRef="Transaction_Response">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusTransition.allowed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F27" sourceRef="CloseByTimeout" targetRef="TimeoutResultTask" />
    <bpmn:sequenceFlow id="F26" sourceRef="InvitationTimeoutBoundary" targetRef="CloseByTimeout" />
    <bpmn:sequenceFlow id="F22e" sourceRef="CandidateResponseFormError" targetRef="CandidateInvitationResponseTask" />
    <bpmn:serviceTask id="ValidateCandidateResponseForm" name="Проверить форму ответа кандидата" camunda:type="external" camunda:topic="form-validation" />
    <bpmn:boundaryEvent id="CandidateResponseFormError" attachedToRef="ValidateCandidateResponseForm">
      <bpmn:errorEventDefinition errorRef="Error_FormValidationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="CandidateResponseGateway" name="Как ответил кандидат?" />
    <bpmn:exclusiveGateway id="CandidateResponsePermissionGateway" name="Кандидат имеет право ответить на это приглашение?" />
    <bpmn:businessRuleTask id="EvaluateCandidateResponsePermission" name="Таблица решений: проверить право кандидата ответить на приглашение" camunda:resultVariable="permissionAllowed" camunda:decisionRef="hhOperationPermissions" camunda:mapDecisionResult="singleEntry" />
    <bpmn:serviceTask id="ResolveCandidateResponsePermission" name="Система: собрать данные для проверки права ответить на приглашение" camunda:type="external" camunda:topic="permission-check" />
    <bpmn:callActivity id="NotifyRejection" name="Подпроцесс: уведомить кандидата об отказе" calledElement="hhNotificationProcess">
      <bpmn:extensionElements>
        <camunda:in sourceExpression="${&#39;REJECTION&#39;}" target="notificationKind" />
        <camunda:in source="applicationId" target="applicationId" />
        <camunda:out source="notificationDispatched" target="NotifyRejectionDispatched" />
        <camunda:out source="notificationKind" target="lastNotificationKind" />
      </bpmn:extensionElements>
    </bpmn:callActivity>
    <bpmn:serviceTask id="Compensate_Transaction_Invitation" name="Компенсация: отменить созданное приглашение" isForCompensation="true" camunda:type="external" camunda:topic="transaction-rollback" />
    <bpmn:userTask id="CandidateInvitationResponseTask" name="Кандидат отвечает на приглашение" camunda:formRef="invitation-response-form" camunda:formRefBinding="latest" camunda:assignee="${candidateCamundaUserId}" />
    <bpmn:boundaryEvent id="InvitationExpiredAtCandidateResponse" name="Событие: приглашение просрочено" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:messageEventDefinition messageRef="Message_InvitationExpired" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="AdminResetDoneAtCandidateResponse" name="Событие: администратор сбросил интервью" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:messageEventDefinition messageRef="Message_AdminResetDone" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="InterviewCancelledAtCandidateResponse" name="Событие: интервью отменено рекрутером" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:messageEventDefinition messageRef="Message_InterviewCancelled" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="VacancyClosedAtCandidateResponse" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:messageEventDefinition messageRef="Message_VacancyClosed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="InvitationTimeoutBoundary" attachedToRef="CandidateInvitationResponseTask">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">${execution.hasVariable('invitationTimeoutDuration') ? invitationTimeoutDuration : 'PT24H'}</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:association id="Association_Compensate_Transaction_Rejection" sourceRef="Compensate_Transaction_Rejection_Boundary" targetRef="Compensate_Transaction_Rejection" />
    <bpmn:association id="Association_Compensate_Transaction_Response" sourceRef="Compensate_Transaction_Response_Boundary" targetRef="Compensate_Transaction_Response" />
    <bpmn:association id="Association_Compensate_Transaction_Invitation" sourceRef="Compensate_Transaction_Invitation_Boundary" targetRef="Compensate_Transaction_Invitation" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AutoLayout">
    <bpmndi:BPMNPlane id="BPMNPlane_AutoLayout" bpmnElement="Collaboration_hhApplicationProcess">
