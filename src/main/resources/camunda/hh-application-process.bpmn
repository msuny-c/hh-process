        <dc:Bounds x="5440" y="255" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ValidateRecruiterDecisionForm" bpmnElement="ValidateRecruiterDecisionForm">
        <dc:Bounds x="2880" y="680" width="170" height="80" />
      </bpmndi:BPMNShape>
