<?xml version="1.0" encoding="UTF-8"?>
<jboss-deployment-structure>
    <deployment>
        <exclusions>
            <module name="org.hibernate" slot="main"/>
            <module name="org.hibernate.commons.annotations" slot="main"/>
            <module name="org.hibernate.validator" slot="main"/>
            <module name="org.hibernate.validator.cdi" slot="main"/>
            <!-- Без этого WildFly подменяет Logback своим SLF4J binding -->
            <module name="org.slf4j.impl"/>
            <module name="org.slf4j.jboss-logmanager"/>
        </exclusions>
    </deployment>
</jboss-deployment-structure>