# Copy this file to app.env on Helios and edit values.
# This file is loaded by infra/appctl.sh and infra/helios/*.sh.

# ===== Helios / FreeBSD target =====
# Check with: freebsd-version
TARGET_OS=FreeBSD 14.4-STABLE

# ===== Java / WildFly =====
# Current project uses Spring Boot 3.x / jakarta.*, so the runtime WildFly must be Jakarta-compatible.
# Do not use WildFly 21 for this branch unless the application is migrated to Spring Boot 2.x / javax.*.
JAVA_HOME=${HOME}/jdk-17
WILDFLY_HOME=${HOME}/wildfly/wildfly-40.0.0.Final

# Your Helios portbase from the journal. Example: 32318
PORTBASE=32318

# Ports are computed from PORTBASE by scripts if these values are omitted.
# WILDFLY_HTTP_PORT=${PORTBASE}
# WILDFLY_AJP_PORT=$((PORTBASE + 1))
# WILDFLY_HTTPS_PORT=$((PORTBASE + 2))
# WILDFLY_MANAGEMENT_HTTP_PORT=$((PORTBASE + 3))
# WILDFLY_MANAGEMENT_HTTPS_PORT=$((PORTBASE + 4))

# Bind public web interface. On Helios use 0.0.0.0 to make HTTP visible outside localhost.
WILDFLY_BIND_ADDRESS=0.0.0.0
# Management can stay localhost unless you really need remote management.
WILDFLY_MANAGEMENT_BIND_ADDRESS=127.0.0.1

# ===== PostgreSQL =====
# In Docker this was provided by docker-compose. On Helios/FreeBSD this must point to a real PostgreSQL.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public

# PostgreSQL must have max_prepared_transactions > 0 for JTA/Narayana XA transactions.
# In Docker Compose it is set to 100. For a shared Helios DB, ask/verify with:
# SHOW max_prepared_transactions;

# ===== Standalone Camunda 7 Run =====
# Start Camunda as a separate service and point the WildFly-deployed application to its REST API.
CAMUNDA_ENABLED=true
CAMUNDA_BASE_URL=http://localhost:8081/engine-rest
CAMUNDA_USERNAME=
CAMUNDA_PASSWORD=
CAMUNDA_FAIL_ON_ERROR=false
CAMUNDA_WORKER_ENABLED=true

# ===== Application runtime data =====
APP_HOME=${HOME}/hh-process
NARAYANA_LOG_DIR=${APP_HOME}/transaction-logs
NARAYANA_NODE_IDENTIFIER=hh-process-helios
NARAYANA_DEFAULT_TIMEOUT=60
APP_SECURITY_USERS_XML=${APP_HOME}/data/users.xml
WS_ALLOWED_ORIGINS=*

# Optional JVM memory. Adjust if Helios limits memory.
JAVA_OPTS=-Xms128m -Xmx512m
