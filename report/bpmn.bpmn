      <bpmn2:incoming>Flow_0uxraj5</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_1nrownf" sourceRef="Start_Candidate" targetRef="Task_SendApplication" />
    <bpmn2:sequenceFlow id="Flow_01ujw1p" sourceRef="Task_SendApplication" targetRef="Throw_Application" />
