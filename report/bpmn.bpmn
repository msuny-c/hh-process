        <bpmn2:flowNodeRef>Task_Review</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_Decide</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>GW_HRDecision</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_SendInvite</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_SendRejectionHR</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Throw_Employer_RejectionHR</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Throw_Employer_Invite</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>GW_WaitInviteResponse</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Catch_Employer_InviteTimeout</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>End_Employer_RejectedHR</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Catch_Employer_InviteResponse</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_CloseByTimeout</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_RecordInviteResponse</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>End_Employer_Invited</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>End_Employer_Timeout</bpmn2:flowNodeRef>
