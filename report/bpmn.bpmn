    <bpmn2:sequenceFlow id="EF_20_invite_record" sourceRef="Catch_Employer_InviteResponse" targetRef="Task_RecordInviteResponse" />
    <bpmn2:sequenceFlow id="EF_21_invite_end" sourceRef="Task_RecordInviteResponse" targetRef="End_Employer_Invited" />
