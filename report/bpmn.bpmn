    <bpmn2:messageFlow id="Flow_04dqpmy" sourceRef="Throw_Employer_RejectionHR" targetRef="Catch_Candidate_Rejection" />
  </bpmn2:collaboration>
  <bpmn2:process id="Process_Candidate" name="Соискатель: отклик и ответы" isExecutable="false">
