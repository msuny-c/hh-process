      <bpmn2:outgoing>Flow_0h87s0m</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:intermediateThrowEvent id="Throw_Employer_RejectionHR" name="Отправить отказ (HR)">
