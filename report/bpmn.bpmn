    </bpmn2:serviceTask>
    <bpmn2:endEvent id="End_Employer_Invited" name="Завершено: приглашение обработано">
      <bpmn2:incoming>Flow_1apdu72</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:endEvent id="End_Employer_Timeout" name="Завершено: таймаут">
      <bpmn2:incoming>Flow_09fpdkv</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_1h1oyx2" sourceRef="Start_Employer_Application" targetRef="Task_CheckVacancy" />
    <bpmn2:sequenceFlow id="Flow_0larcv0" sourceRef="Task_CheckVacancy" targetRef="GW_VacancyActive" />
    <bpmn2:sequenceFlow id="EF_4_yes" name="Да" sourceRef="GW_VacancyActive" targetRef="Task_Save" />
    <bpmn2:sequenceFlow id="Flow_0ezv9cq" sourceRef="Task_Save" targetRef="Task_AutoScreen" />
    <bpmn2:sequenceFlow id="Flow_0m1xuux" name="Нет" sourceRef="GW_VacancyActive" targetRef="Task_ComposeClosed" />
    <bpmn2:sequenceFlow id="Flow_00uml7f" sourceRef="Task_ComposeClosed" targetRef="Throw_Employer_Closed" />
    <bpmn2:sequenceFlow id="Flow_05az4yi" name="Нет" sourceRef="GW_AutoPass" targetRef="Task_ComposeRejectionAuto" />
