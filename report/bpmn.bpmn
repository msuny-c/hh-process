      <bpmn2:messageEventDefinition messageRef="Message_Closed" />
    </bpmn2:intermediateThrowEvent>
    <bpmn2:serviceTask id="Task_ComposeRejectionAuto" name="Сформировать отказ (авто)">
      <bpmn2:incoming>Flow_05az4yi</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1x8eli1</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_07yc2e3</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:intermediateThrowEvent id="Throw_Employer_Rejection" name="Отправить отказ (авто)">
      <bpmn2:incoming>Flow_1x8eli1</bpmn2:incoming>
      <bpmn2:messageEventDefinition messageRef="Message_Rejection" />
    </bpmn2:intermediateThrowEvent>
    <bpmn2:endEvent id="End_Employer_RejectedAuto" name="Завершено: отказ (авто)">
      <bpmn2:incoming>Flow_07yc2e3</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:serviceTask id="Task_AutoScreen" name="Автоскрининг резюме">
      <bpmn2:incoming>Flow_0ezv9cq</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1vol4hv</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:exclusiveGateway id="GW_AutoPass" name="Прошел автоскрининг?">
      <bpmn2:incoming>Flow_1vol4hv</bpmn2:incoming>
      <bpmn2:outgoing>Flow_07956s1</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_05az4yi</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:userTask id="Task_Review" name="Рассмотреть отклик">
