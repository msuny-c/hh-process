    <bpmn2:sequenceFlow id="Flow_0uxraj5" sourceRef="Catch_Candidate_Rejection" targetRef="End_Candidate_Rejection" />
  </bpmn2:process>
  <bpmn2:process id="Process_Employer" name="hh.ru: обработка отклика" isExecutable="true">
    <bpmn2:laneSet id="LaneSet_Employer">
