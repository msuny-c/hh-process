    <bpmn2:endEvent id="End_Candidate_Closed" name="Завершено: вакансия закрыта">
      <bpmn2:incoming>Flow_0a4saze</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:intermediateCatchEvent id="Catch_Candidate_Invite" name="Получено приглашение">
