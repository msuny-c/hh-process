      <bpmn2:outgoing>Flow_0vm39lm</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_1l71hwx</bpmn2:outgoing>
    </bpmn2:eventBasedGateway>
    <bpmn2:intermediateCatchEvent id="Catch_Employer_InviteTimeout" name="Срок ответа истек (48ч)">
      <bpmn2:incoming>Flow_1l71hwx</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1mknlrn</bpmn2:outgoing>
      <bpmn2:timerEventDefinition>
        <bpmn2:timeDuration xsi:type="bpmn2:tFormalExpression">PT48H</bpmn2:timeDuration>
      </bpmn2:timerEventDefinition>
    </bpmn2:intermediateCatchEvent>
    <bpmn2:endEvent id="End_Employer_RejectedHR" name="Завершено: отказ (HR)">
      <bpmn2:incoming>Flow_14tqqv3</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:intermediateCatchEvent id="Catch_Employer_InviteResponse" name="Ответ на приглашение получен">
      <bpmn2:incoming>Flow_0vm39lm</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0e9my2q</bpmn2:outgoing>
