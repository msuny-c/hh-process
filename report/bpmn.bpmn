    <bpmn2:sequenceFlow id="EF_4_no" name="Нет" sourceRef="GW_VacancyActive" targetRef="Task_ComposeClosed" />
    <bpmn2:sequenceFlow id="EF_5_closed" sourceRef="Task_ComposeClosed" targetRef="Throw_Employer_Closed" />
