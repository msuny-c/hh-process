    <bpmn2:sequenceFlow id="CF_7" sourceRef="GW_Candidate_Wait" targetRef="Catch_Candidate_Closed" />
    <bpmn2:sequenceFlow id="CF_8" sourceRef="Catch_Candidate_Rejection" targetRef="End_Candidate_Rejection" />
    <bpmn2:sequenceFlow id="CF_9" sourceRef="Catch_Candidate_Invite" targetRef="Task_AnswerInvite" />
    <bpmn2:sequenceFlow id="CF_10" sourceRef="Task_AnswerInvite" targetRef="Throw_Candidate_InviteResponse" />
    <bpmn2:sequenceFlow id="CF_11" sourceRef="Throw_Candidate_InviteResponse" targetRef="End_Candidate_Invite" />
    <bpmn2:sequenceFlow id="CF_12" />
    <bpmn2:sequenceFlow id="CF_13" />
    <bpmn2:sequenceFlow id="CF_14" targetRef="GW_Candidate_Wait" />
    <bpmn2:sequenceFlow id="CF_15" sourceRef="Catch_Candidate_Closed" targetRef="End_Candidate_Closed" />
    <bpmn2:dataStoreReference id="DataStoreReference_0frowtv" />
    <bpmn2:userTask id="Task_SendApplication" name="Отправить отклик">
      <bpmn2:incoming>Flow_1nrownf</bpmn2:incoming>
      <bpmn2:outgoing>Flow_01ujw1p</bpmn2:outgoing>
