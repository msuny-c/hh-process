      <bpmn2:outgoing>Flow_14tqqv3</bpmn2:outgoing>
      <bpmn2:messageEventDefinition messageRef="Message_Rejection" />
    </bpmn2:intermediateThrowEvent>
    <bpmn2:intermediateThrowEvent id="Throw_Employer_Invite" name="Отправить приглашение">
      <bpmn2:incoming>Flow_0a3olx4</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1pcpt18</bpmn2:outgoing>
      <bpmn2:messageEventDefinition messageRef="Message_Invite" />
    </bpmn2:intermediateThrowEvent>
    <bpmn2:eventBasedGateway id="GW_WaitInviteResponse" name="Ожидать ответ соискателя">
