      <bpmn2:outgoing>Flow_0a985vc</bpmn2:outgoing>
      <bpmn2:messageEventDefinition messageRef="Message_Invite" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:userTask id="Task_AnswerInvite" name="Ответить на приглашение">
      <bpmn2:incoming>Flow_0a985vc</bpmn2:incoming>
      <bpmn2:outgoing>Flow_11va872</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:intermediateThrowEvent id="Throw_Candidate_InviteResponse" name="Ответ отправлен">
