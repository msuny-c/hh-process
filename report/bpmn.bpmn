    <bpmn2:sequenceFlow id="EF_8_no" name="Нет" sourceRef="GW_AutoPass" targetRef="Task_ComposeRejectionAuto" />
    <bpmn2:sequenceFlow id="EF_9" sourceRef="Task_ComposeRejectionAuto" targetRef="Throw_Employer_Rejection" />
    <bpmn2:sequenceFlow id="EF_10" sourceRef="Throw_Employer_Rejection" targetRef="End_Employer_RejectedAuto" />
    <bpmn2:sequenceFlow id="EF_11" sourceRef="Task_Review" targetRef="Task_Decide" />
    <bpmn2:sequenceFlow id="EF_12" sourceRef="Task_Decide" targetRef="GW_HRDecision" />
    <bpmn2:sequenceFlow id="EF_13_reject" name="Отказать" sourceRef="GW_HRDecision" targetRef="Task_SendRejectionHR" />
    <bpmn2:sequenceFlow id="EF_14_reject" sourceRef="Task_SendRejectionHR" targetRef="Throw_Employer_RejectionHR" />
    <bpmn2:sequenceFlow id="EF_15_reject" sourceRef="Throw_Employer_RejectionHR" targetRef="End_Employer_RejectedHR" />
    <bpmn2:sequenceFlow id="EF_13_invite" name="Пригласить" sourceRef="GW_HRDecision" targetRef="Task_SendInvite" />
    <bpmn2:sequenceFlow id="EF_16_invite" sourceRef="Task_SendInvite" targetRef="Throw_Employer_Invite" />
    <bpmn2:sequenceFlow id="EF_17_invite_wait" sourceRef="Throw_Employer_Invite" targetRef="GW_WaitInviteResponse" />
    <bpmn2:sequenceFlow id="EF_18_invite_msg" sourceRef="GW_WaitInviteResponse" targetRef="Catch_Employer_InviteResponse" />
