        <bpmn2:flowNodeRef>Task_CheckVacancy</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_Save</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>GW_VacancyActive</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_ComposeClosed</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Throw_Employer_Closed</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_ComposeRejectionAuto</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Throw_Employer_Rejection</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>End_Employer_RejectedAuto</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_AutoScreen</bpmn2:flowNodeRef>
