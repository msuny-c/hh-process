    <bpmn2:sequenceFlow id="EF_23_timeout_end" sourceRef="Task_CloseByTimeout" targetRef="End_Employer_Timeout" />
    <bpmn2:sequenceFlow id="EF_13_clarify" name="Уточнить" sourceRef="GW_HRDecision" />
    <bpmn2:sequenceFlow id="EF_24_clarify_send" />
    <bpmn2:sequenceFlow id="EF_25_clarify_wait" />
    <bpmn2:sequenceFlow id="EF_26_clarify_msg" />
    <bpmn2:sequenceFlow id="EF_27_clarify_timer" />
    <bpmn2:sequenceFlow id="EF_28_clarify_to_hr" />
    <bpmn2:sequenceFlow id="EF_29_hr_loop" targetRef="Task_Decide" />
    <bpmn2:sequenceFlow id="EF_30_no_clarify" />
    <bpmn2:sequenceFlow id="EF_31_no_clarify_end" />
    <bpmn2:startEvent id="Start_Employer_Application" name="Получен отклик">
