      <bpmn2:outgoing>Flow_09fpdkv</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:serviceTask id="Task_RecordInviteResponse" name="Зафиксировать ответ и обновить статус">
      <bpmn2:incoming>Flow_0e9my2q</bpmn2:incoming>
