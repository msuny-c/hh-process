      <bpmn2:outgoing>Flow_0ljub1h</bpmn2:outgoing>
      <bpmn2:messageEventDefinition messageRef="Message_InviteResponse" />
    </bpmn2:intermediateThrowEvent>
    <bpmn2:endEvent id="End_Candidate_Invite" name="Завершено: ответ на приглашение">
