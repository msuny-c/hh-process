      <bpmn2:outgoing>Flow_0hafgze</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:serviceTask id="Task_SendInvite" name="Сформировать приглашение">
      <bpmn2:incoming>Flow_0hafgze</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0a3olx4</bpmn2:outgoing>
    </bpmn2:serviceTask>
    <bpmn2:serviceTask id="Task_SendRejectionHR" name="Сформировать отказ (HR)">
