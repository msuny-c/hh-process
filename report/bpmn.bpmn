    <bpmn2:messageFlow id="MF_Invite" sourceRef="Throw_Employer_Invite" targetRef="Catch_Candidate_Invite" messageRef="Message_Invite" />
    <bpmn2:messageFlow id="MF_InviteResponse" sourceRef="Throw_Candidate_InviteResponse" targetRef="Catch_Employer_InviteResponse" messageRef="Message_InviteResponse" />
